		// "MISSING" = "[cheering]"
		"ep_02.sheckley_12crazy" = "<clr:251,218,194>12's going crazy!"
		"ep_02.sheckley_24lit" = "<clr:251,218,194>24's lit up!"
		"ep_02.sheckley_24swarm" = "<clr:251,218,194>Swarm at 24!"
		"ep_02.sheckley_36again" = "<clr:251,218,194>36 again!"
		"ep_02.sheckley_36majorswarm" = "<clr:251,218,194>Major swarm!"
		"ep_02.sheckley_36overthere" = "<clr:251,218,194>Over there!"
		"ep_02.sheckley_aboutthat" = "<clr:251,218,194>Yeah, well, about that... "
		"ep_02.sheckley_aboutthat_alt" = "<clr:251,218,194>Yeah, well, about that... "
		"ep_02.sheckley_afteralyx" = "<clr:251,218,194>They're going after Alyx!"
		"ep_02.sheckley_ahcrap" = "<clr:251,218,194>Ahh crap!"
		"ep_02.sheckley_altvortarrive" = "<clr:251,218,194>Hey! It's the vorts!  They made it!"
		"ep_02.sheckley_and12" = "<clr:251,218,194>And 12!"
		"ep_02.sheckley_and24" = "<clr:251,218,194>And 24!"
		"ep_02.sheckley_and36" = "<clr:251,218,194>And 36!"
		"ep_02.sheckley_andbreach" = "<clr:251,218,194>And the Breach!"
		"ep_02.sheckley_at12" = "<clr:251,218,194>They're at 12!"
		"ep_02.sheckley_at12again" = "<clr:251,218,194>They're at 12 again!"
		"ep_02.sheckley_atbreach" = "<clr:251,218,194>They're at the breach!"
		"ep_02.sheckley_awayfromvort" = "<clr:251,218,194>Get em away from the vort!"
		"ep_02.sheckley_badturret" = "<clr:251,218,194>That's the one we call the Great Satan."
		"ep_02.sheckley_badturret_alt" = "<clr:251,218,194>That's the one we like to call the Great Satan"
		"ep_02.sheckley_betweenwave_01" = "<clr:251,218,194>All right, doc!"
		"ep_02.sheckley_betweenwave_02" = "<clr:251,218,194>Doc, you ever see an antlion before?"
		"ep_02.sheckley_betweenwave_03" = "<clr:251,218,194>Yeah!"
		"ep_02.sheckley_betweenwave_04" = "<clr:251,218,194>All right!"
		"ep_02.sheckley_betweenwave_05" = "<clr:251,218,194>I hope that was the last wave."
		"ep_02.sheckley_betweenwave_06" = "<clr:251,218,194>We're doin' pretty good."
		"ep_02.sheckley_betweenwave_conver1_01" = "<clr:251,218,194>Yeah, we all got ten, there's hundreds of 'em."
		"ep_02.sheckley_betweenwave_conver2_01" = "<clr:251,218,194>What?"
		"ep_02.sheckley_betweenwave_conver2_02" = "<clr:251,218,194>WHAT?"
		"ep_02.sheckley_betweenwave_conver3_01" = "<clr:251,218,194>What the hell makes you think that?"
		"ep_02.sheckley_betweenwave_conver4_01" = "<clr:251,218,194>If you see a bug on me, how about you try and get it off next time."
		"ep_02.sheckley_betweenwave_conver4_02" = "<clr:251,218,194>Yeah. No. Sure. They're only like five feet tall. "
		"ep_02.sheckley_breachagain" = "<clr:251,218,194>The breach again!"
		"ep_02.sheckley_bye01" = "<clr:251,218,194>See ya!  "
		"ep_02.sheckley_bye02" = "<clr:251,218,194>Good luck out there"
		"ep_02.sheckley_cantholdout" = "<clr:251,218,194>We can't hold out much longer."
		"ep_02.sheckley_cavalry" = "<clr:251,218,194>I think you mean cavalry."
		"ep_02.sheckley_comingfrom24" = "<clr:251,218,194>They're coming from 24 again!"
		"ep_02.sheckley_cover12" = "<clr:251,218,194>Cover 12!"
		"ep_02.sheckley_cover24" = "<clr:251,218,194>Cover 24!"
		"ep_02.sheckley_cover36" = "<clr:251,218,194>Cover 36!"
		"ep_02.sheckley_covervort" = "<clr:251,218,194>Cover the vort!"
		"ep_02.sheckley_dochelpvort" = "<clr:251,218,194>Doc, help the vort!"
		"ep_02.sheckley_dontcount01" = "<clr:251,218,194>Let's move!  "
		"ep_02.sheckley_dontcount02" = "<clr:251,218,194>We have to defend the vort."
		"ep_02.sheckley_downhere01" = "<clr:251,218,194>As long as you're down here, Freeman, maybe you can give us a hand.  "
		"ep_02.sheckley_downhere02" = "<clr:251,218,194>Let me show you how the antlion sensors work."
		"ep_02.sheckley_everywhere" = "<clr:251,218,194>Oh God, they're coming from everywhere!"
		"ep_02.sheckley_fightlion_01" = "<clr:251,218,194>Hey Griggs, did you see that?"
		"ep_02.sheckley_fightlion_02" = "<clr:251,218,194>Griggs, over there!"
		"ep_02.sheckley_following01" = "<clr:251,218,194>On my way."
		"ep_02.sheckley_following02" = "<clr:251,218,194>Yeah, yeah."
		"ep_02.sheckley_followme01" = "<clr:251,218,194>C'mon, Griggsy, move it."
		"ep_02.sheckley_followme02" = "<clr:251,218,194>Let's go Griggs."
		"ep_02.sheckley_followme03" = "<clr:251,218,194>Over here Griggs.  Hustle it."
		"ep_02.sheckley_followme04" = "<clr:251,218,194>Come on, come on, let's go."
		"ep_02.sheckley_followme05" = "<clr:251,218,194>Come on, try to keep up."
		"ep_02.sheckley_followme06" = "<clr:251,218,194>Are you coming or what?"
		"ep_02.sheckley_gogriggs" = "<clr:251,218,194>All right, Griggs!"
		"ep_02.sheckley_gohelpvort" = "<clr:251,218,194>Freeman, go help the vort!"
		"ep_02.sheckley_helldoesthatmean" = "<clr:251,218,194>What the hell does that mean, anyway?"
		"ep_02.sheckley_idiot02" = "<clr:251,218,194>You idiot, "
		"ep_02.sheckley_idiot03" = "<clr:251,218,194>that's Gordon Freeman"
		"ep_02.sheckley_incom36" = "<clr:251,218,194>Incoming at 36! "
		"ep_02.sheckley_junc_followvortnag01" = "<clr:251,218,194>Better get moving, Doc. Follow the Vort."
		"ep_02.sheckley_junc_followvortnag02" = "<clr:251,218,194>Seriously, Freeman, you need to get going."
		"ep_02.sheckley_junc_followvortnag03" = "<clr:251,218,194>Ms. Vance doesn't look so great, Doc. You better hurry up and follow the Vort."
		"ep_02.sheckley_junc_followvortnag04" = "<clr:251,218,194>We're all tired, Freeman, but you can't just sit around here. Follow the Vort!"
		"ep_02.sheckley_junc_yousaidthat" = "<clr:251,218,194>I can't believe you said that."
		"ep_02.sheckley_keepeye" = "<clr:251,218,194>Freeman! Keep your eye on the lights!"
		"ep_02.sheckley_keepmoving" = "<clr:251,218,194>Just shut up and keep movin'."
		"ep_02.sheckley_keepsupplies" = "<clr:251,218,194>Hey Griggs, you might want to show Dr. Freeman where we keep all the supplies, huh?"
		"ep_02.sheckley_killlion_01" = "<clr:251,218,194>Hahah."
		"ep_02.sheckley_killlion_02" = "<clr:251,218,194>Should I leave some for you Griggs, huh?"
		"ep_02.sheckley_killlion_03" = "<clr:251,218,194>Yeah. Yeah!"
		"ep_02.sheckley_lookalive" = "<clr:251,218,194>Look alive!"
		"ep_02.sheckley_moreat12" = "<clr:251,218,194>More at 12!"
		"ep_02.sheckley_moreat1breach" = "<clr:251,218,194>More at the breach!"
		"ep_02.sheckley_moreat24" = "<clr:251,218,194>More at 24!"
		"ep_02.sheckley_moreat36" = "<clr:251,218,194>More at 36!"
		"ep_02.sheckley_needagun" = "<clr:251,218,194>Hey Doc, if you need a gun, there's extras around."
		"ep_02.sheckley_needsomehelp" = "<clr:251,218,194>I might need some help on this one."
		"ep_02.sheckley_nestbigger" = "<clr:251,218,194>That nest must be bigger than we thought."
		"ep_02.sheckley_neverseen" = "<clr:251,218,194>Never seen this many all at once."
		"ep_02.sheckley_onedge01" = "<clr:251,218,194>Don't listen to him, Doc.  "
		"ep_02.sheckley_onedge02" = "<clr:251,218,194>We're on edge because this place is riddled with antlions."
		"ep_02.sheckley_onelight" = "<clr:251,218,194>One light!"
		"ep_02.sheckley_onenoproblem" = "<clr:251,218,194>No problem."
		"ep_02.sheckley_pickturretup" = "<clr:251,218,194>Pick your turret up!"
		"ep_02.sheckley_protectvort" = "<clr:251,218,194>Protect the vort!"
		"ep_02.sheckley_quietyou" = "<clr:251,218,194>Quiet you."
		"ep_02.sheckley_rightturret" = "<clr:251,218,194>Right that turret!"
		"ep_02.sheckley_somesupplies" = "<clr:251,218,194>Got some supplies over here if you need em.  Health and ammo.  That sort of thing."
		"ep_02.sheckley_swarmatbreach" = "<clr:251,218,194>Swarm! Swarm at the breach!"
		"ep_02.sheckley_theory01" = "<clr:251,218,194>Yeah, well, that's a theory I'd rather not test. "
		"ep_02.sheckley_theory02" = "<clr:251,218,194>We're down to our last two turrets, "
		"ep_02.sheckley_theory03" = "<clr:251,218,194>and even these are held together by baling wire and duct tape at this point.  "
		"ep_02.sheckley_theory04" = "<clr:251,218,194>Nice to have em in a pinch, "
		"ep_02.sheckley_theory05" = "<clr:251,218,194>but I wouldn't exactly trust em with my life."
		"ep_02.sheckley_thosevortswant" = "<clr:251,218,194>Don't look at me, I don't know what those vorts want"
		"ep_02.sheckley_threelights" = "<clr:251,218,194>Three lights!  We got three lights!"
		"ep_02.sheckley_threeomg" = "<clr:251,218,194>Oh my God!"
		"ep_02.sheckley_threeswarm" = "<clr:251,218,194>Swarm!"
		"ep_02.sheckley_thrubreach" = "<clr:251,218,194>They're coming through the breach!"
		"ep_02.sheckley_toomany" = "<clr:251,218,194>Too many!"
		"ep_02.sheckley_training01" = "<clr:251,218,194>This sensor will light up if an antlion is coming down this tunnel."
		"ep_02.sheckley_training02" = "<clr:251,218,194>More lights means more antlions."
		"ep_02.sheckley_training03" = "<clr:251,218,194>When a tunnel lights up, we move a few turrets in front of it.  "
		"ep_02.sheckley_training04" = "<clr:251,218,194>Pretty simple, eh, Doc?"
		"ep_02.sheckley_trainingnags01" = "<clr:251,218,194>Hey, Freeman, come on over here."
		"ep_02.sheckley_trainingnags02" = "<clr:251,218,194>Hey, Doc!  Over here."
		"ep_02.sheckley_trainingnags03" = "<clr:251,218,194>Done looking around?  We really gotta get ready."
		"ep_02.sheckley_trainingnags04" = "<clr:251,218,194>This is serious, Doc.  I need to show you how the defense system works before the next attack."
		"ep_02.sheckley_trainingnags05" = "<clr:251,218,194>Hey Griggs, you might want to show Dr. Freeman where we keep all the supplies, huh?"
		"ep_02.sheckley_tunnelpanic_01" = "<clr:251,218,194>Oh shit, the whole place is lit up. Grab a tunnel!"
		"ep_02.sheckley_tunnelpanic_02" = "<clr:251,218,194>The whole place is lightin' up, grab a tunnel!"
		"ep_02.sheckley_turretbroke" = "<clr:251,218,194>Ahh!  The last turret just broke!"
		"ep_02.sheckley_turretdown01" = "<clr:251,218,194>Turret down!"
		"ep_02.sheckley_turretdown02" = "<clr:251,218,194>One of the turrets got knocked over."
		"ep_02.sheckley_turretfeet" = "<clr:251,218,194>Get those turrets back on their feet!"
		"ep_02.sheckley_turretsturrets" = "<clr:251,218,194>Turrets!  Turrets!"
		"ep_02.sheckley_twolights" = "<clr:251,218,194>Two lights."
		"ep_02.sheckley_twothatmeans" = "<clr:251,218,194>That means two or three, right?"
		"ep_02.sheckley_underest" = "<clr:251,218,194>I think we misunderestimated."
		"ep_02.sheckley_vortintrouble" = "<clr:251,218,194>The VORT needs help!"
		"ep_02.sheckley_vortsaidonway01" = "<clr:251,218,194>The vortigaunt said he was on the way.  "
		"ep_02.sheckley_vortsaidonway02" = "<clr:251,218,194>Dr. Freeman, Alyx Vance is over here."
		"ep_02.sheckley_vortsaidonway03" = "<clr:251,218,194>The vort's trying to patch her up."
		"ep_02.sheckley_vortscalling" = "<clr:251,218,194>The vorts are calling you."
		"ep_02.sheckley_vortswantyou" = "<clr:251,218,194>Ah, I think the vorts want you down there."
		"ep_02.sheckley_watchall" = "<clr:251,218,194>Got to watch all the tunnels, Freeman!"
		"ep_02.sheckley_watchvorts_01" = "<clr:251,218,194>I'm glad they're on our side."
		"ep_02.sheckley_watchvorts_02" = "<clr:251,218,194>Look at 'em go!"
		"ep_02.sheckley_watchvorts_03" = "<clr:251,218,194>Griggsy, don't get near the green lightning."
		"ep_02.sheckley_watchvorts_04" = "<clr:251,218,194>Eat the Vortessence, you ant bastards!"
		"ep_02.sheckley_wecandothis" = "<clr:251,218,194>More lights, we can do this."
		"ep_02.sheckley_wegot_12_01" = "<clr:251,218,194>We got 12!"
		"ep_02.sheckley_wegot_12_02" = "<clr:251,218,194>We'll take 12!"
		"ep_02.sheckley_wegot_24_01" = "<clr:251,218,194>We got 24!"
		"ep_02.sheckley_wegot_24_02" = "<clr:251,218,194>We'll take 24!"
		"ep_02.sheckley_wegot_36_01" = "<clr:251,218,194>We got 36!"
		"ep_02.sheckley_wegot_36_02" = "<clr:251,218,194>We'll take 36!"
		"ep_02.sheckley_wegot_breach_01" = "<clr:251,218,194>We got the breach!"
		"ep_02.sheckley_wegot_breach_02" = "<clr:251,218,194>We'll take the breach!"
		"ep_02.sheckley_whysomany" = "<clr:251,218,194>Why are there so many?"
		"ep_02.sheckley_youtake_12_01" = "<clr:251,218,194>Hey doc, you cover 12!"
		"ep_02.sheckley_youtake_12_02" = "<clr:251,218,194>You handle 12, Doc!"
		"ep_02.sheckley_youtake_24_01" = "<clr:251,218,194>Hey doc, you cover 24!"
		"ep_02.sheckley_youtake_24_02" = "<clr:251,218,194>You handle 24, Doc!"
		"ep_02.sheckley_youtake_36_01" = "<clr:251,218,194>Hey doc, you cover 36!"
		"ep_02.sheckley_youtake_36_02" = "<clr:251,218,194>You handle 36, Doc!"
		"ep_02.sheckley_youtake_breach_01" = "<clr:251,218,194>Hey doc, you cover the breach!"
		"ep_02.sheckley_youtake_breach_02" = "<clr:251,218,194>You handle the breach, Doc!"
		"ep_02.sheckley_youturrets" = "<clr:251,218,194>Dr. Freeman, you take care of the turrets."
		"ep_02.rebc_chop_bootsmysize4" = "Do you think those boots are my size?"
		"ep_02.rebc_chop_hit01" = "Return to sender."
		"ep_02.rebc_chop_hit02" = "That's gonna leave a mark."
		"ep_02.rebc_chop_hit03" = "Doc, you're really puttin on a clinic."
		"ep_02.rebc_chop_hit04" = "How do you like a taste of your own medicine?"
		"ep_02.rebc_chop_shipdown01" = "It's all over but the shouting!"
		"ep_02.rebc_chop_shipdown02" = "I give the Combine a lot of credit, though. They're tough competitors, a real class act."
		"ep_02.reb_tvwatching_01" = "Hey, I was watching that!"
		"ep_02.reb_tvwatching_02" = "Thanks, Freeman."
		"ep_02.reb_tvwatching_03" = "[Groan...]"
		"ep_02.reb_tvwatching_04" = "I hate my life."
		"ep_02.vort_03_urgent_idle_01" = "<clr:188,241,174>I sense the Alyx Vance's thread unraveling. "
		"ep_02.vort_03_urgent_idle_02" = "<clr:188,241,174>Let us hurry, Freeman.  "
		"ep_02.vort_03_urgent_idle_03" = "<clr:188,241,174>We must make haste."
		"ep_02.vort_03_urgent_idle_04" = "<clr:188,241,174>The Alyx Vance depends on our success."
		"ep_02.vort_03_urgent_idle_05" = "<clr:188,241,174>I feel it - she fades."
		"ep_02.vort_03_urgent_idle_06" = "<clr:188,241,174>Onward, Freeman!"
		"ep_02.vort_03_urgent_idle_07" = "<clr:188,241,174>The Alyx Vance cannot remain corporeal for much longer."
		"ep_02.vort_03_urgent_idle_08" = "<clr:188,241,174>We must hasten.  "
		"ep_02.vort_04_elevator_descend_01" = "<clr:188,241,174>I descend!"
		"ep_02.vort_04_elevator_descend_02" = "<clr:188,241,174>Abide a moment longer, Freeman, that we may proceed together!"
		"ep_02.vort_04_enter_elevator_01" = "<clr:188,241,174>Freeman!"
		"ep_02.vort_04_enter_elevator_02" = "<clr:188,241,174>Attend!"
		"ep_02.vort_04_enter_elevator_03" = "<clr:188,241,174>Summon the elevator!"
		"ep_02.vort_acid_01" = "<clr:188,241,174>Beware, Freeman, acid!"
		"ep_02.vort_acid_02" = "<clr:188,241,174>These ones burn flesh!"
		"ep_02.vort_antlions_arrive_01" = "<clr:188,241,174>Antlions!"
		"ep_02.vort_antlions_arrive_02" = "<clr:188,241,174>Antlions approach!"
		"ep_02.vort_basket_puzzle_01" = "<clr:188,241,174>That appears to have had some effect."
		"ep_02.vort_basket_puzzle_02" = "<clr:188,241,174>The Freeman's plan is working!"
		"ep_02.vort_basket_puzzle_03" = "<clr:188,241,174>Continue that line of action, Freeman."
		"ep_02.vort_basket_success_01" = "<clr:188,241,174>Well done. "
		"ep_02.vort_basket_success_02" = "<clr:188,241,174>The way is unbarred. "
		"ep_02.vort_basket_success_03" = "<clr:188,241,174>We must press forward! "
		"ep_02.vort_breakweb01" = "<clr:188,241,174>Others of your kind less fortunate must have sheltered here."
		"ep_02.vort_breakweb02" = "<clr:188,241,174>The sad fate of these others is our good fortune."
		"ep_02.vort_breakweb03" = "<clr:188,241,174>Grim piñata...."
		"ep_02.vort_bridge_attempt" = "<clr:188,241,174>It appears they attempted an escape, but made it no farther than the abyss"
		"ep_02.vort_bridge_depleted01" = "<clr:188,241,174>Its power supply is depleted."
		"ep_02.vort_bridge_depleted02" = "<clr:188,241,174>The gun would appear to be powerless."
		"ep_02.vort_bridge_farewell" = "<clr:188,241,174>Likewise!  And farewell!  It has been an honor!"
		"ep_02.vort_bridge_gofm01" = "<clr:188,241,174>Go, Freeman."
		"ep_02.vort_bridge_gofm02" = "<clr:188,241,174>I will look after the Alyx Vance."
		"ep_02.vort_bridge_gunlacks" = "<clr:188,241,174>It is conceivable I can supply the power this gun lacks."
		"ep_02.vort_bridge_honored" = "<clr:188,241,174>Our bonds are of nature and require no gratitude."
		"ep_02.vort_bridge_host01" = "<clr:188,241,174>I detect numerous host-parasites in the depths."
		"ep_02.vort_bridge_host02" = "<clr:188,241,174>The recent refugees have had no experience in repelling common predators."
		"ep_02.vort_bridge_hunt01" = "<clr:188,241,174>I fear a more urgent errand demands our attention:  "
		"ep_02.vort_bridge_hunt02" = "<clr:188,241,174>There are Advisors yet unhatched. "
		"ep_02.vort_bridge_hunt03" = "<clr:188,241,174>We must see to it that they remain so."
		"ep_02.vort_bridge_nogoodend01" = "<clr:188,241,174>But came to no good end themselves."
		"ep_02.vort_bridge_nogoodend02" = "<clr:188,241,174>Headcrabs have had their way with both parties."
		"ep_02.vort_bridge_recommend" = "<clr:188,241,174>We recommend the Freeman for this task."
		"ep_02.vort_bridge_takeupaim01" = "<clr:188,241,174>That condition will not last long if you plunge into the toxins below.  "
		"ep_02.vort_bridge_takeupaim02" = "<clr:188,241,174>We would do well to lend our protection from above, while Freeman skirts the hazards in the pit."
		"ep_02.vort_bridge_thismountgun" = "<clr:188,241,174>This mounted gun may prove useful."
		"ep_02.vort_bridge_thisroad" = "<clr:188,241,174>This road will take you near White Forest, but be wary that others may use it as well."
		"ep_02.vort_canyon_advisor01" = "<clr:188,241,174>Ah yes, that is an advisor"
		"ep_02.vort_canyon_advisor02" = "<clr:188,241,174>Many were dispersed from the citadel when its destruction was imminent"
		"ep_02.vort_canyon_advisor03" = "<clr:188,241,174>Now with overwatch decapitated they will mobilize local forces until ties are reestablished with the realm of command."
		"ep_02.vort_canyon_enclavesentries01" = "<clr:188,241,174>The humans have their enclave on the rim of this canyon.  "
		"ep_02.vort_canyon_enclavesentries02" = "<clr:188,241,174>I do not see their sentries."
		"ep_02.vort_canyon_farfetch" = "<clr:188,241,174>Such a theory is hardly far-fetched."
		"ep_02.vort_canyon_guardianrage01" = "<clr:188,241,174>The guardian is enraged over our theft of the extract."
		"ep_02.vort_canyon_guardianrage02" = "<clr:188,241,174>If it tries to hinder our progress, we will have no choice but to kill it."
		"ep_02.vort_canyon_podparade01" = "<clr:188,241,174>Yes, and they carry Shu'ulathoi.  Advisors, still in incubation pods."
		"ep_02.vort_canyon_podparade02" = "<clr:188,241,174>They gather and unite the scattered Combine forces."
		"ep_02.vort_canyon_podparade03" = "<clr:188,241,174>That is why we must hunt and kill all we can before they emerge and gain their full power."
		"ep_02.vort_canyon_purpose" = "<clr:188,241,174>They move north with great purpose."
		"ep_02.vort_canyon_puzzling" = "<clr:188,241,174>Puzzling.  The sentries should have spotted us by now."
		"ep_02.vort_canyon_reside01" = "<clr:188,241,174>I know of humans with a vehicle, not far from here."
		"ep_02.vort_canyon_reside02" = "<clr:188,241,174>They will understand our urgent need."
		"ep_02.vort_canyon_towf" = "<clr:188,241,174>I fear at first, to white forest."
		"ep_02.vort_combat_combined01" = "<clr:188,241,174>It is unfortunate the Freeman's suit permits external harm."
		"ep_02.vort_combat_combined02" = "<clr:188,241,174>Your suit shows signs of stress, Freeman!"
		"ep_02.vort_extract_accompany" = "<clr:188,241,174>Now, Freeman.  Accompany!"
		"ep_02.vort_extract_aciddamage01" = "<clr:188,241,174>We have learned to exterminate the acid-lions from a distance."
		"ep_02.vort_extract_aciddamage02" = "<clr:188,241,174>Beware their caustic spray!"
		"ep_02.vort_extract_aciddamage03" = "<clr:188,241,174>Avoid close contact, Freeman!"
		"ep_02.vort_extract_aciddamage04" = "<clr:188,241,174>Explosive pest!"
		"ep_02.vort_extract_aciddamage05" = "<clr:188,241,174>Direct contact with such a foe is hardly wise."
		"ep_02.vort_extract_aciddamage06" = "<clr:188,241,174>Save your skills in melee for less explosive enemies."
		"ep_02.vort_extract_acidinfo01" = "<clr:188,241,174>Beware, the acid-lions spit from a distance!"
		"ep_02.vort_extract_acidinfo02" = "<clr:188,241,174>Guard yourself against the corrosive spray!"
		"ep_02.vort_extract_acidinfo03" = "<clr:188,241,174>Such spittle-it burns."
		"ep_02.vort_extract_acidinfo04" = "<clr:188,241,174>From afar, they squirt their acid!"
		"ep_02.vort_extract_acidinfo05" = "<clr:188,241,174>Beware the acid-lions.  Their corrosive spray permits quick carving of rock passages, but also serves as a strong deterrent to hive robbers like ourselves."
		"ep_02.vort_extract_agreed" = "<clr:188,241,174>Agreed!"
		"ep_02.vort_extract_agreed02" = "<clr:188,241,174>Agreed!"
		"ep_02.vort_extract_ahyes" = "<clr:188,241,174>Ah, yes!"
		"ep_02.vort_extract_almosthere" = "<clr:188,241,174>The lift, Freeman!  It is almost here!"
		"ep_02.vort_extract_amusing" = "<clr:188,241,174>Well, this is all very amusing, but we must not forget the gravity of our errand to heal the Alyx Vance."
		"ep_02.vort_extract_ancientguard" = "<clr:188,241,174>Ah-the ancient guardian!  Retrieving the extract may not be unchallenging."
		"ep_02.vort_extract_antsahead01" = "<clr:188,241,174>Careful, Freeman, although far from clever, the antlions will ambush us where they can."
		"ep_02.vort_extract_antsahead02" = "<clr:188,241,174>They lurk, just ahead!"
		"ep_02.vort_extract_antsahead03" = "<clr:188,241,174>Be cautious at each turn!"
		"ep_02.vort_extract_bond01" = "<clr:188,241,174>Truly, Freeman, well done.  "
		"ep_02.vort_extract_bond02" = "<clr:188,241,174>You bear some traits we thought innate to vortikind.  "
		"ep_02.vort_extract_bond03" = "<clr:188,241,174>Antlion husbandry was once our ancestral practice."
		"ep_02.vort_extract_bond04" = "<clr:188,241,174>The creatures exude many valuable compounds, but the extract is the most prized by far."
		"ep_02.vort_extract_bond05" = "<clr:188,241,174>It dissolves the false veils that divide the vortessence."
		"ep_02.vort_extract_bond06" = "<clr:188,241,174>All this you shall witness when---"
		"ep_02.vort_extract_bounty01" = "<clr:188,241,174>Ah, excellent-a bounty of larval extract.  "
		"ep_02.vort_extract_bounty02" = "<clr:188,241,174>This should only take a moment."
		"ep_02.vort_extract_bravely" = "<clr:188,241,174>Bravely done, Freeman!  When you reach the lower chamber, you must find a way to summon me!"
		"ep_02.vort_extract_chairman" = "<clr:188,241,174>A poignant scene.  An eternity's repose.  It brings peaceful thoughts, does it not?"
		"ep_02.vort_extract_constantobst" = "<clr:188,241,174>What next in the parade of constant obstacles?"
		"ep_02.vort_extract_counterintuitive" = "<clr:188,241,174>Although it seems counterintuitive, I believe we must ascend to reach the nectarium."
		"ep_02.vort_extract_covert" = "<clr:188,241,174>This calls for covert progress rather than confrontation."
		"ep_02.vort_extract_densrundeep01" = "<clr:188,241,174>Freeman, attend.  "
		"ep_02.vort_extract_densrundeep02" = "<clr:188,241,174>These antlion dens run deep.  "
		"ep_02.vort_extract_densrundeep03" = "<clr:188,241,174>In every nest, there is a great nectarium where the creatures store their most precious glandular extract.   "
		"ep_02.vort_extract_densrundeep04" = "<clr:188,241,174>We vortikind possess an ancient affinity with this peculiar secretion, and know how to transmute its properties."
		"ep_02.vort_extract_densrundeep05" = "<clr:188,241,174>But the route is bound to be hazardous."
		"ep_02.vort_extract_densrundeep06" = "<clr:188,241,174>Your aide is most appreciated."
		"ep_02.vort_extract_dire" = "<clr:188,241,174>Dire sublimity!"
		"ep_02.vort_extract_donotkill" = "<clr:188,241,174>Remember, do not kill the guardian or the extract will be ruined!"
		"ep_02.vort_extract_dreamsdonotfollow01" = "<clr:188,241,174>So many crates into the abyss."
		"ep_02.vort_extract_dreamsdonotfollow02" = "<clr:188,241,174>I only hope our dreams do not follow them. "
		"ep_02.vort_extract_elude" = "<clr:188,241,174>The Freeman must not kill the guardian!  Its death cries would curdle the extract!"
		"ep_02.vort_extract_emergency" = "<clr:188,241,174>---But hold!  The Alyx Vance is slipping away...  We must hurry!"
		"ep_02.vort_extract_fallingtrap01" = "<clr:188,241,174>What did the Freeman expect to find down there?"
		"ep_02.vort_extract_fallingtrap02" = "<clr:188,241,174>Truly, the Freeman leaves no path unexplored."
		"ep_02.vort_extract_findaway01" = "<clr:188,241,174>Surely the Freeman can find a way to activate this lift.  "
		"ep_02.vort_extract_findaway02" = "<clr:188,241,174>The Alyx Vance depends on us."
		"ep_02.vort_extract_findnectarium01" = "<clr:188,241,174>Press on to the nectarium!"
		"ep_02.vort_extract_findnectarium02" = "<clr:188,241,174>I sense the extract grows near.  We must hurry!"
		"ep_02.vort_extract_findnectarium03" = "<clr:188,241,174>We are on the right path to the nectarium."
		"ep_02.vort_extract_findnectarium04" = "<clr:188,241,174>Do you smell it, Freeman?  The extract?  The nectarium is near."
		"ep_02.vort_extract_findnectarium05" = "<clr:188,241,174>Each step brings us nearer to the nectarium.  We must not tarry."
		"ep_02.vort_extract_findnectarium06" = "<clr:188,241,174>Forward, Freeman!  To the nectarium!"
		"ep_02.vort_extract_findnectarium07" = "<clr:188,241,174>The route is circuitous, but arrival in the nectarium is guaranteed."
		"ep_02.vort_extract_finequality01" = "<clr:188,241,174>Secretions of the finest quality.  "
		"ep_02.vort_extract_finequality02" = "<clr:188,241,174>Let us return now to the Alyx Vance."
		"ep_02.vort_extract_flipants01" = "<clr:188,241,174>We make an admirable team with the Freeman."
		"ep_02.vort_extract_flipants02" = "<clr:188,241,174>The Freeman is a worthy companion."
		"ep_02.vort_extract_flipants03" = "<clr:188,241,174>We work well together!"
		"ep_02.vort_extract_flipants04" = "<clr:188,241,174>Ably done!"
		"ep_02.vort_extract_flipants05" = "<clr:188,241,174>What skill!"
		"ep_02.vort_extract_fmhurry" = "<clr:188,241,174>The Freeman must hurry!"
		"ep_02.vort_extract_fmitistime" = "<clr:188,241,174>Freeman, it is time!"
		"ep_02.vort_extract_fmnotime" = "<clr:188,241,174>There is no time to tarry!"
		"ep_02.vort_extract_fortunately" = "<clr:188,241,174>Fortunately we have the Freeman..."
		"ep_02.vort_extract_haltattend" = "<clr:188,241,174>Halt, Freeman!  And attend!"
		"ep_02.vort_extract_hardwork01" = "<clr:188,241,174>The scent of ripe perfection beckons.  "
		"ep_02.vort_extract_hardwork02" = "<clr:188,241,174>Follow, Freeman, while I track it to the source.  "
		"ep_02.vort_extract_hardwork03" = "<clr:188,241,174>You have done the hardest work, admitting entrance to this chamber.  "
		"ep_02.vort_extract_hardwork04" = "<clr:188,241,174>Truly, the life of Alyx Vance is in able hands."
		"ep_02.vort_extract_hence" = "<clr:188,241,174>Hence, Freeman!"
		"ep_02.vort_extract_howdescend" = "<clr:188,241,174>But how...how shall we descend?"
		"ep_02.vort_extract_humanmark" = "<clr:188,241,174>A human is needed..."
		"ep_02.vort_extract_imbibe" = "<clr:188,241,174>Join now as we imbibe the extract."
		"ep_02.vort_extract_injuriesdeep01" = "<clr:188,241,174>Her injuries are grave.  "
		"ep_02.vort_extract_injuriesdeep02" = "<clr:188,241,174>This will necessitate deep submersion in the vortessence."
		"ep_02.vort_extract_joinmefm01" = "<clr:188,241,174>Please, Freeman.  "
		"ep_02.vort_extract_joinmefm02" = "<clr:188,241,174>Join me."
		"ep_02.vort_extract_joinusfree" = "<clr:188,241,174>Join us, Freeman!"
		"ep_02.vort_extract_journeydeep01" = "<clr:188,241,174>I will make the journey to seek the extract deep within the nest, in the sacred nectarium.  "
		"ep_02.vort_extract_journeydeep02" = "<clr:188,241,174>But I cannot hope to bring it back alone."
		"ep_02.vort_extract_keen01" = "<clr:188,241,174>The antlions are keen to our presence.  "
		"ep_02.vort_extract_keen02" = "<clr:188,241,174>Expect ever greater resistance as we proceed."
		"ep_02.vort_extract_laddertop" = "<clr:188,241,174>Ahah!  No pit would be complete without a Freeman climbing out of it."
		"ep_02.vort_extract_larvalaroma" = "<clr:188,241,174>Ah!  Such quantities of the larvae... such a heady aroma."
		"ep_02.vort_extract_liftalone" = "<clr:188,241,174>That lift is too small to hold us both.  Go on alone.  I will join you when I can!"
		"ep_02.vort_extract_liftarrived" = "<clr:188,241,174>The lift has arrived!  Go quickly!"
		"ep_02.vort_extract_liftmovesnot01" = "<clr:188,241,174>The power has been restored, but still the lift moves not.  "
		"ep_02.vort_extract_liftmovesnot02" = "<clr:188,241,174>There must be something more the Freeman can do!"
		"ep_02.vort_extract_liftnags01" = "<clr:188,241,174>The lift, Freeman!"
		"ep_02.vort_extract_liftnags02" = "<clr:188,241,174>The lift has arrived!"
		"ep_02.vort_extract_liftnags03" = "<clr:188,241,174>The lift awaits, Freeman!"
		"ep_02.vort_extract_liftnags04" = "<clr:188,241,174>Hurry, Freeman, take the lift aloft!"
		"ep_02.vort_extract_liftnags05" = "<clr:188,241,174>To the lift, Freeman!  Do not wait on me!"
		"ep_02.vort_extract_logic" = "<clr:188,241,174>I detect a dawning light of logic in the Freeman's eyes!"
		"ep_02.vort_extract_magnificently" = "<clr:188,241,174>The Freeman has done his task magnificently!"
		"ep_02.vort_extract_makehaste" = "<clr:188,241,174>Make haste!"
		"ep_02.vort_extract_merge" = "<clr:188,241,174>Merge with the vortessence!"
		"ep_02.vort_extract_nearness" = "<clr:188,241,174>The guardian's presence guarantees the nearness of larval clusters.  They are commonly posted near the young."
		"ep_02.vort_extract_nocrates" = "<clr:188,241,174>Those crates were almost certainly of no value."
		"ep_02.vort_extract_notwise" = "<clr:188,241,174>That was not perhaps the wisest of the Freeman's decisions."
		"ep_02.vort_extract_observefight" = "<clr:188,241,174>Observe how they fight on below, heedless of our escape."
		"ep_02.vort_extract_pharynx" = "<clr:188,241,174>Miraculous secretion!"
		"ep_02.vort_extract_pitythegen" = "<clr:188,241,174>Pity the generator that requires a vortigaunt to operate it."
		"ep_02.vort_extract_promising" = "<clr:188,241,174>The density of antlions is most promising.  It all but ensures that we will find larval extract in the lower reaches."
		"ep_02.vort_extract_puzzling01" = "<clr:188,241,174>Ah, a puzzling predicament of the sort which the Freeman is famed for swiftly solving. "
		"ep_02.vort_extract_puzzling02" = "<clr:188,241,174>I will observe with great anticipation!"
		"ep_02.vort_extract_recalcitrance01" = "<clr:188,241,174>Freeman, it would be good to counteract the lift's recalcitrance, that we may proceed."
		"ep_02.vort_extract_recalcitrance02" = "<clr:188,241,174>The life of Alyx Vance is in our keeping!"
		"ep_02.vort_extract_rejoinplayer01" = "<clr:188,241,174>I am with you, Freeman!"
		"ep_02.vort_extract_rejoinplayer02" = "<clr:188,241,174>Fear not, Freeman, for I follow!"
		"ep_02.vort_extract_rejoinplayer03" = "<clr:188,241,174>I follow the Freeman!"
		"ep_02.vort_extract_reunite01" = "<clr:188,241,174>Ah, Freeman!"
		"ep_02.vort_extract_reunite02" = "<clr:188,241,174>Ahoy, Freeman."
		"ep_02.vort_extract_reunite03" = "<clr:188,241,174>Well met, Freeman."
		"ep_02.vort_extract_reunite04" = "<clr:188,241,174>The Freeman has been missed."
		"ep_02.vort_extract_reunite05" = "<clr:188,241,174>Truly, Freeman - too long have we been apart."
		"ep_02.vort_extract_savedcrates01" = "<clr:188,241,174>The Freeman is a quick thinker and fast mover.  "
		"ep_02.vort_extract_savedcrates02" = "<clr:188,241,174>I think you will be very glad you saved those crates."
		"ep_02.vort_extract_secure" = "<clr:188,241,174>We should proceed secure in the belief of copious larval extract in a nest of this size."
		"ep_02.vort_extract_sendup01" = "<clr:188,241,174>Freeman!  Send up the elevator!"
		"ep_02.vort_extract_sendup02" = "<clr:188,241,174>I sense the Freeman, down below!"
		"ep_02.vort_extract_sendup03" = "<clr:188,241,174>Activate the elevator, that we may reconvene!"
		"ep_02.vort_extract_sendup04" = "<clr:188,241,174>Switch on the elevator!"
		"ep_02.vort_extract_sensor" = "<clr:188,241,174>If this sensor is anything like the others, it is attuned to the presence of antlions."
		"ep_02.vort_extract_shaft01" = "<clr:188,241,174>This shaft connects to the chamber above, where my kin sustain the Alyx Vance. "
		"ep_02.vort_extract_shaft02" = "<clr:188,241,174>Once we have the extract, we can rejoin them quickly, provided we can restore elevator function."
		"ep_02.vort_extract_sheerbulk01" = "<clr:188,241,174>The sheer bulk of this machinery suggests a brute force solution. "
		"ep_02.vort_extract_sheerbulk02" = "<clr:188,241,174>But do not neglect the small and obvious details."
		"ep_02.vort_extract_slipperyslope" = "<clr:188,241,174>Careful, Freeman!  Recklessness is a slippery slope!"
		"ep_02.vort_extract_strikeforth" = "<clr:188,241,174>Freeman, we must strike forth!"
		"ep_02.vort_extract_summoned" = "<clr:188,241,174>So you have summoned the lift."
		"ep_02.vort_extract_theextract" = "<clr:188,241,174>The extract!"
		"ep_02.vort_extract_theextract02" = "<clr:188,241,174>The extract!"
		"ep_02.vort_extract_theextract03" = "<clr:188,241,174>The extract!"
		"ep_02.vort_extract_tothelift" = "<clr:188,241,174>To the lift, Freeman!"
		"ep_02.vort_extract_tothelift01" = "<clr:188,241,174>To the lift, Freeman!"
		"ep_02.vort_extract_tothelift02" = "<clr:188,241,174>Save yourself!"
		"ep_02.vort_extract_tothelift03" = "<clr:188,241,174>I have the situation well in hand!"
		"ep_02.vort_extract_traces" = "<clr:188,241,174>These traces of former habitation somehow sadden me."
		"ep_02.vort_extract_vastnectarium" = "<clr:188,241,174>Ahhh!  Never have I witnessed such a vast nectarium!  Any extract taken from this nest will be of highest quality!"
		"ep_02.vort_extract_vibchasm01" = "<clr:188,241,174>Behold!  Across the chasm! "
		"ep_02.vort_extract_vibchasm02" = "<clr:188,241,174>That immense repellant device promises surcease from endless antlion attacks!"
		"ep_02.vort_extract_vibchasm03" = "<clr:188,241,174>If the Freeman is in agreement, let us find our way to that vibratory haven."
		"ep_02.vort_extract_vibdevice" = "<clr:188,241,174>A vibratory device!  These are most effective at repelling antlions, as the Freeman no doubt remembers."
		"ep_02.vort_extract_vibrespite" = "<clr:188,241,174>That vibratory device may offer us some respite from our present foes. "
		"ep_02.vort_extract_weapons01" = "<clr:188,241,174>The Freeman's weapons, though inferior, seem sufficient for the task.  "
		"ep_02.vort_extract_weapons02" = "<clr:188,241,174>Would that they were innate and required no replenishment."
		"ep_02.vort_extract_weightlift" = "<clr:188,241,174>I am confident the Freeman will find a way to open that gate, so that we may proceed together."
		"ep_02.vort_extract_weighty" = "<clr:188,241,174>This is a weighty matter, well suited to a physicist of your stature."
		"ep_02.vort_extract_wemustremain" = "<clr:188,241,174>We must remain to keep the Alyx Vance alive!"
		"ep_02.vort_extract_werequire" = "<clr:188,241,174>We require...the larval extract."
		"ep_02.vort_extract_willfollow" = "<clr:188,241,174>I will follow the Freeman when I can."
		"ep_02.vort_extract_wind" = "<clr:188,241,174>A wind from below bears the scent of extract.  The stuff we seek lies at the bottom of this pit."
		"ep_02.vort_extract_wrongway01" = "<clr:188,241,174>We stray, Freeman!"
		"ep_02.vort_extract_wrongway02" = "<clr:188,241,174>We have taken a wrong turning.  The nectarium lies elsewhere."
		"ep_02.vort_extract_wrongway03" = "<clr:188,241,174>The scent of extract grows weaker!"
		"ep_02.vort_extract_wrongway04" = "<clr:188,241,174>We are moving away from the nectarium.  We must try another path."
		"ep_02.vort_extract_wrongway05" = "<clr:188,241,174>We must try another direction...the extract aroma is weaker here."
		"ep_02.vort_extract_wrongway06" = "<clr:188,241,174>This is not the way to the nectarium."
		"ep_02.vort_extract_wrongway07" = "<clr:188,241,174>We must retrace our steps and try another route to the nectarium."
		"ep_02.vort_extract_yescompanion01" = "<clr:188,241,174>Yes, take the Freeman!  "
		"ep_02.vort_extract_yescompanion02" = "<clr:188,241,174>There is no finer companion!"
		"ep_02.vort_extract_yesthefm01" = "<clr:188,241,174>Take the Freeeman, yes!"
		"ep_02.vort_extract_yesthefm02" = "<clr:188,241,174>Yes, take the Freeman, ah yes!"
		"ep_02.vort_extract_youareonto" = "<clr:188,241,174>Yes, yes, I can see you are on to something!"
		"ep_02.vort_followvortnag_conver2_01" = "<clr:188,241,174>No!  Her thread unravels, but is not yet rent."
		"ep_02.vort_grp_agree01" = "<clr:188,241,174>Just so"
		"ep_02.vort_grp_agree02" = "<clr:188,241,174>Agreed!"
		"ep_02.vort_grp_agree03" = "<clr:188,241,174>Mmmm"
		"ep_02.vort_grp_agree04" = "<clr:188,241,174>Ah..."
		"ep_02.vort_grp_agree05" = "<clr:188,241,174>Yes."
		"ep_02.vort_grp_agree06" = "<clr:188,241,174>Indeed."
		"ep_02.vort_grp_agree07" = "<clr:188,241,174>Well stated."
		"ep_02.vort_grp_agree08" = "<clr:188,241,174>We are of one mind in this matter."
		"ep_02.vort_grp_greetings01" = "<clr:188,241,174>Greetings  "
		"ep_02.vort_grp_greetings02" = "<clr:188,241,174>It is well"
		"ep_02.vort_grp_greetings03" = "<clr:188,241,174>Mmmm..."
		"ep_02.vort_grp_greetings04" = "<clr:188,241,174>Ah..."
		"ep_02.vort_grp_greetings05" = "<clr:188,241,174>Yes..."
		"ep_02.vort_grubhealth01" = "<clr:188,241,174>The small ones are quite appetizing."
		"ep_02.vort_grubhealth02" = "<clr:188,241,174>The larvae yield the vortal pellet."
		"ep_02.vort_grubhealth03" = "<clr:188,241,174>Do not overlook the larval pellet."
		"ep_02.vort_grubs4health01" = "<clr:188,241,174>Do not neglect the larval pellets!"
		"ep_02.vort_grubs4health02" = "<clr:188,241,174>A ready source of healing is at hand, Freeman!  The grubs are here for our benefit!"
		"ep_02.vort_grubs4health03" = "<clr:188,241,174>Freeman, you appear sickly.  Avail yourself of larval pellets!"
		"ep_02.vort_guard_alyxshelter01" = "<clr:188,241,174>Take shelter near the repellant device!"
		"ep_02.vort_guard_alyxshelter02" = "<clr:188,241,174>The Alyx Vance will be safest where the vibrations are strongest."
		"ep_02.vort_guard_alyxshelter03" = "<clr:188,241,174>A vibratory oasis!"
		"ep_02.vort_guard_killit" = "<clr:188,241,174>At this time, you may kill it without consequence!"
		"ep_02.vort_guard_killit_nag01" = "<clr:188,241,174>The cries of this Guardian no longer threaten our extract. Kill it, Freeman!"
		"ep_02.vort_guard_killit_nag02" = "<clr:188,241,174>Freeman, we cannot proceed while the Guardian yet lives."
		"ep_02.vort_guard_killit_nag03" = "<clr:188,241,174>The Guardian bars our way, but now we are free to destroy it."
		"ep_02.vort_guard_killit_nag04" = "<clr:188,241,174>We cannot summon the lift until the Guardian is dead."
		"ep_02.vort_guard_killit_nag05" = "<clr:188,241,174>If we are to press forward, the Guardian must die."
		"ep_02.vort_guard_killit_nag06" = "<clr:188,241,174>If we are to survive, this Guardian must now die."
		"ep_02.vort_guard_killit_nag07" = "<clr:188,241,174>Kill it, Freeman!"
		"ep_02.vort_guard_killit_nag08" = "<clr:188,241,174>Kill the Guardian now!"
		"ep_02.vort_guard_killit_nag09" = "<clr:188,241,174>The Guardian!"
		"ep_02.vort_guard_movetolift01" = "<clr:188,241,174>Come now.  The vehicle we seek is in the encampment above."
		"ep_02.vort_guard_movetolift02" = "<clr:188,241,174>This lift will carry us to where the vehicle awaits."
		"ep_02.vort_guard_surfacesighting" = "<clr:188,241,174>The guardian!"
		"ep_02.vort_guard_welldone01" = "<clr:188,241,174>Well done, Freeman!"
		"ep_02.vort_guard_welldone02" = "<clr:188,241,174>Freeman!  You dispatched those guards with great dispatch!"
		"ep_02.vort_guard_welldone03" = "<clr:188,241,174>Ah, it is a pity the guardians are out of season.  No pheropods."
		"ep_02.vort_junc_ahfreeman" = "<clr:188,241,174>Ah. Freeman. It is well. "
		"ep_02.vort_junc_ahfreeman02" = "<clr:188,241,174>Ah, the Freeman. "
		"ep_02.vort_junc_almostvortal" = "<clr:188,241,174>Almost vortal, this bond between you..."
		"ep_02.vort_junc_assistance01" = "<clr:188,241,174>The Alyx Vance clings to the margins. "
		"ep_02.vort_junc_assistance02" = "<clr:188,241,174>My kin are still some distance away. "
		"ep_02.vort_junc_assistance03" = "<clr:188,241,174>For now we must not be disturbed. "
		"ep_02.vort_junc_attendtoalyx" = "<clr:188,241,174>We must attend to the Alyx Vance. "
		"ep_02.vort_junc_badlyinjured01" = "<clr:188,241,174>For a moment, indeed, you were.  "
		"ep_02.vort_junc_badlyinjured02" = "<clr:188,241,174>The Combine Hunters caused traumatic injury..."
		"ep_02.vort_junc_behold" = "<clr:188,241,174>Behold!"
		"ep_02.vort_junc_bye01" = "<clr:188,241,174>Farewell!"
		"ep_02.vort_junc_bye02" = "<clr:188,241,174>Go safely!"
		"ep_02.vort_junc_bye03" = "<clr:188,241,174>Travel well!"
		"ep_02.vort_junc_closerfm" = "<clr:188,241,174>Closer, Freeman!"
		"ep_02.vort_junc_donotmove" = "<clr:188,241,174>Move not."
		"ep_02.vort_junc_ebbs" = "<clr:188,241,174>She ebbs!"
		"ep_02.vort_junc_exhausted" = "<clr:188,241,174>We have exhausted their immediate number."
		"ep_02.vort_junc_fmcomecloser01" = "<clr:188,241,174>Closer, Freeman!  "
		"ep_02.vort_junc_fmcomecloser02" = "<clr:188,241,174>The Alyx Vance requires a tether to the human realm."
		"ep_02.vort_junc_fmsignature01" = "<clr:188,241,174>Freeman..."
		"ep_02.vort_junc_fmsignature02" = "<clr:188,241,174>Come close..."
		"ep_02.vort_junc_fmsignature03" = "<clr:188,241,174>As one of her race, her frequency,"
		"ep_02.vort_junc_fmsignature04" = "<clr:188,241,174>we require your vortal signature."
		"ep_02.vort_junc_fmstandnear" = "<clr:188,241,174>The Freeman must stand near."
		"ep_02.vort_junc_givemoretime" = "<clr:188,241,174>This will give you more time. "
		"ep_02.vort_junc_immeasurable" = "<clr:188,241,174>We have averted an immeasurable loss."
		"ep_02.vort_junc_inamongus" = "<clr:188,241,174>In among us!  Now!"
		"ep_02.vort_junc_keephunting" = "<clr:188,241,174>We will continue our hunt for Advisors. "
		"ep_02.vort_junc_killedmanyyet01" = "<clr:188,241,174>We killed many antlions. "
		"ep_02.vort_junc_killedmanyyet02" = "<clr:188,241,174>Yet many more remain. "
		"ep_02.vort_junc_knit" = "<clr:188,241,174>We knit shattered bone and restored circulatory integrity."
		"ep_02.vort_junc_liestill" = "<clr:188,241,174>Lie still."
		"ep_02.vort_junc_loseherloseall" = "<clr:188,241,174>If we lose her, we lose all!"
		"ep_02.vort_junc_matterhours" = "<clr:188,241,174>A matter of hours."
		"ep_02.vort_junc_momentlonger" = "<clr:188,241,174>A moment longer..."
		"ep_02.vort_junc_momentlonger02" = "<clr:188,241,174>A moment longer."
		"ep_02.vort_junc_myplace01" = "<clr:188,241,174>My place is here.  "
		"ep_02.vort_junc_myplace02" = "<clr:188,241,174>I must not be interrupted."
		"ep_02.vort_junc_nextmatter" = "<clr:188,241,174>Now to the next matter of urgency."
		"ep_02.vort_junc_nopulse01" = "<clr:188,241,174>No pulse!  "
		"ep_02.vort_junc_nopulse02" = "<clr:188,241,174>Her heart has stopped!"
		"ep_02.vort_junc_nothingchanged" = "<clr:188,241,174>To our knowledge, he is still at White Forest, working on the portal shield."
		"ep_02.vort_junc_object" = "<clr:188,241,174>There is no time. More antlions approach. "
		"ep_02.vort_junc_pathtowf" = "<clr:188,241,174>Come, then.  I will get you on the path to White Forest."
		"ep_02.vort_junc_quicken" = "<clr:188,241,174>Yes...there is a quickening..."
		"ep_02.vort_junc_quietthem" = "<clr:188,241,174>We shall quiet them. "
		"ep_02.vort_junc_realms" = "<clr:188,241,174>Yet it was the Freeman who retrieved your vortessence."
		"ep_02.vort_junc_rightroad" = "<clr:188,241,174>No fear.  We will put you on the right road"
		"ep_02.vort_junc_rise" = "<clr:188,241,174>Now...try carefully to rise."
		"ep_02.vort_junc_stabilizing01" = "<clr:188,241,174>She is stabilizing.  "
		"ep_02.vort_junc_stabilizing02" = "<clr:188,241,174>Her vortal form has regained integrity."
		"ep_02.vort_junc_stirs" = "<clr:188,241,174>She stirs!"
		"ep_02.vort_junc_strengthtoproceed" = "<clr:188,241,174>If you have the strength, we should proceed."
		"ep_02.vort_junc_thealyxvance" = "<clr:188,241,174>The Alyx Vance!"
		"ep_02.vort_junc_tosurface" = "<clr:188,241,174>Come, Freeman.  To the surface!"
		"ep_02.vort_junc_weavelife" = "<clr:188,241,174>We weave the Freeman's life with hers."
		"ep_02.vort_junc_weweredelayed" = "<clr:188,241,174>Our delay--regrettable. "
		"ep_02.vort_mineshaft_warning01" = "<clr:188,241,174>Watch where you walk."
		"ep_02.vort_mineshaft_warning02" = "<clr:188,241,174>Watch your steps."
		"ep_02.vort_mineshaft_warning03" = "<clr:188,241,174>Freeman, beware the pits."
		"ep_02.vort_playerahead01" = "<clr:188,241,174>Abide a moment, Freeman!  Till I draw apace!"
		"ep_02.vort_playerahead02" = "<clr:188,241,174>Freeman!  "
		"ep_02.vort_prone_nag_01" = "<clr:188,241,174>Finish them, Freeman!"
		"ep_02.vort_prone_nag_02" = "<clr:188,241,174>I have disabled them."
		"ep_02.vort_prone_nag_03" = "<clr:188,241,174>Now attack!"
		"ep_02.vort_rbed_altroute" = "<clr:188,241,174>We must part ways, Freeman!  Lead the antlions away!"
		"ep_02.vort_rbed_antlions" = "<clr:188,241,174>These antlions will not let us proceed in peace."
		"ep_02.vort_rbed_awake" = "<clr:188,241,174>Awake!  Arise!"
		"ep_02.vort_rbed_byanotherpath" = "<clr:188,241,174>Press on, Freeman!  I will take her to my kin by another path."
		"ep_02.vort_rbed_companions01" = "<clr:188,241,174>My kin will meet us at a sheltered location beneath the surface."
		"ep_02.vort_rbed_companions02" = "<clr:188,241,174>We must move her there quickly.  "
		"ep_02.vort_rbed_companions03" = "<clr:188,241,174>I will stabilize her, if the Freeman will provide us with protection."
		"ep_02.vort_rbed_distract" = "<clr:188,241,174>The Freeman must distract the antlions.  "
		"ep_02.vort_rbed_freeman" = "<clr:188,241,174>Freeman!"
		"ep_02.vort_rbed_freeman01" = "<clr:188,241,174>Ah, the Freeman!  "
		"ep_02.vort_rbed_freeman02" = "<clr:188,241,174>I am pleased to see at least you are unharmed!"
		"ep_02.vort_rbed_freeman03" = "<clr:188,241,174>But the Alyx Vance...her condition is grave."
		"ep_02.vort_rbed_freeman04" = "<clr:188,241,174>Healing her will require more than I alone can conjure."
		"ep_02.vort_rbed_freeman05" = "<clr:188,241,174>Let me summon my kin!"
		"ep_02.vort_rbed_intomines01" = "<clr:188,241,174>Let us hurry, Freeman.  "
		"ep_02.vort_rbed_intomines02" = "<clr:188,241,174>Help awaits us, in the mines."
		"ep_02.vort_rbed_letsgo01a" = "<clr:188,241,174>Hurry, Freeman.  "
		"ep_02.vort_rbed_letsgo01b" = "<clr:188,241,174>Our hands are occupied."
		"ep_02.vort_rbed_letsgo01c" = "<clr:188,241,174>Destroy all obstacles!"
		"ep_02.vort_rbed_letsgo02" = "<clr:188,241,174>Lead on, Freeman!"
		"ep_02.vort_rbed_letsgo03" = "<clr:188,241,174>Forward, Freeman.  "
		"ep_02.vort_rbed_letsgo04a" = "<clr:188,241,174>We must hasten.  "
		"ep_02.vort_rbed_letsgo04b" = "<clr:188,241,174>Her state is delicate."
		"ep_02.vort_rbed_nomatter01" = "<clr:188,241,174>No matter!"
		"ep_02.vort_rbed_nomatter02" = "<clr:188,241,174>We shall proceed by another path!"
		"ep_02.vort_rbed_nomatter03" = "<clr:188,241,174>We trust the Freeman's ingenuity will bring us back into proximity!"
		"ep_02.vort_rbed_presson" = "<clr:188,241,174>Press on, Freeman!  If you are able!"
		"ep_02.vort_rbed_stucklift" = "<clr:188,241,174>Perhaps the Freeman can restore this elevator's functionality."
		"ep_02.vort_rbed_thealyx" = "<clr:188,241,174>The Alyx Vance!"
		"ep_02.vort_rbed_usecare" = "<clr:188,241,174>Use care, Freeman!"
		"ep_02.vort_rbed_vemotings01" = "<clr:188,241,174>[Vortigese expressions of shock:]"
		"ep_02.vort_rbed_whatharm" = "<clr:188,241,174>What harm has come?"
		"ep_02.vort_separation_goodbye01" = "<clr:188,241,174>Freeman!  You have cleared our path, but yours is less clear."
		"ep_02.vort_separation_goodbye02" = "<clr:188,241,174>There are many routes to the junction below-I trust you can find your way to join us there."
		"ep_02.vort_separation_goodbye03" = "<clr:188,241,174>If not, your sacrifice shall not be forgotten."
		"ep_02.vort_separation_leave01" = "<clr:188,241,174>Freeman, the entrance to the mines is just ahead."
		"ep_02.vort_separation_leave02" = "<clr:188,241,174>I cannot fend off antlions and keep the Alyx Vance alive."
		"ep_02.vort_separation_leave03" = "<clr:188,241,174>You must draw their aggression so I can hurry her to shelter."
		"ep_02.vort_separation_nag01" = "<clr:188,241,174>Freeman you must attend to the antlions."
		"ep_02.vort_separation_nag02" = "<clr:188,241,174>Freeman, go now."
		"ep_02.vort_separation_success01" = "<clr:188,241,174>Well done, Freeman!"
		"ep_02.vort_separation_success02" = "<clr:188,241,174>Success!"
		"ep_02.vort_separation_success03" = "<clr:188,241,174>Keep on, Freeman!"
		"ep_02.vort_silo_admit" = "<clr:188,241,174>The Magnusson has instructed me to admit you into the secondary silo."
		"ep_02.vort_silo_ahalyx" = "<clr:188,241,174>Ah, the Alyx Vance"
		"ep_02.vort_silo_freeman" = "<clr:188,241,174>Freeman!"
		"ep_02.vort_silo_honor" = "<clr:188,241,174>If you would take the Freeman from here I can return to my place of honor at the side of the Magnusson."
		"ep_02.vort_silo_mag_brag01" = "<clr:188,241,174>Heed well the Magnusson's words."
		"ep_02.vort_silo_mag_brag02" = "<clr:188,241,174>The Magnusson speaks true"
		"ep_02.vort_silo_mag_brag03" = "<clr:188,241,174>Wiser words were never spoken, save possibly by the Magnusson."
		"ep_02.vort_silo_mag_brag04" = "<clr:188,241,174>You are fortunate indeed to have the Magnusson's guidance in this matter."
		"ep_02.vort_silo_mag_brag05" = "<clr:188,241,174>Such time spent with the Magnusson can be no less than the qualitative high point of the Freeman's existence."
		"ep_02.vort_silo_mag_brag06" = "<clr:188,241,174>Well said.  The Magnusson has once again come to the heart of the matter."
		"ep_02.vort_silo_magbestsuited" = "<clr:188,241,174>Perhaps the Magnusson is best suited to operate the Magnusson device."
		"ep_02.vort_silo_magdidwell01" = "<clr:188,241,174>Freeman!"
		"ep_02.vort_silo_magdidwell02" = "<clr:188,241,174>The Magnusson did well to choose you for that task!  "
		"ep_02.vort_silo_magdidwell03" = "<clr:188,241,174>Once again, his judgment proves impeccable."
		"ep_02.vort_silo_maghonor01" = "<clr:188,241,174>It is an honor to have been accepted among the Magnusson's staff."
		"ep_02.vort_silo_maghonor02" = "<clr:188,241,174>Truly, the Magnusson's mind is akin to a force of nature."
		"ep_02.vort_silo_maghonor03" = "<clr:188,241,174>The Vortessence runs strong in the Magnusson."
		"ep_02.vort_silo_magrespected" = "<clr:188,241,174>The Magnusson is much respected."
		"ep_02.vort_silo_norefrigeration" = "<clr:188,241,174>The Magnusson device requires no refrigeration."
		"ep_02.vort_silo_regrettablytrue" = "<clr:188,241,174>Regrettably true."
		"ep_02.vort_silo_returntomag" = "<clr:188,241,174>If you would take the Freeman from here I can return to my place of honor at the side of the Magnusson."
		"ep_02.vort_silo_thankstomag" = "<clr:188,241,174>Thanks to the Magnusson."
		"ep_02.vort_silo_thisway01" = "<clr:188,241,174>This way and quickly."
		"ep_02.vort_silo_thisway02" = "<clr:188,241,174>Your peers await."
		"ep_02.vort_silo_thisway03" = "<clr:188,241,174>Follow, Freeman."
		"ep_02.vort_silo_thruhere" = "<clr:188,241,174>The secondary silo can be reached through here."
		"ep_02.vort_squishgrub01" = "<clr:188,241,174>They are quite pleasant underfoot, are they not?"
		"ep_02.vort_squishgrub02" = "<clr:188,241,174>Ah, such a pleasing sound and sensation."
		"ep_02.vort_squishgrub03" = "<clr:188,241,174>The grubs are nothing if not...succulent."
		"ep_02.vort_squishgrub04" = "<clr:188,241,174>I see you too appreciate the larval pellet's properties!"
		"ep_02.vort_turret_defendus" = "<clr:188,241,174>Defend us!"
		"ep_02.vort_turret_helpcall01" = "<clr:188,241,174>We need help!"
		"ep_02.vort_turret_helpcall02" = "<clr:188,241,174>Defend me!"
		"ep_02.vort_turret_helpcall03" = "<clr:188,241,174>Come to me!"
		"ep_02.vort_turret_helpcall04" = "<clr:188,241,174>We are under attack!"
		"ep_02.vort_turret_helpcall05" = "<clr:188,241,174>Protect us!"
		"ep_02.vort_turret_helpcall06" = "<clr:188,241,174>We need your protection!"
		"ep_02.vort_turret_helpcall07" = "<clr:188,241,174>Clear away these antlions!"
		"ep_02.vort_turret_helpcall08" = "<clr:188,241,174>If I die, the Alyx Vance is lost!"
		"ep_02.vort_turret_helpcall09" = "<clr:188,241,174>To me, Freeman!"
		"ep_02.vort_turret_keepthemaway" = "<clr:188,241,174>Keep them away!"
		"ep_02.vort_turret_mustbestopped" = "<clr:188,241,174>They must be stopped!"
		"ep_02.vort_turret_notinterrupt" = "<clr:188,241,174>No interruptions!"
		"ep_02.vort_turret_protectalyx" = "<clr:188,241,174>Protect the Alyx Vance!"
		"ep_02.vort_turret_protectus" = "<clr:188,241,174>Protect us!"
		"ep_02.vort_turret_use01" = "<clr:188,241,174>Bother us not!"
		"ep_02.vort_turret_use02" = "<clr:188,241,174>No interruptions!"
		"ep_02.vort_turret_use03" = "<clr:188,241,174>You must not distract me from sustaining the Alyx Vance."
		"ep_02.vort_tutor_custom01" = "<clr:188,241,174>Is the Freeman unfamiliar with the custom of knocking? "
		"ep_02.vort_tutor_custom02" = "<clr:188,241,174>I had thought it was widespread.  "
		"ep_02.vort_tutor_deactive01" = "<clr:188,241,174>For the safety of the base, these devices are deactivated."
		"ep_02.vort_tutor_deactive02" = "<clr:188,241,174>They cannot explode like those you will find in the field."
		"ep_02.vort_tutor_knock" = "<clr:188,241,174>Hm, we had thought the custom of knocking was universal."
		"ep_02.vort_tutor_novelmethods" = "<clr:188,241,174>As time permits, you must familiarize me with your own novel methods for finding entry."
		"npc_vortigaunt.above" = "<clr:188,241,174>Above."
		"npc_vortigaunt.abovefm" = "<clr:188,241,174>Above the Freeman."
		"npc_vortigaunt.acceptcharge" = "<clr:188,241,174>Accept a charge. "
		"npc_vortigaunt.acceptenergy" = "<clr:188,241,174>Accept energy. "
		"npc_vortigaunt.accompany" = "<clr:188,241,174>Gladly we accompany. "
		"npc_vortigaunt.advancefm" = "<clr:188,241,174>Advance, Freeman."
		"npc_vortigaunt.alert" = "<clr:188,241,174>Alert."
		"npc_vortigaunt.alert_soldiers" = "<clr:188,241,174>Soldiers!"
		"npc_vortigaunt.allfornow" = "<clr:188,241,174>That is all for now. "
		"npc_vortigaunt.allinoneinall" = "<clr:188,241,174>All in one and one in all. "
		"npc_vortigaunt.allowrecharge" = "<clr:188,241,174>Allow us to recharge your cells. "
		"npc_vortigaunt.allwecanspare" = "<clr:188,241,174>That is all we can spare. "
		"npc_vortigaunt.allwehave" = "<clr:188,241,174>All we have is yours. "
		"npc_vortigaunt.approaches" = "<clr:188,241,174>Something approaches."
		"npc_vortigaunt.asound" = "<clr:188,241,174>A sound."
		"npc_vortigaunt.assent" = "<clr:188,241,174>Assent. "
		"npc_vortigaunt.behindfm" = "<clr:188,241,174>Behind the Freeman."
		"npc_vortigaunt.behindyou" = "<clr:188,241,174>Behind you!"
		"npc_vortigaunt.below" = "<clr:188,241,174>Below!"
		"npc_vortigaunt.belowfm" = "<clr:188,241,174>Below the Freeman!"
		"npc_vortigaunt.beware" = "<clr:188,241,174>Beware!"
		"npc_vortigaunt.bodyyours" = "<clr:188,241,174>This body is yours to command. "
		"npc_vortigaunt.byvort" = "<clr:188,241,174>By the Vortessence!"
		"npc_vortigaunt.cannotfire" = "<clr:188,241,174>We cannot fire without harm to the Freeman. "
		"npc_vortigaunt.caution" = "<clr:188,241,174>Caution! "
		"npc_vortigaunt.cautionfm" = "<clr:188,241,174>Caution, Freeman! "
		"npc_vortigaunt.cautionfm02" = "<clr:188,241,174>Use caution, Freeman."
		"npc_vortigaunt.choicemade" = "<clr:188,241,174>The choice is made."
		"npc_vortigaunt.claimvort" = "<clr:188,241,174>Reclaim the Vortessence!"
		"npc_vortigaunt.cordcut" = "<clr:188,241,174>His cord is cut."
		"npc_vortigaunt.dedicate" = "<clr:188,241,174>We dedicate ourselves to your purpose. "
		"npc_vortigaunt.done" = "<clr:188,241,174>Done. "
		"npc_vortigaunt.downhere" = "<clr:188,241,174>Do not hesitate"
		"npc_vortigaunt.downthere" = "<clr:188,241,174>Down here!"
		"npc_vortigaunt.dreamed" = "<clr:188,241,174>We have dreamed of this moment. "
		"npc_vortigaunt.empowerus" = "<clr:188,241,174>Empower us! "
		"npc_vortigaunt.energyempower" = "<clr:188,241,174>Its energy empowers us. "
		"npc_vortigaunt.enough" = "<clr:188,241,174>Enough."
		"npc_vortigaunt.fearnotfm" = "<clr:188,241,174>Fear not, Freeman."
		"npc_vortigaunt.finished" = "<clr:188,241,174>Finished."
		"npc_vortigaunt.fittingend" = "<clr:188,241,174>This is a fitting end."
		"npc_vortigaunt.fmaccompany" = "<clr:188,241,174>The Freeman will please accompany us."
		"npc_vortigaunt.fmadvance" = "<clr:188,241,174>The Freeman must advance."
		"npc_vortigaunt.fmbeware" = "<clr:188,241,174>Freeman beware!"
		"npc_vortigaunt.fmcanuse" = "<clr:188,241,174>The Freeman can make use of this. "
		"npc_vortigaunt.fmdoesushonor" = "<clr:188,241,174>The Freeman does us honor. "
		"npc_vortigaunt.fmhonorsus" = "<clr:188,241,174>The Freeman honors us. "
		"npc_vortigaunt.fminway" = "<clr:188,241,174>The Freeman is in our way. "
		"npc_vortigaunt.fmknowsbest" = "<clr:188,241,174>The Freeman knows best. "
		"npc_vortigaunt.fmmustbeware" = "<clr:188,241,174>The Freeman must beware! "
		"npc_vortigaunt.fmmustcaution" = "<clr:188,241,174>The Freeman must use caution."
		"npc_vortigaunt.fmmustfollow" = "<clr:188,241,174>The Freeman must follow. "
		"npc_vortigaunt.fmmustmove" = "<clr:188,241,174>The Freeman must move. "
		"npc_vortigaunt.fmmustnotfear" = "<clr:188,241,174>The Freeman must not fear."
		"npc_vortigaunt.fmsilent" = "<clr:188,241,174>The Freeman must be silent."
		"npc_vortigaunt.fmstandstill" = "<clr:188,241,174>The Freeman must stand still. "
		"npc_vortigaunt.followfm" = "<clr:188,241,174>Follow, Freeman."
		"npc_vortigaunt.forbearfm" = "<clr:188,241,174>Forbear, Freeman."
		"npc_vortigaunt.forcause" = "<clr:188,241,174>For the cause of the All-in-One."
		"npc_vortigaunt.forfreedom" = "<clr:188,241,174>For Freedom! "
		"npc_vortigaunt.forthefm" = "<clr:188,241,174>For the Freeman! "
		"npc_vortigaunt.forward" = "<clr:188,241,174>Forward! "
		"npc_vortigaunt.freeman" = "<clr:188,241,174>Freeman. "
		"npc_vortigaunt.giveover" = "<clr:188,241,174>Give over your essence. "
		"npc_vortigaunt.gladly" = "<clr:188,241,174>Gladly. "
		"npc_vortigaunt.gloriousend" = "<clr:188,241,174>To our glorious end. "
		"npc_vortigaunt.greetingsfm" = "<clr:188,241,174>Greetings to the Freeman. "
		"npc_vortigaunt.halt" = "<clr:188,241,174>Halt. "
		"npc_vortigaunt.hark" = "<clr:188,241,174>Hark"
		"npc_vortigaunt.hastefm" = "<clr:188,241,174>Make haste, Freeman."
		"npc_vortigaunt.heal01" = "<clr:188,241,174>Your energies require our assistance, Freeman."
		"npc_vortigaunt.heal02" = "<clr:188,241,174>It is a pleasure to heal the Freeman."
		"npc_vortigaunt.heal03" = "<clr:188,241,174>The Freeman must be healed."
		"npc_vortigaunt.heal04" = "<clr:188,241,174>Allow us to treat your wounds."
		"npc_vortigaunt.heal05" = "<clr:188,241,174>We have no medkit, but this should suffice."
		"npc_vortigaunt.healscanharm" = "<clr:188,241,174>What heals can also harm."
		"npc_vortigaunt.here" = "<clr:188,241,174>Here. "
		"npc_vortigaunt.herewestay" = "<clr:188,241,174>Here we stay. "
		"npc_vortigaunt.hold" = "<clr:188,241,174>Hold. "
		"npc_vortigaunt.holdorcantcharge" = "<clr:188,241,174>Hold still or we cannot charge you. "
		"npc_vortigaunt.holdstill" = "<clr:188,241,174>Hold still. "
		"npc_vortigaunt.honorfollow" = "<clr:188,241,174>To our honor we follow you. "
		"npc_vortigaunt.honorours" = "<clr:188,241,174>The honor is ours. "
		"npc_vortigaunt.hurryonfm" = "<clr:188,241,174>Hurry, Freeman."
		"npc_vortigaunt.ifyoumove" = "<clr:188,241,174>If you move we cannot help you. "
		"npc_vortigaunt.isitthefm" = "<clr:188,241,174>Is it the Freeman? "
		"npc_vortigaunt.itisthefm" = "<clr:188,241,174>It is the Freeman. "
		"npc_vortigaunt.keepfmsafe" = "<clr:188,241,174>That should keep the Freeman safe. "
		"npc_vortigaunt.leadon" = "<clr:188,241,174>Lead on. "
		"npc_vortigaunt.leadus" = "<clr:188,241,174>Lead us. "
		"npc_vortigaunt.lookwell" = "<clr:188,241,174>Look well."
		"npc_vortigaunt.losesight" = "<clr:188,241,174>May we never lose sight of the All-in-One, the One-in-All."
		"npc_vortigaunt.movingtarget" = "<clr:188,241,174>We cannot heal a moving target. "
		"npc_vortigaunt.mutual" = "<clr:188,241,174>Our purpose is mutual. "
		"npc_vortigaunt.nodenexus" = "<clr:188,241,174>Node and nexus, feed upon this life! "
		"npc_vortigaunt.obstruction" = "<clr:188,241,174>Let us see this obstruction's true nature."
		"npc_vortigaunt.onepasses" = "<clr:188,241,174>One passes but we live on."
		"npc_vortigaunt.onesurvives" = "<clr:188,241,174>While one survives, so live we all."
		"npc_vortigaunt.onward" = "<clr:188,241,174>Onward! "
		"npc_vortigaunt.ourplacehere" = "<clr:188,241,174>Our place is here. "
		"npc_vortigaunt.overthere" = "<clr:188,241,174>Over there!  "
		"npc_vortigaunt.passon" = "<clr:188,241,174>Pass on! "
		"npc_vortigaunt.pleasure" = "<clr:188,241,174>With pleasure. "
		"npc_vortigaunt.prepare" = "<clr:188,241,174>Prepare to receive energy. "
		"npc_vortigaunt.preparetomerge" = "<clr:188,241,174>Prepare to merge with the void."
		"npc_vortigaunt.prevail" = "<clr:188,241,174>We shall prevail. "
		"npc_vortigaunt.proceedfm" = "<clr:188,241,174>Proceed, Freeman."
		"npc_vortigaunt.propitious" = "<clr:188,241,174>Propitious alliance. "
		"npc_vortigaunt.reasondelay" = "<clr:188,241,174>Is there reason for delay?"
		"npc_vortigaunt.recsilence" = "<clr:188,241,174>We recommend silence."
		"npc_vortigaunt.regrettable" = "<clr:188,241,174>This is regrettable. "
		"npc_vortigaunt.regrettable02" = "<clr:188,241,174>Regrettable."
		"npc_vortigaunt.rememberus" = "<clr:188,241,174>Remember us."
		"npc_vortigaunt.returntoall" = "<clr:188,241,174>Return to the all in one. "
		"npc_vortigaunt.returnvoid" = "<clr:188,241,174>Return to the void. "
		"npc_vortigaunt.satisfaction" = "<clr:188,241,174>Satisfaction. "
		"npc_vortigaunt.seenworse" = "<clr:188,241,174>We have survived worse across the ages. "
		"npc_vortigaunt.silence" = "<clr:188,241,174>Silence."
		"npc_vortigaunt.standclear" = "<clr:188,241,174>Stand clear. "
		"npc_vortigaunt.surge" = "<clr:188,241,174>We surge. "
		"npc_vortigaunt.tethercut" = "<clr:188,241,174>The tether is cut. "
		"npc_vortigaunt.thatisall" = "<clr:188,241,174>That is all. "
		"npc_vortigaunt.thatsound" = "<clr:188,241,174>That sound."
		"npc_vortigaunt.thefreeman" = "<clr:188,241,174>The Freeman. "
		"npc_vortigaunt.there" = "<clr:188,241,174>There!"
		"npc_vortigaunt.tothevoid" = "<clr:188,241,174>To the void with you. "
		"npc_vortigaunt.troubleus" = "<clr:188,241,174>That one shall trouble us no more. "
		"npc_vortigaunt.trulyitis" = "<clr:188,241,174>Truly it is the Freeman. "
		"npc_vortigaunt.undeserving" = "<clr:188,241,174>Undeserving of consciousness. "
		"npc_vortigaunt.untethered" = "<clr:188,241,174>This one is untethered."
		"npc_vortigaunt.upthere" = "<clr:188,241,174>Up there"
		"npc_vortigaunt.utmostprotect" = "<clr:188,241,174>We shall do our utmost to protect the Freeman."
		"npc_vortigaunt.veillifted" = "<clr:188,241,174>May the veil be switfly lift or, if not lifted, rent."
		"npc_vortigaunt.vmourn01" = "<clr:188,241,174>The Bright One perishes."
		"npc_vortigaunt.vmourn02" = "<clr:188,241,174>The opener's way has shut."
		"npc_vortigaunt.vmourn03" = "<clr:188,241,174>The Freeman must not fear, only merge."
		"npc_vortigaunt.vmourn04" = "<clr:188,241,174>In the Vortessence there is no end."
		"npc_vortigaunt.vmourn05" = "<clr:188,241,174>Such postures are but fleeting."
		"npc_vortigaunt.vmourn06" = "<clr:188,241,174>It is but the blink of an eye."
		"npc_vortigaunt.vmourn07" = "<clr:188,241,174>This is not the end."
		"npc_vortigaunt.vmourn08" = "<clr:188,241,174>The Freeman lives on in us."
		"npc_vortigaunt.vmourn09" = "<clr:188,241,174>The Freeman's cord is cut."
		"npc_vortigaunt.vmourn10" = "<clr:188,241,174>The Freeman's cord is cut."
		"npc_vortigaunt.vmourn11" = "<clr:188,241,174>The Freeman is no longer."
		"npc_vortigaunt.vmourn12" = "<clr:188,241,174>Such is mortality."
		"npc_vortigaunt.voidlaysclaim" = "<clr:188,241,174>The Void lays claim to its own."
