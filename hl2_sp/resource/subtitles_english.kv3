		"ep2_rebel.reb_hunters03" = "What are we waiting for?"
		"ep2_rebel.reb_hunters04" = "That's a nice suit."
		"ep2_rebel.reb_hunters05" = "You know, orange is your color; looks good on you."
		"ep2_rebel.reb_hunters06" = "I hear things are better back in the city."
