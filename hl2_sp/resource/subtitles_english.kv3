		"odessa.nlo_cheer01" = "*cheers*"
		"odessa.nlo_cheer02" = "*cheers*"
		"odessa.nlo_cheer03" = "*laughter*"
		"odessa.nlo_cheer04" = "*cheers*"
		"odessa.nlo_citizen_bringcar" = "Bring your car up here and I'll open the gate for you. "
		"odessa.nlo_citizen_drivesafe" = "Drive safely! "
		"odessa.nlo_citizen_greet01" = "I'd get into the basement if I were you.  We're bracing for an attack. "
		"odessa.nlo_citizen_greet02" = "Gordon Freeman? The Colonel is expecting you. "
		"odessa.nlo_citizen_greet03" = "This is no time to be wandering around.  The Combine's closing in. "
		"odessa.nlo_citizen_greet04" = "Get in the basement! We're making sure everyone has what they need to hold off an attack. "
		"odessa.nlo_citizen_greet05" = "You shouldn't be walking around out here. Get into the basement. "
		"odessa.nlo_citizen_post01" = "Hold onto that launcher, Dr. Freeman. You'll be glad you have it on the road ahead. "
		"odessa.nlo_citizen_post02" = "Get going, Dr. Freeman. We know Eli Vance is depending on you. "
		"odessa.nlo_citizen_post03" = "Good luck in Nova Prospekt, Dr. Freeman. "
		"odessa.nlo_cub_carry" = "Now, who's going to be the lucky one to carry it into combat? "
		"odessa.nlo_cub_class01" = "This steerable rocket launcher is our best bet for taking down a gunship. "
		"odessa.nlo_cub_class02" = "Using the laser guide, you can steer your rocket past the gunship's defenses and prevent it from shooting down your rocket. "
		"odessa.nlo_cub_class03" = "This will only anger it at first, but if you can survive long enough to make several direct hits, you'll be rewarded with a prize worthy of any mantlepiece. "
		"odessa.nlo_cub_corkscrew" = "Remember: use the launcher's laser guide to steer your rocket past the gunship's defenses. "
		"odessa.nlo_cub_farewell" = "Farewell! And please tell Dr. Vance that Colonel Cubbage regrets not having been able to rescue him in person! "
		"odessa.nlo_cub_freeman" = "Ah, yes! Gordon Freeman! "
		"odessa.nlo_cub_hello" = "Ah, hello! I'll be right with you! "
		"odessa.nlo_cub_ledtobelieve" = "I gather you've disposed of that gunship, Dr. Freeman. Your reputation, sir, is well deserved. "
		"odessa.nlo_cub_opengate" = "I shall have someone open the gate for you immediately, so that you can drive on. I understand that Dr. Vance is in great need. "
		"odessa.nlo_cub_radio" = "N.L.O. to Lighthouse Point. N.L.O. to Lighthouse Point. Come in. This is Colonel Cubbage. Come in, please. "
		"odessa.nlo_cub_roadahead" = "Use extreme caution when approaching the Bridge. Radio silence from that outpost leads me to believe it has come under Combine control. Still, you're clearly the right man for the job! "
		"odessa.nlo_cub_service" = "Colonel Odessa Cubbage at your service! "
		"odessa.nlo_cub_teachgunship" = "Go on! Teach that gunship a lesson it will never forget! "
		"odessa.nlo_cub_thatsthat" = "Well, that's that. "
		"odessa.nlo_cub_volunteer" = "I couldn't have asked for a finer volunteer! "
		"odessa.nlo_cub_warning" = "Damn! Let me just send a warning to Lighthouse Point, then I'll come right up to lend a hand! "
		"odessa.nlo_cub_wherewasi" = "Now, where was I? Ah, yes... "
		"odessa.nlo_cub_youllmakeit" = "You'll make it through if anyone can. "
		"odessa.nlo_cubdeath01" = "No. No! "
		"odessa.nlo_cubdeath02" = "No! No! "
		"odessa.nlo_cubdeath03" = " "
		"odessa.nlo_cubdeath04" = " "
		"odessa.nlo_cubdeath05" = " "
		"odessa.nlo_farewell" = " "
		"odessa.nlo_getyourjeep" = "Get in your car and I'll open up this gate. "
		"odessa.nlo_greet_freeman" = "Gordon Freeman! "
		"odessa.nlo_greet_intro" = "Hurry, get in the basement. We're expecting gunships at any moment. Colonel Cubbage will be glad to see you made it. "
		"odessa.nlo_greet_nag01" = "This way, Dr. Freeman. "
		"odessa.nlo_greet_nag02" = "Colonel Cubbage is in the basement, Doctor Freeman. "
		"odessa.nlo_opengate" = "Doctor Freeman, I'll open the gate and let you through. "
		"odessa.nlo_opengate02" = " "
		"odessa.nlo_userockets" = " "
		"odessa.nlo_vort_exit" = "The Freeman must now hurry on! The Eli Vance is held in distress most dire! "
		"odessa.nlo_yourcarsir" = "Get your car, Doc.  You won't get far on foot. "
		"odessa.stairman_follow01" = "This way. "
		"odessa.stairman_follow02" = " "
		"odessa.stairman_follow03" = "Stay with me, Freeman. "
		"odessa.stairman_upstairs" = " "
		"opening.cit_bench01" = "Stay back, you'll attract unwanted attention. "
		"opening.cit_bench02" = "I can't be seen talking to you.  Not out here. "
		"opening.cit_bench03" = "Don't sit near me.  It'll look suspicious. "
		"opening.cit_bench04" = "You're scaring off the pigeons. "
		"opening.cit_blocker_getin" = "Get in here, quick! "
		"opening.cit_blocker_go01" = "Get going! "
		"opening.cit_blocker_go02" = "Go on! "
		"opening.cit_blocker_go03" = "Get going! "
		"opening.cit_blocker_holdem" = "Go on, I'll hold 'em. "
		"opening.cit_blocker_roof" = "Keep moving.  Head for the roof! "
		"opening.cit_breenagain" = "Dr. Breen again? I was hoping I'd seen the last of him in City 14. "
		"opening.cit_cell_coupon" = "This must be a mistake. I got a standard relocation coupon, just like everybody else. "
		"opening.cit_couch_use05" = "What's going on? "
		"opening.cit_drunk" = "Was that you knocking? I didn't even know we still had a door. "
		"opening.cit_fence_onlyones" = "Were you the only ones on that train? "
		"opening.cit_fence_woods" = "Overwatch stopped our train in the woods and took my husband for questioning. They said he'd be on the next train. I'm not sure when that was. They're being nice, though, letting me wait for him. "
		"opening.cit_foodline01" = "The line starts at the end. "
		"opening.cit_foodline02" = "You'll have to wait your turn like everybody else. "
		"opening.cit_foodline03" = "You gotta be damn hungry to wait in line for this crap. "
		"opening.cit_foodline04" = "I don't know about you, but I'm ready to join Civil Protection just to get a decent meal. "
		"opening.cit_hall_psst" = "Psst! Hey you! In here! "
		"opening.cit_hall_roof" = "Head for the roof! There's no time to lose! "
		"opening.cit_hit01" = "Cut it out! "
		"opening.cit_hit02" = "Stop that! "
		"opening.cit_hit03" = "Watch it, will ya? "
		"opening.cit_hit04" = "No more! "
		"opening.cit_hit05" = "That's enough of that. "
		"opening.cit_lug_allihave" = "But this stuff, it's all I have left... "
		"opening.cit_lug_allright" = "All right, I'm moving. Jeez. "
		"opening.cit_nerve" = "I'm working up the nerve to go on. "
		"opening.cit_pacing" = "<norepeat:60>...They're always departing but they never arrive... and the ones that do arrive... they never leave... you never see them go they're always full... no one ever gets on but they're always... they're always departing but they never arrive... "
		"opening.cit_pedestrian01" = "New in town, aren't ya? "
		"opening.cit_pedestrian02" = "Word to the wise: keep it to yourself. "
		"opening.cit_pedestrian03" = "If I talk to you out here, we'll both be in trouble. "
		"opening.cit_pedestrian04" = "We can't be seen talking to each other. "
		"opening.cit_pedestrian05" = "I'd like to help you, but it's out of the question. "
		"opening.cit_raid_findone" = "Don't worry, they'll find one. "
		"opening.cit_raid_reason" = "They have no reason to come to our place. "
		"opening.cit_raid_start" = "This is how it always starts. First a building, then the whole block. "
		"opening.cit_raid_use01" = "Just be glad you don't live there. "
		"opening.cit_raid_use02" = "If you're looking for a place to stay, you better keep going. "
		"opening.cit_tookcase" = "I see they took your suitcase too! They can't get away with this much longer. "
		"opening.cit_tooloud" = "I wouldn't say that too loud. This is his base of operations. "
		"opening.cit_train_endline" = "Well, end of the line. "
		"opening.cit_train_geton" = "I didn't see you get on. "
		"opening.cit_train_hookup" = "Maybe we can hook up later. "
		"opening.cit_train_reloc" = "No matter how many times I've been relocated, I never get used to it. "
		"opening.cit_water" = "Don't drink the water. They put something in it to make you forget. I don't even remember how I got here. "
		"opening.cit_window_cop" = "Oh, I thought you were a cop. "
		"opening.cit_window_hope" = "Just this once I hope you're wrong. "
		"opening.cit_window_look" = "Look at them down there. "
		"opening.cit_window_stand" = "He's one of us. "
		"opening.cit_window_use01" = "This doesn't look good. "
		"opening.cit_window_use02" = "They're definitely coming in here! "
		"opening.cit_window_use03" = "It was just a matter of time! "
		"opening.cit_window_use04" = "Here goes the rest of the neighborhood! "
		"opening.cit_window_usnext" = "I told you they'd be coming for us next! "
		"opening.husb_allright" = "It's all right. "
		"opening.husb_dontworry" = "Don't worry. "
		"opening.husb_okay" = "Everything's going to be okay. "
		"opening.husb_think" = "We'll think of something. "
		"opening.wife_canttake" = "I can't take it anymore. "
		"opening.wife_end" = "When is it all going to end? "
		"opening.wife_please" = "Please! "
		"opening.wife_whattodo" = "What are we going to do? "
		"plaza.citizen_beating" = "Ow!"
		"ravenholm.aimforhead" = "<clr:128,176,164>Aim for the head! "
		"ravenholm.attic_apologize" = "<clr:128,176,164>Ah, it is you, brother! I apologize! But no harm done. My bullets are the least of your concerns. "
		"ravenholm.bucket_almost" = "<clr:128,176,164>Almost there, brother! "
		"ravenholm.bucket_brake" = "<clr:128,176,164>The hand-brake, brother! Release it and come down! "
		"ravenholm.bucket_guardwell" = "<clr:128,176,164>Guard yourself well! "
		"ravenholm.bucket_patience" = "<clr:128,176,164>Patience, brother! "
		"ravenholm.bucket_stepin" = "<clr:128,176,164>Now, brother! Step into the cart! "
		"ravenholm.bucket_thereyouare" = "<clr:128,176,164>Ah, there you are! At last! "
		"ravenholm.bucket_waited" = "<clr:128,176,164>I will send the cart for you, brother. It will be but a moment. "
		"ravenholm.cartrap_better" = "<clr:128,176,164>Better and better! "
		"ravenholm.cartrap_iamgrig" = "<clr:128,176,164>I am Father Grigori! You have already met my congregation. "
		"ravenholm.engage01" = "<clr:128,176,164>Yes, come to me! Come! "
		"ravenholm.engage02" = "<clr:128,176,164>Come! "
		"ravenholm.engage03" = "<clr:128,176,164>Come! "
		"ravenholm.engage04" = "<clr:128,176,164>I will end your torment! "
		"ravenholm.engage05" = "<clr:128,176,164>Let me end your torment! "
		"ravenholm.engage06" = "<clr:128,176,164>Yes, my children, it is I! "
		"ravenholm.engage07" = "<clr:128,176,164>Come to the light I carry! Come! "
		"ravenholm.engage08" = "<clr:128,176,164>It is not me you want, but the light that shines through me! "
		"ravenholm.engage09" = "<clr:128,176,164>Come to the light! "
		"ravenholm.exit_darkroad" = "<clr:128,176,164>Farewell, Brother! I fear I deliver you to a darker place. May the Light of Lights illuminate your path. "
		"ravenholm.exit_goquickly" = "<clr:128,176,164>Go quickly! "
		"ravenholm.exit_hurry" = "<clr:128,176,164>Hurry while I hold the gate! "
		"ravenholm.exit_nag01" = "<clr:128,176,164>Flee, brother! "
		"ravenholm.exit_nag02" = "<clr:128,176,164>Onward to the mines! "
		"ravenholm.exit_salvation" = "<clr:128,176,164>Look to your own salvation! "
		"ravenholm.firetrap_freeuse" = "<clr:128,176,164>Make free use of my traps, but take care not to fall in them yourself. "
		"ravenholm.firetrap_lookout" = "<clr:128,176,164>Look out, brother! Behind you! "
		"ravenholm.firetrap_vigil" = "<clr:128,176,164>In Ravenholm, you do well to be vigilant. "
		"ravenholm.firetrap_welldone" = "<clr:128,176,164>Well done, brother! "
		"ravenholm.grave_follow" = "<clr:128,176,164>Follow me, brother. And tread lightly. For this is hallowed ground. "
		"ravenholm.grave_stayclose" = "<clr:128,176,164>Stay close to me, brother! "
		"ravenholm.madlaugh01" = "<clr:128,176,164>*laughter*"
		"ravenholm.madlaugh02" = "<clr:128,176,164>*laughter*"
		"ravenholm.madlaugh03" = "<clr:128,176,164>*laughter*"
		"ravenholm.madlaugh04" = "<clr:128,176,164>*laughter*"
		"ravenholm.monk_blocked01" = "<clr:128,176,164>Out of my way! "
		"ravenholm.monk_blocked02" = "<clr:128,176,164>Look out! "
		"ravenholm.monk_blocked03" = "<clr:128,176,164>Stand aside, brother! "
		"ravenholm.monk_coverme01" = "<clr:128,176,164>Cover me, brother. "
		"ravenholm.monk_coverme02" = "<clr:128,176,164>Your assistance, brother! "
		"ravenholm.monk_coverme03" = "<clr:128,176,164>Over here, brother! "
		"ravenholm.monk_coverme04" = "<clr:128,176,164>To me, brother! "
		"ravenholm.monk_coverme05" = "<clr:128,176,164>I require your assistance, brother! "
		"ravenholm.monk_coverme07" = "<clr:128,176,164>Where art thou, brother? "
		"ravenholm.monk_danger01" = "<clr:128,176,164>Look out! "
		"ravenholm.monk_danger02" = "<clr:128,176,164>Beware! "
		"ravenholm.monk_danger03" = "<clr:128,176,164>Careful, brother! "
		"ravenholm.monk_death07" = "<clr:128,176,164>Agh! "
		"ravenholm.monk_followme" = "<clr:128,176,164>Follow me. "
		"ravenholm.monk_giveammo01" = "<clr:128,176,164>Here, brother! Ammunition! "
		"ravenholm.monk_givehealth01" = "<clr:128,176,164>Heal thyself, brother! "
		"ravenholm.monk_helpme01" = "<clr:128,176,164>I am outnumbered! "
		"ravenholm.monk_helpme02" = "<clr:128,176,164>Help me, brother! "
		"ravenholm.monk_helpme03" = "<clr:128,176,164>I cannot fight them all alone! "
		"ravenholm.monk_helpme04" = "<clr:128,176,164>Lend a hand, brother! "
		"ravenholm.monk_helpme05" = "<clr:128,176,164>I need help, brother! "
		"ravenholm.monk_kill01" = "<clr:128,176,164>Woe to thee! "
		"ravenholm.monk_kill02" = "<clr:128,176,164>Woe betide thee, child! "
		"ravenholm.monk_kill03" = "<clr:128,176,164>Rest, my child. "
		"ravenholm.monk_kill04" = "<clr:128,176,164>I think no worse of thee. "
		"ravenholm.monk_kill05" = "<clr:128,176,164>May the Light of Lights be with you. "
		"ravenholm.monk_kill06" = "<clr:128,176,164>You meant no harm. "
		"ravenholm.monk_kill07" = "<clr:128,176,164>Return to your true nature. "
		"ravenholm.monk_kill08" = "<clr:128,176,164>Balm for your affliction, child. "
		"ravenholm.monk_kill09" = "<clr:128,176,164>Be free, my child! "
		"ravenholm.monk_kill10" = "<clr:128,176,164>The grave holds nothing worse for you. "
		"ravenholm.monk_kill11" = "<clr:128,176,164>I remember your true face! "
		"ravenholm.monk_mourn01" = "<clr:128,176,164>Well, brother, if I survive this night, I shall build you an honest pyre. "
		"ravenholm.monk_mourn02" = "<clr:128,176,164>Oh Light of Lights! Why have you taken my helper? "
		"ravenholm.monk_mourn03" = "<clr:128,176,164>So... again I am alone. "
		"ravenholm.monk_mourn04" = "<clr:128,176,164>Well, brother... you have found another egress from the House of Chaos. "
		"ravenholm.monk_mourn05" = "<clr:128,176,164>Rest now, brother. For you will surely live again. "
		"ravenholm.monk_mourn06" = "<clr:128,176,164>Rise, brother. Rise! "
		"ravenholm.monk_mourn07" = "<clr:128,176,164>Live again, brother! "
		"ravenholm.monk_overhere" = "<clr:128,176,164>Over here, brother. "
		"ravenholm.monk_pain01" = "<clr:128,176,164>*pain!*"
		"ravenholm.monk_pain02" = "<clr:128,176,164>*pain!*"
		"ravenholm.monk_pain03" = "<clr:128,176,164>*pain!*"
		"ravenholm.monk_pain04" = "<clr:128,176,164>*pain!*"
		"ravenholm.monk_pain05" = "<clr:128,176,164>*pain!*"
		"ravenholm.monk_pain06" = "<clr:128,176,164>*pain!*"
		"ravenholm.monk_pain07" = "<clr:128,176,164>*pain!*"
		"ravenholm.monk_pain08" = "<clr:128,176,164>*pain!*"
		"ravenholm.monk_pain09" = "<clr:128,176,164>*pain!*"
		"ravenholm.monk_pain10" = "<clr:128,176,164>*pain!*"
		"ravenholm.monk_pain12" = "<clr:128,176,164>*pain!*"
		"ravenholm.monk_quicklybro" = "<clr:128,176,164>Quickly, brother! "
		"ravenholm.monk_rant01" = "<clr:128,176,164>Iniquity's snares are cunning, but by the Light of Lights, mine are greater still. "
		"ravenholm.monk_rant02" = "<clr:128,176,164>Woe to all, for our dwelling place is distant, and we wander through the domiciles of Chaos. "
		"ravenholm.monk_rant03" = "<clr:128,176,164>My power was lost in places which were not mine. Affliction besought me, and the merciless ones attacked me without cause. "
		"ravenholm.monk_rant04" = "<clr:128,176,164>Although they call me crazy I care not, for thou art my helper, my strength, and my saviour. "
		"ravenholm.monk_rant05" = "<clr:128,176,164>Thy will be done, Oh Light of Lights. I bless the glory of thy greatness all the day and through the darkness of this night. "
		"ravenholm.monk_rant06" = "<clr:128,176,164>I pray do never turn away thy light. Give heed to me, and spring thy traps upon my enemies when I cry out to thee. "
		"ravenholm.monk_rant07" = "<clr:128,176,164>For it was said they had become like those peculiar demons, which dwell in matter but in whom no light may be found. "
		"ravenholm.monk_rant08" = "<clr:128,176,164>Turn not thy face away from me; incline thy ear and hear me when I shall cry to thee in my affliction. "
		"ravenholm.monk_rant09" = "<clr:128,176,164>For the days of my life have vanished like smoke, and my bones are parched like ash, and let all my impurities be as fuel for that fire until nothing remains but the Light alone. "
		"ravenholm.monk_rant10" = "<clr:128,176,164>From the voice of my groaning my bone has cleaved to my flesh. "
		"ravenholm.monk_rant11" = "<clr:128,176,164>For my soul is filled with evil, and like this place must be purged. "
		"ravenholm.monk_rant12" = "<clr:128,176,164>For the dead know no sleep in their graves, nor dost thou remember them, until they are destroyed through thy hands. "
		"ravenholm.monk_rant13" = "<clr:128,176,164>I have been laid down in a pit of darknesses and the shadow of death. And thy anger has pressed down upon me; and all thy cares have come down upon me. And from this bed I cry out for the kindling of thy Light! "
		"ravenholm.monk_rant14" = "<clr:128,176,164>And what terrible wonders are these those hast done among the dead. What shades rise to confess thee, and what specters shall know thee by thy name? "
		"ravenholm.monk_rant15" = "<clr:128,176,164>Oh Light, may thy name be spoken in the graves, and spelled in bones and ashes! "
		"ravenholm.monk_rant16" = "<clr:128,176,164>Thy rages have come down upon me, and thy fears have agitated me. "
		"ravenholm.monk_rant17" = "<clr:128,176,164>Judge those who do injustice to me; fight with those who fight with me. "
		"ravenholm.monk_rant18" = "<clr:128,176,164>Take hold of a weapon and shield, and rise to help me. "
		"ravenholm.monk_rant19" = "<clr:128,176,164>Draw forth a sword and sheathe it in those that afflict me; say to my soul: I am thy salvation. "
		"ravenholm.monk_rant20" = "<clr:128,176,164>May they become like dust before the wind; may the angel of the Lord pursue them. "
		"ravenholm.monk_rant21" = "<clr:128,176,164>May their paths become dark and slippery; and may the angel of the Lord afflict them. "
		"ravenholm.monk_rant22" = "<clr:128,176,164>May the snare which they do not know come to them; and may the net, which they have hidden for me, catch them in my place. "
		"ravenholm.monk_stayclosebro" = "<clr:128,176,164>Stay close, brother. "
		"ravenholm.pyre_anotherlife" = "<clr:128,176,164>But who is this? Another life to save? "
		"ravenholm.pyre_keepeye" = "<clr:128,176,164>I'll keep my eye on you. More than that, I cannot promise. "
		"ravenholm.shotgun_advice" = "<clr:128,176,164>My advice to you is... aim for the head! "
		"ravenholm.shotgun_bettergun" = "<clr:128,176,164>Here, I have a more suitable gun for you. You'll need it. "
		"ravenholm.shotgun_catch" = "<clr:128,176,164>Catch! "
		"ravenholm.shotgun_closer" = "<clr:128,176,164>Come closer. "
		"ravenholm.shotgun_hush" = "<clr:128,176,164>Hush! "
		"ravenholm.shotgun_keepitclose" = "<clr:128,176,164>Good. Now keep it close. "
		"ravenholm.shotgun_moveon" = "<clr:128,176,164>There is no rest in Ravenholm. Move on and I will meet you at the church! "
		"ravenholm.shotgun_overhere" = "<clr:128,176,164>Here, brother! "
		"ravenholm.shotgun_stirreduphell" = "<clr:128,176,164>You've stirred up Hell!  A man after my own heart! "
		"ravenholm.shotgun_theycome" = "<clr:128,176,164>They come! "
		"ravenholm.wrongside_howcome" = "<clr:128,176,164>How came you here, brother? "
		"ravenholm.wrongside_mendways" = "<clr:128,176,164>Mend your ways, before it is too late! "
		"ravenholm.wrongside_seekchurch" = "<clr:128,176,164>Did I not tell you to seek the church? "
		"ravenholm.wrongside_town" = "<clr:128,176,164>This is the wrong side of town for you! "
		"ravenholm.yard_greetings" = "<clr:128,176,164>Greetings, brother! And so we meet at last. "
		"ravenholm.yard_shepherd" = "<clr:128,176,164>As for me... A shepherd must tend to his flock. Especially when they have grown unruly. "
		"ravenholm.yard_suspect" = "<clr:128,176,164>I suspect you have little wish to remain in Ravenholm, so I will show you to the mines. "
		"ravenholm.yard_traps" = "<clr:128,176,164>You are to be commended for avoiding my traps. The work of a man who once had too much time on his hands, and now finds time for nothing but the work of salvation. "
		"rubble.ba_comebackdog" = "<clr:215,255,255>Here boy, Dog! come back here, Dog! "
		"rubble.ba_damnitall" = "<clr:215,255,255>Damn it all! "
		"rubble.ba_dogwantsyou" = "<clr:215,255,255>I think he wants you to go through, Gordon.  You'd better hurry. "
		"rubble.ba_gordon" = "<clr:215,255,255>Gordon! "
		"rubble.ba_helpmeout" = "<clr:215,255,255>Hey!  Help me out here! "
		"rubble.ba_illbedamned" = "<clr:215,255,255>Well, I'll be damned. "
		"rubble.ba_lookingforalyx" = "<clr:215,255,255>Dog came crashing through the plaza, knocking over walls and...I think he's looking for Alyx. He seems to have it set in his head that she's in the Citadel. "
		"rubble.ba_nag_wall01" = "<clr:215,255,255>Go on through, Gordon. "
		"rubble.ba_nag_wall02" = "<clr:215,255,255>Better get going, Gordon. "
		"rubble.ba_nag_wall03" = "<clr:215,255,255>I'll hold 'em off.  You'd better get going. "
		"rubble.ba_nag_wall04" = "<clr:215,255,255>Go on! "
		"rubble.ba_nag_wall05" = "<clr:215,255,255>Hey, go! "
		"rubble.ba_nottheredog" = "<clr:215,255,255>Hey, Dog! Not there! You can't get through that way! "
		"rubble.ba_tellbreen" = "<clr:215,255,255>And if you see Dr. Breen, tell him I said, 'Fu----ou!' "
		"rubble.ba_trystoppinghim" = "<clr:215,255,255>I figured Alyx wouldn't want him getting any deeper in trouble, but... Hell, you try stopping him! "
		"rubble.ba_youhurryon" = "<clr:215,255,255>Uh oh.  I'll stay here.  You hurry on. Good luck up there, Gordon! "
		"rubble.cit_cache" = "We're almost to the Citadel wall, Doc. I don't know how the hell we're going to breach it, but you've made it this far. I'm sure you'll think of something. "
		"rubble.cit_striders" = "Dr. Freeman! It's a mess out there. This close to the Citadel they've turned the streets over to Striders. I think we can push them back if we can just get to high ground. "
		"rubble.d3_c17_13_horse01" = "Head for the horse! "
		"rubble.d3_c17_13_horse02" = "We have to get to the horse! "
		"rubble.d3_c17_13_horse03" = "Let's meet up at the horse! "
		"sandtrap.sandy_asyougo" = "Remember to stay off the sand. The antlions are edgy right now. "
		"sandtrap.sandy_dontmove" = "Laszlo, don't move! "
		"sandtrap.sandy_dontstep" = "Don't step on the sand! It makes the antlions crazy! "
		"sandtrap.sandy_goahead" = "Go ahead. I hope you have better luck than we had. "
		"sandtrap.sandy_help" = "No! Help! "
		"sandtrap.sandy_holdstill" = "Hold still, Laszlo! Someone's coming! "
		"sandtrap.sandy_poorlaszlo" = "Dear God!  Poor Laszlo!  The finest mind of his generation, come to such an end. "
		"sandtrap.sandy_stop" = "Stop where you are! Stay on the rocks! "
		"sandtrap.sandy_vortcamp" = "We were heading to the vortigaunt camp, hoping to pick up some bugbait so these damn things would leave us alone. But without Laszlo what's the point? "
		"sandtrap.sandy_youidiot" = "You idiot! Walking on the sand brings antlions after you! "
		"sandtrap.sandy_youthere" = "You, there! "
		"sandtrap.sandy_youtried" = "I know you tried to help. I'll stay with him awhile. There's something I have to do. "
		"sniper.cit_greeting" = "Dr. Freeman! Barney said you were on the way. We got split up by snipers, and he's pinned down in a warehouse up ahead. Go ahead. He's relying on you. "
		"sniper.cit_savebarney" = "You're Barney's old friend, aren't you? Maybe you can help him. Snipers trapped him on that warehouse roof. He was going for a cache of grenades, but I doubt he can get to them now. Go on, Dr. Freeman. "
		"streetwar.al_ah" = "<clr:255,212,255>Ah! "
		"streetwar.al_ahno" = "<clr:255,212,255>Ah, no! "
		"streetwar.al_almostdone" = "<clr:255,212,255>Almost done."
		"streetwar.al_bridge01" = "<clr:255,212,255>The bridge we've gotta cross is beyond that gate."
		"streetwar.al_bridge02" = "<clr:255,212,255>I can hack the gate controls and hold it open till we're through, but you're gonna have to watch my back while I'm working."
		"streetwar.al_cmoncmon" = "<clr:255,212,255>Come on, come on. "
		"streetwar.al_comeon03_r" = "<clr:255,212,255>Come on, Gordon! "
		"streetwar.al_commandcenter" = "<clr:255,212,255>There's a command center downstairs. I'm hoping to find information about generator locations. "
		"streetwar.al_coreexposed" = "<clr:255,212,255>Okay, the core's exposed. "
		"streetwar.al_coreexposed_r" = "<clr:255,212,255>Okay, the core's exposed. "
		"streetwar.al_coupleminutes" = "<clr:255,212,255>It could take me a couple minutes to take control of the gate."
		"streetwar.al_damn" = "<clr:255,212,255>Damn!"
		"streetwar.al_disablegen" = "<clr:255,212,255>Well, we're in luck. There's a generator in the square outside. We're trying to disable as many as we can to loosen the Combine's grip on this sector. "
		"streetwar.al_exposecore_a" = "<clr:255,212,255>It'll take me a few minutes to expose the core. "
		"streetwar.al_exposecore_b" = "<clr:255,212,255>Then I'll need you to hit it with a burst from the gravity gun. "
		"streetwar.al_extshield" = "<clr:255,212,255>There goes the external shield. "
		"streetwar.al_extshield_r" = "<clr:255,212,255>There goes the external shield. "
		"streetwar.al_farside" = "<clr:255,212,255>Okay.  Barney should be on the far side of that... canal. "
		"streetwar.al_firstbit" = "<clr:255,212,255>First bit's done."
		"streetwar.al_gateisopen_r" = "<clr:255,212,255>The gate is open. "
		"streetwar.al_getoverhere" = "<clr:255,212,255>Get over here! "
		"streetwar.al_goingthru01" = "<clr:255,212,255>Looks like instead of going over it "
		"streetwar.al_goingthru02" = "<clr:255,212,255>we'll be going through. "
		"streetwar.al_goodletsgo" = "<clr:255,212,255>Good.  Let's go."
		"streetwar.al_gordonrun" = "<clr:255,212,255>Gordon, run! Get out of here! "
		"streetwar.al_hadfeeling" = "<clr:255,212,255>Gordon! I had a feeling I'd find you here. "
		"streetwar.al_heregoes" = "<clr:255,212,255>All right, here goes."
		"streetwar.al_hey" = "<clr:255,212,255>Hey! "
		"streetwar.al_hurry" = "<clr:255,212,255>Hurry! "
		"streetwar.al_imwaiting_r" = "<clr:255,212,255>I'm waiting, Gordon. "
		"streetwar.al_inshield" = "<clr:255,212,255>Inner shields are coming down. "
		"streetwar.al_inshield_r" = "<clr:255,212,255>Inner shields are coming down. "
		"streetwar.al_iwasafraid" = "<clr:255,212,255>I was afraid you weren't going to make it. "
		"streetwar.al_letsgo" = "<clr:255,212,255>Ready? Let's go! "
		"streetwar.al_letsgo01" = "<clr:255,212,255>Let's go! "
		"streetwar.al_letsgo02_r" = "<clr:255,212,255>Let's go! "
		"streetwar.al_no" = "<clr:255,212,255>No! "
		"streetwar.al_nottoolong" = "<clr:255,212,255>This shouldn't take too long. As soon as the generator's down, I'll open that gate and we can get out of here. "
		"streetwar.al_nowtobarney" = "<clr:255,212,255>I've got Dr. Kleiner in a safe spot. Now we can join up with Barney. "
		"streetwar.al_nowtricky" = "<clr:255,212,255>Now for the tricky part."
		"streetwar.al_okthatsit" = "<clr:255,212,255>Okay, that's it!"
		"streetwar.al_okthisisit" = "<clr:255,212,255>Okay, this is it. You take that door. I'll take this one. "
		"streetwar.al_onemorebit" = "<clr:255,212,255>One more bit and we're ready."
		"streetwar.al_onewill01" = " "
		"streetwar.al_onewill02" = " "
		"streetwar.al_openinggate" = "<clr:255,212,255>All right, I'm opening the gate. "
		"streetwar.al_readywhenyou" = "<clr:255,212,255>Ready when you are. "
		"streetwar.al_scout" = "<clr:255,212,255>Let me see if I can scout a new path. "
		"streetwar.al_standardpanel" = "<clr:255,212,255>It's a standard panel. "
		"streetwar.al_thankgod" = "<clr:255,212,255>Thank God. "
		"streetwar.al_thatsit" = "<clr:255,212,255>That's it. "
		"streetwar.al_thatsit_r" = "<clr:255,212,255>That's it. "
		"streetwar.al_thatway" = "<clr:255,212,255>Let's head that way. "
		"streetwar.al_thebridge" = "<clr:255,212,255>The bridge! "
		"streetwar.al_thedeal" = "<clr:255,212,255>Ok, here's the deal."
		"streetwar.al_there" = "<clr:255,212,255>There."
		"streetwar.al_theresbridge01" = "<clr:255,212,255>There's the bridge "
		"streetwar.al_theresbridge02" = "<clr:255,212,255>Let's get across. "
		"streetwar.al_theysawus" = "<clr:255,212,255>They saw us! "
		"streetwar.al_thrudownthere" = "<clr:255,212,255>Looks like we might be able to get through down there. "
		"streetwar.al_usedtobe" = "<clr:255,212,255>Well, there used to be a bridge here. "
		"streetwar.al_usegravgun01" = "<clr:255,212,255>Use the gravity gun, Gordon. "
		"streetwar.al_usegravgun01_r" = "<clr:255,212,255>Use the gravity gun, Gordon."
		"streetwar.al_usegravgun02" = "<clr:255,212,255>Go on, Gordon, give the core a jolt. "
		"streetwar.al_usegravgun02_r" = "<clr:255,212,255>Go on, Gordon, give the core a jolt. "
		"streetwar.al_usegravgun03" = "<clr:255,212,255>Gordon, hit the core with your gravity gun. "
		"streetwar.al_usegravgun03_r" = "<clr:255,212,255>Gordon, hit the core with your gravity gun. "
		"streetwar.al_waitforme" = "<clr:255,212,255>Wait for me here. "
		"streetwar.al_watchmyback" = "<clr:255,212,255>In the meantime, watch my back. "
		"streetwar.al_whatnow01" = "<clr:255,212,255>What now? "
		"streetwar.al_whatnow02" = "<clr:255,212,255>We have to get across this canal! "
		"streetwar.ba_allclearthxgordon" = "<clr:215,255,255>It's all clear, thanks to Gordon. "
		"streetwar.ba_cantmove" = "<clr:215,255,255>Gordon, I can't move.  These snipers got me pinned down. "
		"streetwar.ba_gateclearance" = "<clr:215,255,255>Let me get this gate.  My Civil Protection status still gives me limited clearance. "
		"streetwar.ba_goodtohavehelp" = "<clr:215,255,255>It's good to see ya, Gordon. It'll be good to have your help goin' into the nexus up ahead. "
		"streetwar.ba_hauntsme" = "<clr:215,255,255>That damn thing haunts me. "
		"streetwar.ba_headhumpersgordon" = "<clr:215,255,255>Watch the headhumpers, Gordon. "
		"streetwar.ba_hearcat" = "<clr:215,255,255>Did you hear a cat just now? "
		"streetwar.ba_heycomeon" = "<clr:215,255,255>Hey, come on! "
		"streetwar.ba_letsclearout" = "<clr:215,255,255>All right, thanks, Gordon. Now let's clear outta here. "
		"streetwar.ba_letsgetgoing" = "<clr:215,255,255>Let's get going. "
		"streetwar.ba_nag_grenade01" = "<clr:215,255,255>The grenades, Gordon! "
		"streetwar.ba_nag_grenade02" = "<clr:215,255,255>Hey, look at the grenades, would ya? "
		"streetwar.ba_nag_grenade03" = "<clr:215,255,255>How about a grenade, Gordon? "
		"streetwar.ba_nag_grenade04" = "<clr:215,255,255>Gordon, lob a couple grenades, that'll clear 'em out. "
		"streetwar.ba_nag_grenade05" = "<clr:215,255,255>Gordon!  Grenades!"
		"streetwar.ba_onedown" = "<clr:215,255,255>One down! "
		"streetwar.ba_onedownonetogo" = "<clr:215,255,255>That's one down, one to go, buddy! "
		"streetwar.ba_onemorenow" = "<clr:215,255,255>All right! One more now! Come on, Gordon! "
		"streetwar.ba_overhere" = "<clr:215,255,255>Over here! "
		"streetwar.ba_putsqueeze" = " "
		"streetwar.ba_returnhero" = "<clr:215,255,255>You're quite the returning hero these days, Gordon. "
		"streetwar.ba_takeoutsnipers" = "<clr:215,255,255>Gordon, take out these snipers, would ya?! "
		"streetwar.c17_05_firepit_greet" = "Dr. Freeman? We hoped for one more fighter to help storm that barricade, but we never guessed it would be you. "
		"streetwar.c17_05_hoppers" = "Watch out for the hoppers. They're everywhere! "
		"streetwar.c17_05_letusthru" = "Let us through! "
		"streetwar.c17_05_minehelp1" = "Don't waste the hoppers, Dr. Freeman. We can use them against the Combine. "
		"streetwar.c17_05_minehelp2" = "If you can get those hoppers up without setting them off, you can plant them wherever you want them. "
		"streetwar.c17_05_opengate" = "Open the gate! "
		"streetwar.c17_05_tail" = "They're on our tail!"
		"streetwar.c17_06_det01" = "Gordon Freeman? It is you, isn't it? Give me a minute, I'm gonna plant some charges and blow this open. "
		"streetwar.c17_06_det02" = "If you can hold them off, I'm almost done here. "
		"streetwar.c17_06_det03" = "Okay, last charge! "
		"streetwar.c17_06_det04" = "Stand back. It's gonna blow! "
		"streetwar.c17_06_det05" = "Come on through, Freeman. And hurry. "
		"streetwar.c17_06_keepcoming" = "The manhacks just keep coming.  They're never gonna stop! "
		"streetwar.c17_06_keepmoving" = "Keep moving, Dr. Freeman. I'll send word you're coming, and see you up ahead. "
		"streetwar.c17_06_notsafe" = "Dr. Freeman? If you were looking for a place to hole up, it's not safe here anymore. They're shelling the hell out of us. "
		"streetwar.c17_06_password01" = "Hey, it's me. Open the door. "
		"streetwar.c17_06_password02" = "What's the password? "
		"streetwar.c17_06_password03" = "Password! "
		"streetwar.c17_06_password04" = "Come on in. "
		"streetwar.c17_06_plank01" = "Okay, come across! "
		"streetwar.c17_06_plank02" = "I've got to stay here in case anyone else needs to get across. "
		"streetwar.c17_06_tunnel_greet" = "Dr. Freeman! The Combine has cut our supply tunnel in two. If you'll join up with us, we'll take a stab at pushing through their outpost. "
		"streetwar.c17_09_ba_allover" = "<clr:215,255,255>That's better.  I thought it was all over for me."
		"streetwar.c17_09_ba_cantmove" = " "
		"streetwar.c17_09_ba_gothru" = "<clr:215,255,255>Go on through, Gordon."
		"streetwar.c17_09_ba_headout" = "<clr:215,255,255>Okay, let's head for the gate and I'll open it while the coast is clear."
		"streetwar.c17_09_ba_medic" = " "
		"streetwar.c17_09_ba_needhelp" = "<clr:215,255,255>We're going to need all the help we can get, dealing with the Nexus up ahead."
		"streetwar.c17_09_casualties" = " "
		"streetwar.c17_09_cellar" = "Help! Help me! We thought we'd be safer down here. Little did we know the place was infested. Rest of 'em headed upstairs, took their chances with the snipers. I guess they're still up there. "
		"streetwar.c17_09_help01" = "Help!"
		"streetwar.c17_09_help02" = "Help me!"
		"streetwar.c17_09_help03" = "Is somebody up there!"
		"streetwar.c17_09_help04" = "Help me!"
		"streetwar.c17_09_med_greet" = " "
		"streetwar.c17_09_med_heal" = " "
		"streetwar.c17_10_heshere" = "It's Freeman, he's here!  Let us out, we'll throw in with you. "
		"streetwar.c17_10_letusout" = "Hey, let us out of here! "
		"streetwar.d3_c17_06_post_det01" = "That door's locked from the other side, Dr. Freeman. Maybe you can find a way around. "
		"streetwar.d3_c17_06_post_det02" = "Looks nasty in there. Good thing you've got that suit. "
		"streetwar.d3_c17_06_post_det03" = "Hey! Let us through! I can hear you in there! Come on! Open the door! "
		"streetwar.d3_c17_06_post_det04" = "I see you made it through okay. Figured you would. "
		"streetwar.d3_c17_07_tenant" = "You were amazing back there, Dr. Freeman! But I feel sorry for anyone who put down a security deposit. "
		"streetwar.al_gordon02" = "<clr:255,212,255>Gordon!"
		"streetwar.al_uggh02" = "<clr:255,212,255>Agh!"
		"Trainride.gman_riseshine" = "Rise and shine, Mr. Freeman. Rise and shine. "
		"Trainride.gman_02" = "Not that I wish to imply you have been sleeping on the job.  No one is more deserving of a rest.  And all the effort in the world would have gone to waste until...well, let's just say your hour has come again. "
		"Trainride.gman_03" = "The right man in the wrong place can make all the difference in the world. "
		"Trainride.gman_04" = "So, wake up, Mr. Freeman.  Wake up and smell the ashes. "
		"Trainyard.al_dadstarted" = "<clr:255,212,255>Heh. Don't get my dad started on Dr. Breen. "
		"Trainyard.al_hmm" = "<clr:255,212,255>Hm."
		"Trainyard.al_imalyx" = "<clr:255,212,255>I'm Alyx Vance. My father worked with you, back in Black Mesa. I'm sure you don't remember me though. "
		"Trainyard.al_nicetomeet" = " "
		"Trainyard.al_nicetomeet_b" = " "
		"Trainyard.al_nicetomeet_cc" = "<clr:255,212,255>Oh, and by the way?  Nice to finally meet you."
		"Trainyard.al_nomap" = "<clr:255,212,255>Dr. Kleiner said you'd be coming this way. I don't think it occurred to him that you might not have a map. "
		"Trainyard.al_noyoudont" = "<clr:255,212,255>Ha! No you don't! "
		"Trainyard.al_oldadmin" = "<clr:255,212,255>Remember him from Black Mesa? Your old Administrator? "
		"Trainyard.al_overhere" = "<clr:255,212,255>Over here! "
		"Trainyard.al_presume" = "<clr:255,212,255>Doctor Freeman, I presume? "
		"Trainyard.al_suspicious" = "<clr:255,212,255>We'd better hurry. The Combine can be slow to wake, but once they're up, you don't want to get in their way. "
		"Trainyard.al_suspicious_b" = " "
		"Trainyard.al_suspicious_cc" = "<clr:255,212,255>We'd better hurry. The Combine can be slow to wake, but once they're up, you don't want to get in their way. "
		"Trainyard.al_thisday" = "<clr:255,212,255>Funny, you showing up on this day in particular. "
		"Trainyard.al_thisday01" = " "
		"Trainyard.al_thisday01_cc" = "<clr:255,212,255>We've been helping people escape the city on foot.  It's a dangerous route to my father's lab, through the old canals.  Today we're finally on the verge of having a better way. "
		"Trainyard.al_thisday02" = " "
		"Trainyard.al_thisday03" = " "
		"Trainyard.al_thisday04" = " "
		"Trainyard.al_thruhere" = "<clr:255,212,255>Through here. "
		"Trainyard.ba_backup" = "Back up! "
		"Trainyard.ba_blowcover" = "<clr:215,255,255>Oh man, that's what I was afraid of. Get in here, Gordon, before you blow my cover. "
		"Trainyard.ba_blowcover_b" = "<clr:215,255,255>Pile up some stuff to get through that window, and keep going till you're in the plaza. "
		"Trainyard.ba_checkpoints" = "<clr:215,255,255>Well, as long as he stays away from checkpoints we should be okay. "
		"Trainyard.ba_citadel02" = "<clr:215,255,255>The Citadel's on full alert! I've never seen it lit up like that. "
		"Trainyard.ba_crowbar01" = " "
		"Trainyard.ba_crowbar01_cc" = "<clr:215,255,255>Oh, and before I forget.  I think you dropped this back in Black Mesa."
		"Trainyard.ba_crowbar02" = " "
		"Trainyard.ba_exitnag01" = "<clr:215,255,255>There's no time to waste here, Gordon. Get a move on! "
		"Trainyard.ba_exitnag02" = "<clr:215,255,255>They're right outside, get going! "
		"Trainyard.ba_exitnag03" = "<clr:215,255,255>Hey, move it now, will you? "
		"Trainyard.ba_exitnag04" = "<clr:215,255,255>Will you get going? "
		"Trainyard.ba_exitnag05" = "<clr:215,255,255>Move it along! "
		"Trainyard.ba_exitnag06" = "<clr:215,255,255>Get going, Gordon! "
		"Trainyard.ba_exitnag07" = "<clr:215,255,255>Hurry up! "
		"Trainyard.ba_getin" = "Get in! "
		"Trainyard.ba_getoutfast" = " "
		"Trainyard.ba_getoutfast_cc" = "<clr:215,255,255>Get out of City 17 as fast as you can, Gordon! Take the old canals, right?  They'll get you to Eli's lab.  It's a dangerous route, but there's a whole network of refugees and they'll help you if they can."
		"Trainyard.ba_goodluck01" = " "
		"Trainyard.ba_goodluck01_cc" = "<clr:215,255,255>Good luck out there, buddy.  You're gonna need it."
		"Trainyard.ba_goodluck02" = " "
		"Trainyard.ba_goon" = "Go on!"
		"Trainyard.ba_gottago" = "<clr:215,255,255>Listen, I gotta go, Doc. We're taking enough chances as it is. "
		"Trainyard.ba_heygordon" = "<clr:215,255,255>Hey, Gordon! "
		"Trainyard.ba_inhere2" = "Get in here. "
		"Trainyard.ba_lookafterdoc" = "<clr:215,255,255>I'd come with you, but I've got to look after Dr. Kleiner. "
		"Trainyard.ba_lookwho" = "<clr:215,255,255>Sorry, Doc, but look who's here. "
		"Trainyard.ba_meetyoulater01" = "<clr:215,255,255>I'll meet up with you later. "
		"Trainyard.ba_move01" = "I said 'move!' "
		"Trainyard.ba_noimgood" = "No, I'm good. "
		"Trainyard.ba_oldcanals" = "<clr:215,255,255>Take the canals, right?  They'll get you to Eli's lab. It's a dangerous route, but there's a whole network of refugees and they'll help you if they can. "
		"Trainyard.ba_ownway" = "<clr:215,255,255>Okay, Gordon you're gonna have to make your own way to Dr. Kleiner's lab. "
		"Trainyard.ba_privacy" = "Yeah, I'm gonna need me some privacy for this! "
		"Trainyard.ba_rememberme" = "<clr:215,255,255>It's me, Gordon! Barney from Black Mesa. "
		"Trainyard.ba_rooftops" = "<clr:215,255,255>There's supposed to be a high route over the rooftops, but... I've never been that way myself. "
		"Trainyard.ba_sorryscare" = "<clr:215,255,255>Hey, sorry for the scare. I had to put on a show for the cameras. "
		"Trainyard.ba_tellme01" = " "
		"Trainyard.ba_tellme01_cc" = "<clr:215,255,255>Yeah, you and me both, Doc.  He was about to board the Express to Nova Prospekt."
		"Trainyard.ba_tellme02" = " "
		"Trainyard.ba_thatbeer01" = "Now..."
		"Trainyard.ba_thatbeer02" = "<clr:215,255,255>...about that beer I owed ya. "
		"Trainyard.ba_thinking01" = "<clr:215,255,255>I'm thinking, I'm thinking. "
		"Trainyard.ba_undercover" = "<clr:215,255,255>I've been working undercover with Civil Protection. I can't take too long or they'll get suspicious. I'm way behind on my beating quota. "
		"Trainyard.ba_youcomewith" = "You, Citizen!  Come with me. "
		"Trainyard.cit_term_ques02" = "This is my third transfer this year. "
		"Trainyard.cop_knockitoff" = "Get out of here. "
		"Trainyard.cop_needanyhelp" = "Need any help with this one? "
		"Trainyard.kl_alyxaround" = "<clr:255,255,200>Alyx is around here somewhere. She would have a better idea how to get him here. "
		"Trainyard.kl_intend" = "<clr:255,255,200>Well, Barney, what do you intend? "
		"Trainyard.kl_morewarn01" = " "
		"Trainyard.kl_morewarn01_cc" = "<clr:255,255,200>Great Scott!  Gordon Freeman!  I expected more warning."
		"Trainyard.kl_morewarn02" = " "
		"Trainyard.kl_morewarn03" = " "
		"Trainyard.kl_verywell" = "<clr:255,255,200>Very well. And, eh, Gordon? Good to see you! "
		"Trainyard.kl_whatisit01" = " "
		"Trainyard.kl_whatisit01_cc" = "<clr:255,255,200>Yes, Barney, what is it?  I'm in the middle of a critical test."
		"Trainyard.kl_whatisit02" = " "
		"Trainyard.man_me" = "Me?! "
		"Trainyard.man_waitaminute" = "Wait a minute... "
		"Trainyard.man_whereyoutakingme" = "Where are you taking me? "
		"Trainyard.metro_suprise" = " "
		"opening.cit_tvbust01" = "What are you doing? "		
		"opening.cit_tvbust02" = "You're gonna be in trouble. "		
		"opening.cit_tvbust03" = "Hey, you're gonna bring trouble down on all of us! "		
		"opening.cit_tvbust04" = "Put that down! "		
		"opening.cit_tvbust05" = "Oh no. Now we're really gonna get it. "
		"Canals.d1_canals_01_arrest_helpme" = "Help me!"
		"Town.d1_town_01_monk_rant07" = "For it was said they had become like those peculiar demons, which dwell in matter but in whom no light may be found."
		"Town.d1_town_01_monk_rant09" = "For the days of my life have vanished like smoke, and my bones are parched like ash, and let all my impurities be as fuel for that fire until nothing remains but the Light alone."
		"Town.d1_town_01_monk_rant20" = "May they become like dust before the wind; may the angel of the Lord pursue them."
		// "ravenholm.madlaugh02" = "*laughter*"
		"coast.crane_playerincar" = "<I>Good, here we go."
		"coast.crane_magfail" = "<I>Damn magnet's failing...hold on!"
		"coast.crane_sorry" = "<I>Sorry, Doc."
		"coast.crane_gravgun" = "<I>Use your gravity gun to flip the car over again."
		"coast.crane_driveforfeel" = "<I>Why don't you take a spin around the beach until you've got a feel for the car.  When you're done, head for the slope down by the water."
		"coast.crane_antlions" = "<I>Watch out for antlions."
		"coast.crane_rockslide" = "<I>You're never gonna get traction in that gravel.  Try the slope down by the water."
		"coast.crane_pier01" = "<I>Come back up, Dr. Freeman.  The car's on the pier."
		"coast.crane_pier02" = "<I>I said, get back up on the pier."
		"coast.crane_pier03" = "<I>Dr. Freeman, you won't get anywhere on foot.  Come back up and get in the car."
		"coast.crane_hopin" = "<I>Hop in and I'll lower you down to the beach."
		"coast.crane_carsallready" = "<I>Hello, Dr. Freeman.  The car's all ready for you."
		"coast.crane_getupandhellout" = "<I>Get that car upright and get the hell out of here!"
		"streetwar.d3_c17_06a_overhere01" = "Hey, over here!"
