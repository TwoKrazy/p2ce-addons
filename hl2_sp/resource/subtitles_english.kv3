		"ep2_rebel.reb_leading02" = "You want to follow me?"
		"ep2_rebel.reb_leading03" = "Come on Freeman."
		"ep2_rebel.reb_leading04" = "Come on Doc."
		"ep2_rebel.reb_manhacks01" = "Manhacks!"
		"ep2_rebel.reb_manhacks02" = "Here come the hacks!"
		"ep2_rebel.reb_manhacks03" = "Here come the hacks!"
		"ep2_rebel.reb_medkit01" = "Here have a medkit."
		"ep2_rebel.reb_medkit02" = "Here have a medkit."
		"ep2_rebel.reb_medkit03" = "Medkit coming your way."
		"ep2_rebel.reb_medkit04" = "Take a medkit."
		"ep2_rebel.reb_medkit05" = "Here's a medkit doc."
		"ep2_rebel.reb_medkit06" = "You better heal up doc."
		"ep2_rebel.reb_medkit07" = "You better heal up doc."
		"ep2_rebel.reb_medkit08" = "Here take this."
		"ep2_rebel.reb_medkit09" = "Here you go doc."
		"ep2_rebel.reb_nevergonnamakeit01" = "I'm never gonna make it."
		"ep2_rebel.reb_nevergonnamakeit02" = "I'm never gonna make it."
		"ep2_rebel.reb_nevergonnamakeit03" = "I'm never gonna make it."
		"ep2_rebel.reb_nevergonnamakeit04" = "I'm never gonna make it."
		"ep2_rebel.reb_newweapon01" = "Oh man, I've been wanting one of these."
