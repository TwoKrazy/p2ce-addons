		"npc_alyx.howlongwait01" = "<clr:255,212,255>How long are we just gonna wait? "
		"npc_alyx.hurt04" = "<clr:255,212,255>Ow! "
		"npc_alyx.hurt05" = "<clr:255,212,255>Ow! "
