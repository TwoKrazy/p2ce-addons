		"ep2_rebel.reb_striders06" = "Oh god, strider!"
		"ep2_rebel.reb_striders07" = "Striders!"
		"ep2_rebel.reb_striders08" = "Strider!"
		"ep2_rebel.reb_striders09" = "Striderrr!"
		"ep2_rebel.reb_striders10" = "Striderr!"
		"ep2_rebel.reb_thatsitforme01" = "That's it for me."
		"ep2_rebel.reb_thatsitforme02" = "That's it for me."
		"ep2_rebel.reb_thatsitforme03" = "That's it... That's it for me."
		"ep2_rebel.reb_turretdown01" = "Got a turret down."
		"ep2_rebel.reb_turretdown02" = "Turret down."
		"ep2_rebel.reb_turretdown03" = "That turret's had it."
		"ep2_rebel.reb_turretdown04" = "That turret's cooked."
		"ep2_rebel.reb_turretdown05" = "Watch your turret Doc!"
		"ep2_rebel.reb_use_deny01" = "No."
		"ep2_rebel.reb_use_deny02" = "Nah."
		"ep2_rebel.reb_use_deny03" = "I don't think so."
		"ep2_rebel.reb_use_deny04" = "Ain't gonna happen."
		"ep2_rebel.reb_use_deny05" = "No thanks I'm good."
		"ep2_rebel.reb_use_deny06" = "Nope."
		"ep2_rebel.reb_use_deny07" = "uh-huh."
		"ep2_rebel.reb_use_deny08" = "Not right now."
		"ep2_rebel.reb_use_deny09" = "Hell no."
		"ep2_rebel.reb_use_deny10" = "Hell no!"
		"ep2_rebel.reb_warnings01" = "Look out. "
		"ep2_rebel.reb_warnings02" = "Watch out."
		"ep2_rebel.reb_warnings03" = "Oh no!  A turret just went kaput!"
		"ep2_rebel.reb_warnings04" = "Uh oh"
		"ep2_rebel.reb_warnings05" = "Uh oh"
		"ep2_rebel.reb_warnings06" = "Shit"
