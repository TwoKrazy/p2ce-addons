		"ep1_citizen.cit_kill16_male" = "Rot in hell!  If you believe in that sort of thing. "
		"ep1_citizen.cit_kill17_male" = "Rot in hell! "
		"ep1_citizen.cit_kill18_male" = "That's how you do it, eh Freeman?"
		"ep1_citizen.cit_kill19_male" = "See what I just did there?"
		"ep1_citizen.cit_kill20_male" = "[Giddy laughter]"
		"ep1_citizen.cit_letyouthru_male" = "Okay, we'll let you through!"
