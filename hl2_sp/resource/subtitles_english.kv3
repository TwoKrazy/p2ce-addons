		"npc_citizen.vanswer01" = "Enough of your mumbo jumbo. "
		"npc_citizen.vanswer02" = "Damn vorts. "
		"npc_citizen.vanswer03" = "I'm not sure how to take that. "
		"npc_citizen.vanswer04" = "Should I take that personally?"
		"npc_citizen.vanswer05" = "Speak English."
		"npc_citizen.vanswer06" = "You got that from me."
		"npc_citizen.vanswer07" = "That's why we put up with you."
		"npc_citizen.vanswer08" = "Couldn't have put it better myself. "
		"npc_citizen.vanswer09" = "That almost made sense."
		"npc_citizen.vanswer10" = "Something must be wrong with me, I almost understood that."
		"npc_citizen.vanswer11" = "I guess I'm getting used to you vorts."
		"npc_citizen.vanswer12" = "None of your vort philosophy."
		"npc_citizen.vanswer13" = "Stop, you're killing me!"
		"npc_citizen.vanswer14" = "What did I do to deserve this?"
		"npc_citizen.vquestion01" = "Stop looking at me like that."
		"npc_citizen.vquestion02" = "Some things I just never get used to."
