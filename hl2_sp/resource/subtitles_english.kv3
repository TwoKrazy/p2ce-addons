		"npc_barney.ba_run02" = "<clr:215,255,255>Run! "		
		"npc_barney.ba_soldiers" = "<clr:215,255,255>Soldiers! "		
		"npc_barney.ba_thatwasclose01" = "<clr:215,255,255>That was close! "		
		"npc_barney.ba_thatwasclose02" = "<clr:215,255,255>That was close! "		
		"npc_barney.ba_thisisbad01" = "<clr:215,255,255>This is bad. "		
		"npc_barney.ba_thisisbad02" = "<clr:215,255,255>Okay, this is bad. "		
		"npc_barney.ba_turret" = "<clr:215,255,255>Turret! "		
		"npc_barney.ba_uhohheretheycome" = "<clr:215,255,255>Uh oh, here they come! "		
		"npc_barney.ba_wounded01" = "<clr:215,255,255>I'm hurtin, Gordon. "		
		"npc_barney.ba_wounded02" = "<clr:215,255,255>I need to get patched up. "		
		"npc_barney.ba_wounded03" = "<clr:215,255,255>I'm hurt pretty bad... "		
		"npc_barney.ba_yell" = "<clr:215,255,255>Yeah! "
		"npc_citizen.abouttime01" = "Well, Gordon Freeman! And about time, too. "
		"npc_citizen.abouttime02" = "Well, Gordon Freeman! And about time, too. "
		"npc_citizen.ahgordon01" = "Ah, Gordon Freeman. "
		"npc_citizen.ahgordon02" = "Ah, Gordon Freeman. "
		"npc_citizen.almosthityou01" = "I almost hit you."
		"npc_citizen.almosthityou02" = "I almost hit you."
		"npc_citizen.ammo01" = "Freeman, ammo! "
		"npc_citizen.ammo02" = "Freeman, ammo! "
		"npc_citizen.ammo03" = "Here, ammo! "
		"npc_citizen.ammo04" = "Take some ammo! "
		"npc_citizen.ammo05" = "Take some ammo! "
		"npc_citizen.answer01" = "That's you all over. "
		"npc_citizen.answer02" = "I won't hold it against you. "
		"npc_citizen.answer03" = "Figures. "
		"npc_citizen.answer04" = "Try not to dwell on it. "
		"npc_citizen.answer05" = "Could we talk about this later? "
		"npc_citizen.answer06" = "Keep it to yourself. "
		"npc_citizen.answer07" = "Same here. "
		"npc_citizen.answer08" = "Know what you mean. "
		"npc_citizen.answer09" = "You're talking to yourself again. "
		"npc_citizen.answer10" = "I wouldn't say that too loud. "
		"npc_citizen.answer11" = "I'll put it on your tombstone. "
		"npc_citizen.answer12" = "Doesn't bear thinking about. "
		"npc_citizen.answer13" = "I'm with you. "
		"npc_citizen.answer14" = "You and me both. "
		"npc_citizen.answer15" = "That's one way of looking at it. "
		"npc_citizen.answer16" = "Have you ever had an original thought? "
		"npc_citizen.answer17" = "I'm not even gonna tell you to shut up. "
		"npc_citizen.answer18" = "Let's concentrate on the task at hand. "
		"npc_citizen.answer19" = "Keep your mind on your work. "
		"npc_citizen.answer20" = "Your mind is in the gutter. "
		"npc_citizen.answer21" = "Don't be so sure of that. "
		"npc_citizen.answer22" = "You never know. "
		"npc_citizen.answer23" = "Never can tell. "
		"npc_citizen.answer24" = "Why are you telling me? "
		"npc_citizen.answer25" = "How about that? "
		"npc_citizen.answer26" = "That's more information than I require. "
		"npc_citizen.answer27" = "Wanna bet? "
		"npc_citizen.answer28" = "I wish I had a dime for every time somebody said that. "
		"npc_citizen.answer29" = "What am I supposed to do about it? "
		"npc_citizen.answer30" = "You talking to me? "
		"npc_citizen.answer31" = "You should nip that kind of talk in the bud. "
		"npc_citizen.answer32" = "Right on. "
		"npc_citizen.answer33" = "No argument there. "
		"npc_citizen.answer34" = "Don't forget Hawaii. "
		"npc_citizen.answer35" = "Try not to let it get to you. "
		"npc_citizen.answer36" = "Wouldn't be the first time. "
		"npc_citizen.answer37" = "You sure about that? "
		"npc_citizen.answer38" = "Leave it alone. "
		"npc_citizen.answer39" = "That's enough outta you. "
		"npc_citizen.answer40" = "There's a first time for everything. "
		"npc_citizen.antguard01" = "It's an antlion guard!"
		"npc_citizen.antguard02" = "It's an antlion guard!"
		"npc_citizen.antlion01" = "Antlion!"
		"npc_citizen.antlion02" = "Antlion!"
		"npc_citizen.antlions01" = "Antlions!"
		"npc_citizen.antlions02" = "Antlions!"
		"npc_citizen.antrhino01" = " "
		"npc_citizen.antrhino02" = " "
		"npc_citizen.areyoucrazy" = "Are you crazy?  I am not going out in that!"
		"npc_citizen.barnacles01" = "Barnacles!"
		"npc_citizen.barnacles02" = "Barnacles"
		"npc_citizen.behindyou01" = "Behind you!"
		"npc_citizen.behindyou02" = "Behind you!"
		"npc_citizen.bouncebombs01" = "Bouncebombs!"
		"npc_citizen.bouncebombs02" = "Bouncebombs!"
		"npc_citizen.busy01" = "Not right now. "
		"npc_citizen.busy02" = "Can't you see I'm busy? "
		"npc_citizen.busy03" = "This isn't a good time. "
		"npc_citizen.busy04" = "This isn't the time. "
		"npc_citizen.busy05" = "Later, please. "
		"npc_citizen.cantbeseen02" = "I can't be seen talking to you."
