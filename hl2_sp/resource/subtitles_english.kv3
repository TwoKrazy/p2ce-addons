		"ep_02.al_launch_struggle25" = "<sfx><norepeat:10><clr:255,212,255>[struggle sounds.]"
		"ep_02.al_launch_struggle26" = "<sfx><norepeat:10><clr:255,212,255>[struggle sounds.]"
		"ep_02.al_launch_struggle27" = "<sfx><norepeat:10><clr:255,212,255>[struggle sounds.]"
		"ep_02.al_launch_struggle28" = "<sfx><norepeat:10><clr:255,212,255>[struggle sounds.]"
		"ep_02.al_launch_theredog" = "<clr:255,212,255>Dog! There you are!"
		"ep_02.al_launch_theymean" = "<clr:255,212,255>I think they want you to push the button, Gordon."
		"ep_02.al_launch_thing01" = "<clr:255,212,255>It's all yours."
		"ep_02.al_launch_thing02" = "<clr:255,212,255>Launch that thing."
		"ep_02.al_launch_toohappy" = "<clr:255,212,255>I'll bet the Combine aren't too happy right now."
		"ep_02.al_launch_upsetnut01" = "<clr:255,212,255>What a nut.  "
		"ep_02.al_launch_upsetnut02" = "<clr:255,212,255>Don't go too far!"
		"ep_02.al_launch_wedidit01" = "<clr:255,212,255>We did it, Gordon!  "
		"ep_02.al_launch_wedidit02" = "<clr:255,212,255>We did it!"
		"ep_02.al_launch_wedidit03" = "<clr:255,212,255>We Shut the portal!"
		"ep_02.al_launch_wereback" = "<clr:255,212,255>We're back!"
		"ep_02.al_launch_whatdoing" = "<clr:255,212,255>Oh my god!"
		"ep_02.al_launch_wow" = "<clr:255,212,255>Whoa..."
		"ep_02.al_launch_wowgord" = "<clr:255,212,255>Wow, Gordon.  You were amazing out there."
		"ep_02.al_launch_wowgord_alt" = "<clr:255,212,255>Wow, Gordon.  You were amazing out there.  I don't know how you do it."
		"ep_02.al_rad_1stpowernowtrans01" = "<clr:255,212,255>Lets go find out what we just powered up. I sure hope it was a transmitter."
		"ep_02.al_rad_1stpowernowtrans02" = "<clr:255,212,255>Let's find the transmitter room before any more hunters find us."
		"ep_02.al_rad_1stpowernowtrans03" = "<clr:255,212,255>The transmitter room has to be around here somewhere."
		"ep_02.al_rad_allofem01" = "<clr:255,212,255>I think that's all of them. "
		"ep_02.al_rad_allofem02" = "<clr:255,212,255>I hope so, anyway. "
		"ep_02.al_rad_another" = "<clr:255,212,255>There's another one. "
		"ep_02.al_rad_atdoor" = "<clr:255,212,255>It's at the door."
		"ep_02.al_rad_awayfromdoor01" = "<clr:255,212,255>The door! "
		"ep_02.al_rad_awayfromdoor02" = "<clr:255,212,255>Get away from the door!"
		"ep_02.al_rad_backtocar" = "<clr:255,212,255>Let's get back to the car."
		"ep_02.al_rad_bullets" = "<clr:255,212,255>Bullets aren't doing anything."
		"ep_02.al_rad_carefulok" = "<clr:255,212,255>Careful, ok"
		"ep_02.al_rad_caught01" = "<clr:255,212,255>Well, come on."
		"ep_02.al_rad_caught02" = "<clr:255,212,255>I don't want my father to think we were caught in there when it went up."
		"ep_02.al_rad_combing" = "<clr:255,212,255>Oh crap, they must be combing the hills now."
		"ep_02.al_rad_comingthrough" = "<clr:255,212,255>He's coming through!"
		"ep_02.al_rad_coverdoor" = "<clr:255,212,255>The door!  Cover the door, Gordon!"
		"ep_02.al_rad_coverdoor01" = "<clr:255,212,255>The door! "
		"ep_02.al_rad_coverdoor02" = "<clr:255,212,255>Cover the door, Gordon. "
		"ep_02.al_rad_crap" = "<clr:255,212,255>Crap."
		"ep_02.al_rad_datauseless01" = "<clr:255,212,255>This data's gonna be useless if we don't beat the Combine to White Forest. "
		"ep_02.al_rad_datauseless02" = "<clr:255,212,255>That portal's gonna open all the way and then..."
		"ep_02.al_rad_datauseless03" = "<clr:255,212,255>We'd better get moving..."
		"ep_02.al_rad_detour01" = "<clr:255,212,255>Uh...isn't this the way back to the bridge?  "
		"ep_02.al_rad_detour02" = "<clr:255,212,255>We should go back through the compound and see where the road goes."
		"ep_02.al_rad_didyouhear" = "<clr:255,212,255>Did you hear something?"
		"ep_02.al_rad_didyousee" = "<clr:255,212,255>Did you see that?"
		"ep_02.al_rad_doorlock01" = "<clr:255,212,255>Well, that's it."
		"ep_02.al_rad_doorlock02" = "<clr:255,212,255>The power's out."
		"ep_02.al_rad_doyouread01" = "<clr:255,212,255>Hey"
		"ep_02.al_rad_doyouread02" = "<clr:255,212,255>Hello?"
		"ep_02.al_rad_doyouread03" = "<clr:255,212,255>Come in"
		"ep_02.al_rad_doyouread04" = "<clr:255,212,255>Hello??"
		"ep_02.al_rad_doyouread05" = "<clr:255,212,255>Are you there?"
		"ep_02.al_rad_doyouread06" = "<clr:255,212,255>White Forest, do you read?"
		"ep_02.al_rad_dreamed" = "<clr:255,212,255>I never thought I would see this day."
		"ep_02.al_rad_findradroom" = "<clr:255,212,255>Now to find the radio room..."
		"ep_02.al_rad_findway" = "<clr:255,212,255>Can you find a way up there?"
		"ep_02.al_rad_foundcontrols01" = "<clr:255,212,255>Found the gate controls!  "
		"ep_02.al_rad_foundcontrols02" = "<clr:255,212,255>Here goes!"
		"ep_02.al_rad_gateclosed01" = "<clr:255,212,255>We can't get out till I open that gate.  "
		"ep_02.al_rad_gateclosed02" = "<clr:255,212,255>Hold on..."
		"ep_02.al_rad_gateclosed03" = "<clr:255,212,255>The controls have got to be around here someplace."
		"ep_02.al_rad_gener" = "<clr:255,212,255>Generators... power.. What more do we need?"
		"ep_02.al_rad_getouthere" = "<clr:255,212,255>Let's get out here."
		"ep_02.al_rad_getpoweron01" = "<clr:255,212,255>We should get the power back on."
		"ep_02.al_rad_getpoweron02" = "<clr:255,212,255>We'd better try to get power to the transmitter, Gordon."
		"ep_02.al_rad_getready" = "<clr:255,212,255>No, not us.  The Combine!  You have to get ready!"
		"ep_02.al_rad_good" = "<clr:255,212,255>Good."
		"ep_02.al_rad_goodpoweron" = "<clr:255,212,255>Good...the power's on."
		"ep_02.al_rad_headingyourway" = "<clr:255,212,255>Yes, I know!  But the Combine, they're heading your way!"
		"ep_02.al_rad_hellodoc01" = "<clr:255,212,255>Hello - Dr. Magnusson?"
		"ep_02.al_rad_hellodoc02" = "<clr:255,212,255>Hello?"
		"ep_02.al_rad_hellodoc03" = "<clr:255,212,255>Are you there?"
		"ep_02.al_rad_hellout" = "<clr:255,212,255>Let's get the hell out of here."
		"ep_02.al_rad_help" = "<clr:255,212,255>Help, Gordon!"
		"ep_02.al_rad_herecomes" = "<clr:255,212,255>Here it comes."
		"ep_02.al_rad_hereitis01" = "<clr:255,212,255>Here it is."
		"ep_02.al_rad_hereitis02" = "<clr:255,212,255>Okay..."
		"ep_02.al_rad_hereitis03" = "<clr:255,212,255>this should do it..."
		"ep_02.al_rad_hereletme" = "<clr:255,212,255>Here, let me open the gate."
		"ep_02.al_rad_hideinhere" = "<clr:255,212,255>Gordon, hide. "
		"ep_02.al_rad_hideinhere01" = "<clr:255,212,255>Gordon..."
		"ep_02.al_rad_hideinhere02" = "<clr:255,212,255>Hide!"
		"ep_02.al_rad_hopehold" = "<clr:255,212,255>Let's hope that holds long enough to power up the transmitter."
		"ep_02.al_rad_inheresomewhere" = "<clr:255,212,255>There's gotta be a transmitter in here somewhere.  Let's find it."
		"ep_02.al_rad_killedit" = "<clr:255,212,255>We killed it!  We killed it! "
		"ep_02.al_rad_killedyeah" = "<clr:255,212,255>Yeah!"
		"ep_02.al_rad_location01" = "<clr:255,212,255>No, the Combine's moving toward your location."
		"ep_02.al_rad_location02" = "<clr:255,212,255>They'll be there soon!"
		"ep_02.al_rad_lookforradio01" = "<clr:255,212,255>There's got to be a transmitter around here, Gordon."
		"ep_02.al_rad_lookforradio02" = "<clr:255,212,255>Let's see if there's a transmitter around here."
		"ep_02.al_rad_lookforradio03" = "<clr:255,212,255>Let's look for a transmitter room."
		"ep_02.al_rad_lookout" = "<clr:255,212,255>I'll keep a lookout while you poke around inside."
		"ep_02.al_rad_lookup" = "<clr:255,212,255>Hey, look up there! It's a radio tower."
		"ep_02.al_rad_message" = "<clr:255,212,255>It's one of those things we saw in the message from Judith."
		"ep_02.al_rad_musthavetrans" = "<clr:255,212,255>They must have a transmitter in one of these buildings."
		"ep_02.al_rad_needdad" = "<clr:255,212,255>I need to talk to my father."
		"ep_02.al_rad_needwarn01" = "<clr:255,212,255>We need to send a warning to White Forest."
		"ep_02.al_rad_neverpower01" = "<clr:255,212,255>Doesn't look like the power is ever coming on again"
		"ep_02.al_rad_neverpower02" = "<clr:255,212,255>We should get back on the road."
		"ep_02.al_rad_nobody01" = "<clr:255,212,255>Nobody's home. "
		"ep_02.al_rad_nobody02" = "<clr:255,212,255>Wonder how long it's been deserted."
		"ep_02.al_rad_notthistime" = "<clr:255,212,255>Not this time. "
		"ep_02.al_rad_notthistime_loud" = "<clr:255,212,255>Not this time! "
		"ep_02.al_rad_nottough" = "<clr:255,212,255>They're not as tough as they look!"
		"ep_02.al_rad_notwastetime" = "<clr:255,212,255>Let's not waste any more time. We need to call White Forest. "
		"ep_02.al_rad_now" = "<clr:255,212,255>Now! "
		"ep_02.al_rad_offagain" = "<clr:255,212,255>Hey!  It's off again!  What'd you do?"
		"ep_02.al_rad_offguard" = "<clr:255,212,255>They're not gonna catch me off guard again. "
		"ep_02.al_rad_oldblue" = "<clr:255,212,255>Nice work with old blue eyes."
		"ep_02.al_rad_omgc17" = "<clr:255,212,255>Oh my god."
		"ep_02.al_rad_omgc17a" = "<clr:255,212,255>The portal's getting bigger.  "
		"ep_02.al_rad_omgc17b" = "<clr:255,212,255>I hope we still have time to shut it down."
		"ep_02.al_rad_onedown" = "<clr:255,212,255>One down!"
		"ep_02.al_rad_onemoredown" = "<clr:255,212,255>One more down!"
		"ep_02.al_rad_onlyonemore" = "<clr:255,212,255>Only one more!"
		"ep_02.al_rad_onroof" = "<clr:255,212,255>Listen--it's on the roof!"
		"ep_02.al_rad_onroof01" = "<clr:255,212,255>Listen. "
		"ep_02.al_rad_onroof02" = "<clr:255,212,255>It's on the roof. "
		"ep_02.al_rad_onuphere" = "<clr:255,212,255>Okay!  Power's on up here!"
		"ep_02.al_rad_pickuproad" = "<clr:255,212,255>Let's keep going, see if we can pick up the road somewhere ahead."
		"ep_02.al_rad_posthunters01" = "<clr:255,212,255>Let's try the transmitter before any more show up."
		"ep_02.al_rad_posthunters02" = "<clr:255,212,255>Let's find the transmitter before any more show up."
		"ep_02.al_rad_postkill01" = "<clr:255,212,255>All right, we got all of em!  Yeah!  "
		"ep_02.al_rad_postkill02" = "<clr:255,212,255>They'll think twice about messing with us again."
		"ep_02.al_rad_postkill03" = "<clr:255,212,255>Right, Gordon?"
		"ep_02.al_rad_postkill04" = "<clr:255,212,255>Never again."
		"ep_02.al_rad_postkill05" = "<clr:255,212,255>Yeah!"
		"ep_02.al_rad_postkill06" = "<clr:255,212,255>Well...even so..."
		"ep_02.al_rad_postkill07" = "<clr:255,212,255>We should get our warning out and then keep moving. "
		"ep_02.al_rad_powerboxagain01" = "<clr:255,212,255>Let's go check that power box again."
		"ep_02.al_rad_powerboxagain02" = "<clr:255,212,255>Maybe it's just flaky."
		"ep_02.al_rad_powerlines" = "<clr:255,212,255>Hey, those power lines are coming from this building."
		"ep_02.al_rad_powerout01" = "<clr:255,212,255>Well, here's the transmitter. "
		"ep_02.al_rad_powerout02" = "<clr:255,212,255>Mm. No power though. "
		"ep_02.al_rad_powerout03" = "<clr:255,212,255>Let's see if we can get some electricity going. "
		"ep_02.al_rad_ready" = "<clr:255,212,255>I'm ready! "
		"ep_02.al_rad_readyforyou" = "<clr:255,212,255>I'm ready for you. "
		"ep_02.al_rad_readythistime" = "<clr:255,212,255>I'm ready for them this time!"
		"ep_02.al_rad_roadblock" = "<clr:255,212,255>We're gonna have to find a way around this anyway."
		"ep_02.al_rad_roadpast01" = "<clr:255,212,255>Looks like the road will take us right past it."
		"ep_02.al_rad_roadpast02" = "<clr:255,212,255>Let's go in."
		"ep_02.al_rad_roadsout" = "<clr:255,212,255>Should have known it wouldn't be as easy as just driving down the road. Looks like we'll have to take a detour. "
		"ep_02.al_rad_seeifworking" = "<clr:255,212,255>Come on, Gordon.  Let's see if the transmitter's working."
		"ep_02.al_rad_seestower01" = "<clr:255,212,255>A radio tower. "
		"ep_02.al_rad_seestower02" = "<clr:255,212,255>If it's working, we need to send a warning to White Forest. "
		"ep_02.al_rad_seestower03" = "<clr:255,212,255>They've got no idea the Combine's heading their way. "
		"ep_02.al_rad_setback" = "<clr:255,212,255>We had a bit of a set-back."
		"ep_02.al_rad_sh" = "<clr:255,212,255>Shh. "
		"ep_02.al_rad_shit" = "<clr:255,212,255>Shit."
		"ep_02.al_rad_signweak01" = "<clr:255,212,255>The signal's really weak..."
		"ep_02.al_rad_signweak02" = "<clr:255,212,255>Well, let's give it a try."
		"ep_02.al_rad_stickby01" = "<clr:255,212,255>Find a way back to the power box, ok?"
		"ep_02.al_rad_stickby02" = "<clr:255,212,255>I'll stick by the radio in case we get them back on the line."
		"ep_02.al_rad_stickby03" = "<clr:255,212,255>We might not have much time to talk, even if you do restore the power."
		"ep_02.al_rad_stunned" = "<clr:255,212,255>I think you stunned it."
		"ep_02.al_rad_takedown" = "<clr:255,212,255>Take it down!"
		"ep_02.al_rad_takethat01" = "<clr:255,212,255>Take that!"
		"ep_02.al_rad_takethese" = "<clr:255,212,255>Gordon we can take these."
		"ep_02.al_rad_thatsit" = "<clr:255,212,255>That's it."
		"ep_02.al_rad_theyreback" = "<clr:255,212,255>Those things that attacked us at the mines... hunters, they're out there."
		"ep_02.al_rad_theyreback01" = "<clr:255,212,255>Those things that attacked us at the mines..."
		"ep_02.al_rad_theyreback02" = "<clr:255,212,255>Hunters..."
		"ep_02.al_rad_theyreback03" = "<clr:255,212,255>They're out there. "
		"ep_02.al_rad_thick01" = "<clr:255,212,255>That was probably a scouting party. "
		"ep_02.al_rad_thick02" = "<clr:255,212,255>Let's send our warning and get out of here."
		"ep_02.al_rad_thisis" = "<clr:255,212,255>This is..."
		"ep_02.al_rad_thisisav01" = "<clr:255,212,255>No, this is Alyx Vance."
		"ep_02.al_rad_thisisav02" = "<clr:255,212,255>Dr. Magnusson, is that you?"
		"ep_02.al_rad_threedown01" = "<clr:255,212,255>Get it!."
		"ep_02.al_rad_throw" = "<clr:255,212,255>Throw something at it!"
		"ep_02.al_rad_timetogo01" = "<clr:255,212,255>We should get moving.  They need us at White Forest."
		"ep_02.al_rad_timetogo02" = "<clr:255,212,255>Let's get driving, Gordon."
		"ep_02.al_rad_tough" = "<clr:255,212,255>Damn these things are tough."
		"ep_02.al_rad_trypowerbox" = "<clr:255,212,255>Try that power box, Gordon."
		"ep_02.al_rad_trysignal" = "<clr:255,212,255>Seems like a long shot but we have to try to get a signal."
		"ep_02.al_rad_twomore" = "<clr:255,212,255>Oh, crap.  More?"
		"ep_02.al_rad_use_findtrans01" = "<clr:255,212,255>We need to find the transmitter room, so we can contact White Forest and warn them the Combine are coming their way."
		"ep_02.al_rad_use_findtrans02" = "<clr:255,212,255>Nobody at White Forest has any idea the Combine are coming.  We have to warn them!"
		"ep_02.al_rad_use_powertotrans01" = "<clr:255,212,255>We need to restore power to the transmitter."
		"ep_02.al_rad_use_powertotrans02" = "<clr:255,212,255>We need to get the transmitter powered up."
		"ep_02.al_rad_usecar" = "<clr:255,212,255>We've got to take the car if we want to beat the Combine to White Forest."
		"ep_02.al_rad_useless" = "<clr:255,212,255>Bullets are useless!"
		"ep_02.al_rad_usetrans" = "<clr:255,212,255>Come on, let's see if we can use their transmitter."
		"ep_02.al_rad_warn" = "<clr:255,212,255>I just hope they got my warning."
		"ep_02.al_rad_wecandothis" = "<clr:255,212,255>We can do this! "
		"ep_02.al_rad_wfcomein01" = "<clr:255,212,255>White Forest, come in."
		"ep_02.al_rad_wfcomein02" = "<clr:255,212,255>White Forest, do you read?"
		"ep_02.al_rad_wfcomein03" = "<clr:255,212,255>White Forest, do you read?"
		"ep_02.al_rad_whatwasthat" = "<clr:255,212,255>What the hell was that?"
		"ep_02.al_rad_wonder_alt01" = "<clr:255,212,255>I wonder if he got any of that.  "
		"ep_02.al_rad_wonder_alt02" = "<clr:255,212,255>We'd better get back on the road."
		"ep_02.al_rad_wonder01" = "<clr:255,212,255>I wonder if he got any of that.  "
		"ep_02.al_rad_wonder02" = "<clr:255,212,255>Let's get back on the road."
		"ep_02.al_radar_blip01" = "<clr:255,212,255>Blip."
		"ep_02.al_radar_blip02" = "<clr:255,212,255>Blip."
		"ep_02.al_radar_blip03" = "<clr:255,212,255>[laughter]"
		"ep_02.al_radar_blip04" = "<clr:255,212,255>Blip-blip"
		"ep_02.al_radar_building01" = "<clr:255,212,255>According to the radar, there's a beacon inside this building."
		"ep_02.al_radar_building02" = "<clr:255,212,255>The cache must be inside this building."
		"ep_02.al_radar_building03" = "<clr:255,212,255>I'll keep watch out here if you want to look inside for the cache."
		"ep_02.al_radar_colder01" = "<clr:255,212,255>Getting colder."
		"ep_02.al_radar_colder02" = "<clr:255,212,255>It's moving offscreen."
		"ep_02.al_radar_colder03" = "<clr:255,212,255>Gone."
		"ep_02.al_radar_colder04" = "<clr:255,212,255>Lost it."
		"ep_02.al_radar_followup01" = "<clr:255,212,255>You want to check it out?"
		"ep_02.al_radar_followup02" = "<clr:255,212,255>Think it's worth looking at?"
		"ep_02.al_radar_followup03" = "<clr:255,212,255>We should check it out."
		"ep_02.al_radar_followup04" = "<clr:255,212,255>Want to give it a look?"
		"ep_02.al_radar_getgoing01" = "<clr:255,212,255>Gordon, we should get going."
		"ep_02.al_radar_getgoing02" = "<clr:255,212,255>Maybe we should just head out.  "
		"ep_02.al_radar_getgoing03" = "<clr:255,212,255>You okay in there?"
		"ep_02.al_radar_hiddencache01" = "<clr:255,212,255>Hmm... we're getting a signal but I don't see anything."
		"ep_02.al_radar_hiddencache02" = "<clr:255,212,255>What do you think, Gordon?"
		"ep_02.al_radar_launcherhandy" = "<clr:255,212,255>Oh, rocket launcher!  That'll come in handy!"
		"ep_02.al_radar_multi" = "<clr:255,212,255>Wow, the radar is going crazy!"
		"ep_02.al_radar_newdetect01" = "<clr:255,212,255>Hey-something on the radar."
		"ep_02.al_radar_newdetect02" = "<clr:255,212,255>We're picking up something on the radar."
		"ep_02.al_radar_newdetect03" = "<clr:255,212,255>Radar's going off, Gordon."
		"ep_02.al_radar_newdetect04" = "<clr:255,212,255>There goes the radar."
		"ep_02.al_radar_newdetect05" = "<clr:255,212,255>What's that?  Something on the radar."
		"ep_02.al_radar_newpanel01" = "<clr:255,212,255>There goes the new radar panel."
		"ep_02.al_radar_newpanel02" = "<clr:255,212,255>They told me it's keyed to rebel caches...stuff we might need."
		"ep_02.al_radar_newpanel03" = "<clr:255,212,255>Maybe we should see what it's picking up."
		"ep_02.al_radar_nicejob" = "<clr:255,212,255>Nice job.  That'll come in handy."
		"ep_02.al_radar_plususe01" = "<clr:255,212,255>Maybe we should just head out. We need to get to White Forest."
		"ep_02.al_radar_plususe02" = "<clr:255,212,255>I don't know.  This is supposed to be your area of expertise."
		"ep_02.al_radar_regain01" = "<clr:255,212,255>There it is again."
		"ep_02.al_radar_regain02" = "<clr:255,212,255>Picking it up again."
		"ep_02.al_radar_regain03" = "<clr:255,212,255>Got a signal again."
		"ep_02.al_radar_warmer01" = "<clr:255,212,255>We're getting close."
		"ep_02.al_radar_warmer02" = "<clr:255,212,255>Getting warmer."
		"ep_02.al_radar_warmer03" = "<clr:255,212,255>We're right on top of it."
		"ep_02.al_radar_warmer04" = "<clr:255,212,255>It's around here someplace."
		"ep_02.al_radar_withoutbeacon" = "<clr:255,212,255>We'd never have known this was here without the beacon."
		"ep_02.al_radar_worthtrouble" = "<clr:255,212,255>Oh well...I bet that stuff wasn't worth the trouble.  Let's go."
		"ep_02.al_radar_youfoundcache" = "<clr:255,212,255>Ah, you found it.  "
		"ep_02.al_radar_zombiestuff" = "<clr:255,212,255>I think the zombies want their stuff back!"
		"ep_02.al_rbed_aportalstorm" = "<clr:255,212,255>Portal storm! "
		"ep_02.al_rbed_areyouok" = "<clr:255,212,255>Are you okay? "
		"ep_02.al_rbed_backuptracks" = "<clr:255,212,255>We're going to want to get back up to the tracks and keep our original heading, but in the meantime, maybe we can find those vortigaunts."
		"ep_02.al_rbed_bridge" = "<clr:255,212,255>Look out!  The bridge!"
		"ep_02.al_rbed_callinggordon01" = "<clr:255,212,255>Gordon! "
		"ep_02.al_rbed_callinggordon02" = "<clr:255,212,255>Gordon! "
		"ep_02.al_rbed_callinggordon03" = "<clr:255,212,255>Gordon! "
		"ep_02.al_rbed_callinggordon04" = "<clr:255,212,255>Gordon! "
		"ep_02.al_rbed_checkin" = "<clr:255,212,255>Now, to check in. "
		"ep_02.al_rbed_commctr01" = "<clr:255,212,255>Okay - a communication center. "
		"ep_02.al_rbed_commctr02" = "<clr:255,212,255>Let's see if we can get out a message to my Dad. "
		"ep_02.al_rbed_cover" = "<clr:255,212,255>It's good idea to take advantage of cover for now, in case they're doing fly-overs.  "
		"ep_02.al_rbed_didntseeyou01" = "<clr:255,212,255>When I couldn't find you I got... "
		"ep_02.al_rbed_didntseeyou02" = "<clr:255,212,255>I know, I know - I shouldn't have worried. "
		"ep_02.al_rbed_didtrick" = "<clr:255,212,255>That did the trick."
		"ep_02.al_rbed_didtrick02" = "<clr:255,212,255>Thanks."
		"ep_02.al_rbed_didyouhear" = "<clr:255,212,255>Did you hear that?"
		"ep_02.al_rbed_expectmore01" = "<clr:255,212,255>I guess we can expect more of those..."
		"ep_02.al_rbed_expectmore02" = "<clr:255,212,255>It's like the First Days all over again."
		"ep_02.al_rbed_findcover" = "<clr:255,212,255>We need to find some cover.  "
		"ep_02.al_rbed_firstdays01" = "<clr:255,212,255>Portal storms!  "
		"ep_02.al_rbed_firstdays02" = "<clr:255,212,255>It's like the First Days all over again."
		"ep_02.al_rbed_gatenags01" = "<clr:255,212,255>Go on, Gordon.  Open the gate."
		"ep_02.al_rbed_gatenags02" = "<clr:255,212,255>As long as they're doing aerial sweeps, we should make our way into the mines."
		"ep_02.al_rbed_gatenags03" = "<clr:255,212,255>Maybe you can find a way to get this gate open.  "
		"ep_02.al_rbed_gatenags04" = "<clr:255,212,255>Looks like we can get into the mines through here.  If we could just get this gate open."
		"ep_02.al_rbed_gatenags05" = "<clr:255,212,255>Do you see a gate control in there, Gordon?"
		"ep_02.al_rbed_gatenags06" = "<clr:255,212,255>Open the gate up, Gordon!"
		"ep_02.al_rbed_giveupnow01" = "<clr:255,212,255>Well, we should keep moving. "
		"ep_02.al_rbed_giveupnow02" = "<clr:255,212,255>I'm sure the Combine haven't forgotten about us. "
		"ep_02.al_rbed_gladtosee" = "<clr:255,212,255>I can't tell you how glad I was to see you in there."
		"ep_02.al_rbed_gordon" = "<clr:255,212,255>Gordon?"
		"ep_02.al_rbed_gravgunkick" = "<clr:255,212,255>Wow - I forgot what a kick this thing has. "
		"ep_02.al_rbed_gravgunstillworks" = "<clr:255,212,255>Let's hope this still works "
		"ep_02.al_rbed_haven" = "<clr:255,212,255>Well, safe haven it ain't. "
		"ep_02.al_rbed_heardvorts01" = "<clr:255,212,255>I heard vortigaunts a few minutes ago. Maybe they're still around. "
		"ep_02.al_rbed_heardvorts02" = "<clr:255,212,255>We've got a long way to go to find my Dad. It would be nice to have some extra help. "
		"ep_02.al_rbed_help" = "<clr:255,212,255>Help!"
		"ep_02.al_rbed_heregoes" = "<clr:255,212,255>Here goes. "
		"ep_02.al_rbed_holdonsec" = "<clr:255,212,255>Hold on a sec - I'll let you out of there. "
		"ep_02.al_rbed_holdonsec_alt" = "<clr:255,212,255>Hold on a sec - I'll get you out of there. "
		"ep_02.al_rbed_hopewedont01" = "<clr:255,212,255>It's like the First Days all over again. "
		"ep_02.al_rbed_hopewedont02" = "<clr:255,212,255>I hope we don't get many more. "
		"ep_02.al_rbed_hunter_breathing01" = "<clr:255,212,255>[pained breathing]"
		"ep_02.al_rbed_hunter_breathing02" = "<clr:255,212,255>[pained breathing]"
		"ep_02.al_rbed_hunter_breathing03" = "<clr:255,212,255>[pained breathing]"
		"ep_02.al_rbed_hunter_breathing04" = "<clr:255,212,255>[pained breathing]"
		"ep_02.al_rbed_hunter_breathing05" = "<clr:255,212,255>[pained breathing]"
		"ep_02.al_rbed_hunter_breathing06" = "<clr:255,212,255>[pained breathing]"
		"ep_02.al_rbed_hunter_breathing07" = "<clr:255,212,255>[pained breathing]"
		"ep_02.al_rbed_hunter_breathing08" = "<clr:255,212,255>[pained breathing]"
		"ep_02.al_rbed_hunter_breathing09" = "<clr:255,212,255>[pained breathing]"
		"ep_02.al_rbed_hunter_breathing10" = "<clr:255,212,255>[pained breathing]"
		"ep_02.al_rbed_hunter_breathing11" = "<clr:255,212,255>[pained breathing]"
		"ep_02.al_rbed_hunter_breathing12" = "<clr:255,212,255>[pained breathing]"
		"ep_02.al_rbed_hunter_breathing13" = "<clr:255,212,255>[pained breathing]"
		"ep_02.al_rbed_hunter_collapse01" = "<clr:255,212,255>[pain sounds]"
		"ep_02.al_rbed_hunter_collapse02" = "<clr:255,212,255>[pain sounds]"
		"ep_02.al_rbed_hunter_collapse03" = "<clr:255,212,255>[pain sounds]"
		"ep_02.al_rbed_hunter_collapse04" = "<clr:255,212,255>[pain sounds]"
		"ep_02.al_rbed_hunter_collapse05" = "<clr:255,212,255>[pain sounds]"
		"ep_02.al_rbed_hunter_collapse06" = "<clr:255,212,255>[pain sounds]Help me.."
		"ep_02.al_rbed_hunter_collapse07" = "<clr:255,212,255>[pain sounds]Help..."
		"ep_02.al_rbed_hunter_collapse08" = "<clr:255,212,255>[pain sounds]Help me..."
		"ep_02.al_rbed_hunter_collapse09" = "<clr:255,212,255>[pain sounds]Gordon..."
		"ep_02.al_rbed_hunter_collapse10" = "<clr:255,212,255>[pain sounds]Help..."
		"ep_02.al_rbed_hunter_gordon" = "<clr:255,212,255>[pain sounds]Gordon!"
		"ep_02.al_rbed_hunter_pain01" = "<clr:255,212,255>[pain sounds]"
		"ep_02.al_rbed_hunter_pain02" = "<clr:255,212,255>[pain sounds]"
		"ep_02.al_rbed_hunter_pain03" = "<clr:255,212,255>[pain sounds]"
		"ep_02.al_rbed_hunter_pain04" = "<clr:255,212,255>[pain sounds]"
		"ep_02.al_rbed_hunter_pain05" = "<clr:255,212,255>[pain sounds]"
		"ep_02.al_rbed_hunter_pain06" = "<clr:255,212,255>[pain sounds]"
		"ep_02.al_rbed_hunter_pain07" = "<clr:255,212,255>[pain sounds]"
		"ep_02.al_rbed_hunter_pain08" = "<clr:255,212,255>[pain sounds]"
		"ep_02.al_rbed_hurrynags01" = "<clr:255,212,255>Gordon, we're not alone!"
		"ep_02.al_rbed_hurrynags02" = "<clr:255,212,255>Hurry!"
		"ep_02.al_rbed_hurrynags03" = "<clr:255,212,255>Come on, we'd better hurry!"
		"ep_02.al_rbed_insight" = "<clr:255,212,255>Hey, if you have any blinding insights into how to fix this, go for it. "
		"ep_02.al_rbed_lookbridge" = "<clr:255,212,255>Look - the bridge! "
		"ep_02.al_rbed_lookdoingbridge" = "<clr:255,212,255>Look what it's doing to the bridge!"
		"ep_02.al_rbed_lookrocks" = "<clr:255,212,255>Look.  Rocks must have shifted when that shockwave hit.  "
		"ep_02.al_rbed_mess" = "<clr:255,212,255>What a mess. This could take a while. "
		"ep_02.al_rbed_mindplug" = "<clr:255,212,255>Would you mind plugging it in?"
		"ep_02.al_rbed_mineshaft01" = "<clr:255,212,255>A mineshaft!  "
		"ep_02.al_rbed_mineshaft02" = "<clr:255,212,255>Let's head in there."
		"ep_02.al_rbed_notalone" = "<clr:255,212,255>Shh. Quiet!  We're not alone"
		"ep_02.al_rbed_notsurehow" = "<clr:255,212,255>Not sure what I just did ...but it worked.  "
		"ep_02.al_rbed_omg" = "<clr:255,212,255>Oh my God!"
		"ep_02.al_rbed_omgcitadel01" = "<clr:255,212,255>Oh my God - the Citadel! "
		"ep_02.al_rbed_omgcitadel02" = "<clr:255,212,255>What the hell is happening? "
		"ep_02.al_rbed_plugitin" = "<clr:255,212,255>See the cord, Gordon?  You want to plug it in?"
		"ep_02.al_rbed_plususe01" = "<clr:255,212,255>I'm glad to see you too."
		"ep_02.al_rbed_plususe02" = "<clr:255,212,255>Okay, Gordon...let's keep moving."
		"ep_02.al_rbed_plususe03" = "<clr:255,212,255>Mm-hm, we should head out."
		"ep_02.al_rbed_plususe04" = "<clr:255,212,255>Amazing we survived, isn't it?"
		"ep_02.al_rbed_powercord" = "<clr:255,212,255>Hey...a power cord.  How'd that get down there?"
		"ep_02.al_rbed_rebel" = "<clr:255,212,255>I wouldn't be surprised if the rebels used this place. "
		"ep_02.al_rbed_refugees_alt" = "<clr:255,212,255>Refugees!  I wish someone would have warned them about headcrabs."
		"ep_02.al_rbed_refugees01" = "<clr:255,212,255>Refugees..."
		"ep_02.al_rbed_refugees02" = "<clr:255,212,255>They could have used a crash-course in outland survival."
		"ep_02.al_rbed_refugees03" = "<clr:255,212,255>I just wish someone would have warned them about headcrabs."
		"ep_02.al_rbed_rocksshifted" = "<clr:255,212,255>I hadn't noticed this before; rocks must have shifted when that shockwave hit. "
		"ep_02.al_rbed_rocksshifted01" = "<clr:255,212,255>I hadn't noticed this before."
		"ep_02.al_rbed_rocksshifted02" = "<clr:255,212,255>Rocks must have shifted when that shockwave hit. "
		"ep_02.al_rbed_seeanyway" = "<clr:255,212,255>If you can see any way to help, I'd appreciate it, Gordon."
		"ep_02.al_rbed_seesgravgun01" = "<clr:255,212,255>Ah!"
		"ep_02.al_rbed_seesgravgun02" = "<clr:255,212,255>The gravity gun."
		"ep_02.al_rbed_shifted01" = "<clr:255,212,255>Something shifted up there..."
		"ep_02.al_rbed_shifted02" = "<clr:255,212,255>I see an opening."
		"ep_02.al_rbed_snooping" = "<clr:255,212,255>Gordon - there's something snooping around out here. "
		"ep_02.al_rbed_standback" = "<clr:255,212,255>Stand back. "
		"ep_02.al_rbed_takegravgun01" = "<clr:255,212,255>Here - you take the gravity gun. "
		"ep_02.al_rbed_takegravgun02" = "<clr:255,212,255>You're better with it than I am. "
		"ep_02.al_rbed_toovuln" = "<clr:255,212,255>Come on.  We're too exposed out here."
		"ep_02.al_rbed_wannaplugitin" = "<clr:255,212,255>Hey, Gordon?  Want to plug it in?"
		"ep_02.al_rbed_whatnow01" = "<clr:255,212,255>Damn. "
		"ep_02.al_rbed_whatnow02" = "<clr:255,212,255>What now. "
		"ep_02.al_rbed_whatsthat" = "<clr:255,212,255>What's that? "
		"ep_02.al_rbed_whatthat" = "<clr:255,212,255>What was that? "
		"ep_02.al_rbed_whoa" = "<clr:255,212,255>Whoa!"
		"ep_02.al_rbed_workingagain" = "<clr:255,212,255>Let me see if I can get it working again. "
		"ep_02.al_rbed_yourokay" = "<clr:255,212,255>Oh Gordon, thank God you're all right. "
		"ep_02.al_rbed_zombies01" = "<clr:255,212,255>Zombies! Get ready!"
		"ep_02.al_rbed_zombies02" = "<clr:255,212,255>Zombies! I got 'em!"
		"ep_02.al_rbed_zombies03" = "<clr:255,212,255>Or you do..."
		"ep_02.al_rbed_zombies04" = "<clr:255,212,255>Or you can get 'em..."
		"ep_02.al_rdblk_field01" = "<clr:255,212,255>We're not going to get the car any further without disabling that force field."
		"ep_02.al_rdblk_field02" = "<clr:255,212,255>How about I stay here and try to keep down the zombie population while you see if you can shut that thing down."
		"ep_02.al_rdblk_needboth01" = "<clr:255,212,255>We don't need to both defend the car, Gordon."
		"ep_02.al_rdblk_needboth02" = "<clr:255,212,255>See if you can shut off the force field."
		"ep_02.al_rdblk_podhid01" = "<clr:255,212,255>so they had an advisor pod hidden in here"
		"ep_02.al_rdblk_podhid02" = "<clr:255,212,255>and this one hatched"
		"ep_02.al_rdblk_podhid03" = "<clr:255,212,255>better step on the gas."
		"ep_02.al_silo_anotheralarm" = "<clr:255,212,255>Another alarm?"
		"ep_02.al_silo_anysooner01" = "<clr:255,212,255>I'm sorry we couldn't get here any sooner, Dad.  "
		"ep_02.al_silo_anysooner02" = "<clr:255,212,255>We went as fast as we could."
		"ep_02.al_silo_areyouok" = "<clr:255,212,255>Dad?  Are you okay?"
		"ep_02.al_silo_array01" = "<clr:255,212,255>I take it the old portal satellite array was functional after all."
		"ep_02.al_silo_basesecure01" = "<clr:255,212,255>Yes, he's fine."
		"ep_02.al_silo_basesecure02" = "<clr:255,212,255>And thanks to him, the base is secure "
		"ep_02.al_silo_besttime01" = "<clr:255,212,255>dad...hmm"
		"ep_02.al_silo_besttime02" = "<clr:255,212,255>I know this isn't the best time to ask about this"
		"ep_02.al_silo_besttime03" = "<clr:255,212,255>but with everything she put us through"
		"ep_02.al_silo_besttime04" = "<clr:255,212,255>the betrayal and nova prospekt"
		"ep_02.al_silo_bigger" = "<clr:255,212,255>how is the project going?"
		"ep_02.al_silo_borealisreal01" = "<clr:255,212,255>What?"
		"ep_02.al_silo_borealisreal02" = "<clr:255,212,255>The Borealis? It's real?"
		"ep_02.al_silo_breath01" = "<norepeat:10><clr:255,212,255>[breath]"
		"ep_02.al_silo_breath02" = "<norepeat:10><clr:255,212,255>[breath]"
		"ep_02.al_silo_bunker" = "<clr:255,212,255>That looks like a bunker entrance up ahead."
		"ep_02.al_silo_bunkerentrance" = "<clr:255,212,255>There's the entrance!  "
		"ep_02.al_silo_cantcome01" = "<clr:255,212,255>I'm sorry I can't come with you, Gordon.  "
		"ep_02.al_silo_cantcome02" = "<clr:255,212,255>I should really help Dr. Kleiner."
		"ep_02.al_silo_captured01" = "<clr:255,212,255>Gordon and I captured a raw data stream that was going out when the Citadel blew."
		"ep_02.al_silo_captured02" = "<clr:255,212,255>They put everything they had into sending it"
		"ep_02.al_silo_captured03" = "<clr:255,212,255>and they've been on our heels ever since."
		"ep_02.al_silo_catchup" = "<clr:255,212,255>Catch up with us when you're done."
		"ep_02.al_silo_comefindyou" = "<clr:255,212,255>I'll come find you in a little while."
		"ep_02.al_silo_comeonin" = "<clr:255,212,255>Come on, Gordon."
		"ep_02.al_silo_coming_far" = "<clr:255,212,255>Hey gordon, you coming?"
		"ep_02.al_silo_coming_near" = "<clr:255,212,255>Gordon, you coming?"
		"ep_02.al_silo_copied01" = "<clr:255,212,255>yeah, I copied the whole packet."
		"ep_02.al_silo_copied02" = "<clr:255,212,255>Along with the transmission from Judith."
		"ep_02.al_silo_dad" = "<clr:255,212,255>Dad!"
		"ep_02.al_silo_dadshock01" = "<clr:255,212,255>Dad!"
		"ep_02.al_silo_dadshock02" = "<clr:255,212,255>Dad!"
		"ep_02.al_silo_dadtransmission" = "<clr:255,212,255>Dad."
		"ep_02.al_silo_dadtransmissionno" = "<clr:255,212,255>Dad, no!"
		"ep_02.al_silo_dogslowpoke" = "<clr:255,212,255>Better luck next time, slowpoke!"
		"ep_02.al_silo_dogwins" = "<clr:255,212,255>Well, you won this time, Dog. "
		"ep_02.al_silo_dontgiveup01" = "<clr:255,212,255>Don't give up now, Gordon.  "
		"ep_02.al_silo_dontgiveup02" = "<clr:255,212,255>Let's go in."
		"ep_02.al_silo_doyouneed01" = "<clr:255,212,255>Ok."
		"ep_02.al_silo_doyouneed02" = "<clr:255,212,255>Do you need anything?"
		"ep_02.al_silo_everythingok" = "<clr:255,212,255>Is everything all right?"
		"ep_02.al_silo_finehere01" = "<clr:255,212,255>We'll be fine here, Gordon."
		"ep_02.al_silo_finehere02" = "<clr:255,212,255>Dr. Kleiner needs you"
		"ep_02.al_silo_fixyouup" = "<clr:255,212,255>Looks like they're set to fix you up here."
		"ep_02.al_silo_gladtobeback" = "<clr:255,212,255>I'm glad to be back."
		"ep_02.al_silo_gladtobehere01" = "<clr:255,212,255>Heya!"
		"ep_02.al_silo_gladtobehere02" = "<clr:255,212,255>Boy, are we glad to be here."
		"ep_02.al_silo_goingtobe" = "<clr:255,212,255>Everything's going to be all right."
		"ep_02.al_silo_goodteam01" = "<clr:255,212,255>Yeah."
		"ep_02.al_silo_goodteam02" = "<clr:255,212,255>We make a pretty good team."
		"ep_02.al_silo_gordonthankgoodness01" = "<clr:255,212,255>Gordon..."
		"ep_02.al_silo_gordonthankgoodness02" = "<clr:255,212,255>Thank goodness you're okay."
		"ep_02.al_silo_gordonthankgoodness03" = "<clr:255,212,255>We got in here as soon as we could. "
		"ep_02.al_silo_gordonthankgoodness04" = "<clr:255,212,255>We couldn't get in till you sealed off the silo and the blast doors opened up "
		"ep_02.al_silo_gothruhere01" = "<clr:255,212,255>Through here, Gordon."
		"ep_02.al_silo_gothruhere02" = "<clr:255,212,255>This way."
		"ep_02.al_silo_gothruhere03" = "<clr:255,212,255>After you, Gordon."
		"ep_02.al_silo_gotthru" = "<clr:255,212,255>Looks like our message got through after all."
		"ep_02.al_silo_greetrebs01" = "<clr:255,212,255>Thanks. It's good to be here."
		"ep_02.al_silo_greetrebs02" = "<clr:255,212,255>Boy am I glad to be here."
		"ep_02.al_silo_greetrebs03" = "<clr:255,212,255>Safe at last!"
		"ep_02.al_silo_greetrebs04" = "<clr:255,212,255>Let us in!"
		"ep_02.al_silo_hellomag" = "<clr:255,212,255>Hello, Dr. Magnusson."
		"ep_02.al_silo_hereyougo01" = "<clr:255,212,255>Here you go.  "
		"ep_02.al_silo_hereyougo02" = "<clr:255,212,255>The kettle was hot"
		"ep_02.al_silo_hereyougo03" = "<clr:255,212,255>You feeling better now?"
		"ep_02.al_silo_hopegothere01" = "<clr:255,212,255>And what about the Combine?  "
		"ep_02.al_silo_hopegothere02" = "<clr:255,212,255>Will we be able to launch before they attack?"
		"ep_02.al_silo_howlongactive01" = "<clr:255,212,255>Do we have any idea how long until the superportal's active?"
		"ep_02.al_silo_illcatchup" = "<clr:255,212,255>I'll catch up with you in a bit."
		"ep_02.al_silo_imfine01" = "<clr:255,212,255>Dad, it's not what it looks like.  I'm fine."
		"ep_02.al_silo_imfine02" = "<clr:255,212,255>Really, I'm fine."
		"ep_02.al_silo_imherenow01" = "<clr:255,212,255>Shh.. Dad."
		"ep_02.al_silo_imherenow02" = "<clr:255,212,255>I'm here now."
		"ep_02.al_silo_imherenow03" = "<clr:255,212,255>Nothing's gonna happen to me."
		"ep_02.al_silo_inhere" = "<clr:255,212,255>In here."
		"ep_02.al_silo_inseparable" = "<clr:255,212,255>Oh, they're inseparable."
		"ep_02.al_silo_install01" = "<clr:255,212,255>She said something about an installation."
		"ep_02.al_silo_install02" = "<clr:255,212,255>When's the last time you heard from her?"
		"ep_02.al_silo_intercomdad" = "<clr:255,212,255>Dad?"
		"ep_02.al_silo_judithnorth" = "<clr:255,212,255>Doctor Kleiner told me that Judith headed north in a helicopter right after they got here but he wouldn't tell me why."
		"ep_02.al_silo_justhaveto01" = "<clr:255,212,255>We'll just have to..."
		"ep_02.al_silo_justhaveto02" = "<clr:255,212,255>just have to..."
		"ep_02.al_silo_justwhat" = "<clr:255,212,255>I may have just what you're looking for."
		"ep_02.al_silo_keepeye01" = "<clr:255,212,255>I'll be right back."
		"ep_02.al_silo_keepeye02" = "<clr:255,212,255>Gordon, keep an eye on him?"
		"ep_02.al_silo_leanintome01" = "<clr:255,212,255>Okay..."
		"ep_02.al_silo_leanintome02" = "<clr:255,212,255>It's okay."
		"ep_02.al_silo_leanintome03" = "<clr:255,212,255>Just lean into me."
		"ep_02.al_silo_leanintome04" = "<clr:255,212,255>That's it."
		"ep_02.al_silo_leanintome05" = "<clr:255,212,255>Let's get you off your feet."
		"ep_02.al_silo_leanintome06" = "<clr:255,212,255>Lie down."
		"ep_02.al_silo_leanintome07" = "<clr:255,212,255>Here you go."
		"ep_02.al_silo_letdadknow" = "<clr:255,212,255>I better let my Dad know you're all right."
		"ep_02.al_silo_letsgetin" = "<clr:255,212,255>Let's get in."
		"ep_02.al_silo_letsgetinside" = "<clr:255,212,255>Let's get in."
		"ep_02.al_silo_listentokleiner01" = "<clr:255,212,255>Listen to Dr. Kleiner, Dad.  "
		"ep_02.al_silo_listentokleiner02" = "<clr:255,212,255>Gordon and I are more than able to handle this.  "
		"ep_02.al_silo_listentokleiner03" = "<clr:255,212,255>We'll get her back."
		"ep_02.al_silo_looklater03" = "<clr:255,212,255>It's just good to finally be here."
		"ep_02.al_silo_meetincontrolroom" = "<clr:255,212,255>We'll meet you up in the control room when you're done."
		"ep_02.al_silo_message" = "<clr:255,212,255>Do you mean the message didn't get through?"
		"ep_02.al_silo_neverget" = "<clr:255,212,255>I thought we'd never get here."
		"ep_02.al_silo_neversoglad01" = "<clr:255,212,255>I was never so glad to see him, believe me.  "
		"ep_02.al_silo_neversoglad02" = "<clr:255,212,255>Isn't that right, boy?"
		"ep_02.al_silo_nohiding01" = "<clr:255,212,255>So..."
		"ep_02.al_silo_nohiding02" = "<clr:255,212,255>no more hiding?"
		"ep_02.al_silo_noidea01" = "<clr:255,212,255>I'm sorry."
		"ep_02.al_silo_noidea02" = "<clr:255,212,255>I had no idea."
		"ep_02.al_silo_notatall01" = "<clr:255,212,255>Not at all."
		"ep_02.al_silo_notatall02" = "<clr:255,212,255>You heard him, Dog."
		"ep_02.al_silo_notatall03" = "<clr:255,212,255>I'm going to go see Dad."
		"ep_02.al_silo_notatall04" = "<clr:255,212,255>I'll catch up to you later."
		"ep_02.al_silo_notatall05" = "<clr:255,212,255>Take care of yourself."
		"ep_02.al_silo_ohyou" = "<clr:255,212,255>[wordless exasperation]"
		"ep_02.al_silo_omgdad" = "<clr:255,212,255>Dad..."
		"ep_02.al_silo_ourfight" = "<clr:255,212,255>It's all of our fight, Dad."
		"ep_02.al_silo_prepare" = "<clr:255,212,255>Prepare for unforeseen consequences."
		"ep_02.al_silo_prepare01" = "<clr:255,212,255>Dad... "
		"ep_02.al_silo_prepare02" = "<clr:255,212,255>Prepare for unforeseen consequences..."
		"ep_02.al_silo_rightheredoc01" = "<clr:255,212,255>It's right here, Dr. Kleiner. "
		"ep_02.al_silo_rightheredoc02" = "<clr:255,212,255>We've got a ton of data."
		"ep_02.al_silo_rightheredoc03" = "<clr:255,212,255>The strange thing is, it was all attached to a transmission from Judith."
		"ep_02.al_silo_safeatlastg01" = "<clr:255,212,255>Well, Gordon.  "
		"ep_02.al_silo_safeatlastg02" = "<clr:255,212,255>White Forest."
		"ep_02.al_silo_safeatlastg03" = "<clr:255,212,255>We made it.  Safe at last."
		"ep_02.al_silo_sameold" = "<clr:255,212,255>Same old Doctor Magnusson I see."
		"ep_02.al_silo_sameold01" = "<clr:255,212,255>Same old Doctor Magnusson."
		"ep_02.al_silo_seedad01" = "<clr:255,212,255>Come on, "
		"ep_02.al_silo_seedad02" = "<clr:255,212,255>I can't wait to see Dad!"
		"ep_02.al_silo_seemag" = "<clr:255,212,255>We'd better hurry up.  Magnusson will lose it if he thinks we were fooling around."
		"ep_02.al_silo_sheok01" = "<clr:255,212,255>Is she ok?"
		"ep_02.al_silo_sheok02" = "<clr:255,212,255>It sounded like she was..."
		"ep_02.al_silo_soafraid" = "<clr:255,212,255>I was so afraid I wouldn't see you again."
		"ep_02.al_silo_somethings" = "<clr:255,212,255>Some things never change."
		"ep_02.al_silo_starting" = "<clr:255,212,255>Oh no, what's that?"
		"ep_02.al_silo_surething01" = "<clr:255,212,255>Sure thing."
		"ep_02.al_silo_surething02" = "<clr:255,212,255>Better now! "
		"ep_02.al_silo_takegoodcare" = "<clr:255,212,255>Take good care of him, ok?"
		"ep_02.al_silo_thankreb" = "<clr:255,212,255>Thanks."
		"ep_02.al_silo_thanksdog" = "<clr:255,212,255>Dog, good, you made it."
		"ep_02.al_silo_thereitis01" = "<clr:255,212,255>[Inhalation]  "
		"ep_02.al_silo_thereitis02" = "<clr:255,212,255>Wow."
		"ep_02.al_silo_thereitis03" = "<clr:255,212,255>There it is."
		"ep_02.al_silo_tired01" = "<clr:255,212,255>Whoa!"
		"ep_02.al_silo_tired02" = "<clr:255,212,255>Sorry, heh."
		"ep_02.al_silo_tired03" = "<clr:255,212,255>I must be tired"
		"ep_02.al_silo_wait" = "<clr:255,212,255>Wait a minute."
		"ep_02.al_silo_waithere_far" = "<clr:255,212,255>We'll wait for you here, Gordon."
		"ep_02.al_silo_waithere_near" = "<clr:255,212,255>We'll wait for you here, Gordon."
		"ep_02.al_silo_wellheadover01" = "<clr:255,212,255>We'll head right over."
		"ep_02.al_silo_wemadeit01" = "<clr:255,212,255>This is it!"
		"ep_02.al_silo_wemadeit02" = "<clr:255,212,255>We made it!"
		"ep_02.al_silo_whatif" = "<clr:255,212,255>Did you ever---"
		"ep_02.al_silo_whereskleiner01" = "<clr:255,212,255>Um, where's Dr. Kleiner?"
		"ep_02.al_silo_whereskleiner02" = "<clr:255,212,255>We should get this data to him right away."
		"ep_02.al_silo_wonder01" = "<clr:255,212,255>Well, at least we beat the Combine here."
		"ep_02.al_silo_wonder02" = "<clr:255,212,255>I just hope they're ready for what's coming."
		"ep_02.al_silo_wow" = "<clr:255,212,255>Wow."
		"ep_02.al_silo_yougo01" = "<clr:255,212,255>you go ahead gordon.  I don't want to leave him alone just yet."
		"ep_02.al_silo_yougo02" = "<clr:255,212,255>I'll catch up with you later."
		"ep_02.al_silo_youshouldhelp" = "<clr:255,212,255>Gordon, I guess you should help Dr. Magnusson."
		"ep_02.al_str_almosthadme" = "<clr:255,212,255>You had me worried there."
		"ep_02.al_str_base01" = "<clr:255,212,255>The base is around here somewhere.  "
		"ep_02.al_str_base02" = "<clr:255,212,255>I've never come in from this direction."
		"ep_02.al_str_careful" = "<clr:255,212,255>Careful!"
		"ep_02.al_str_carnag01" = "<clr:255,212,255>Come on, Gordon, get the car and we'll challenge Dog to a race."
		"ep_02.al_str_carnag02" = "<clr:255,212,255>We should bring the car, Gordon."
		"ep_02.al_str_carnag03" = "<clr:255,212,255>Mind getting the car, Gordon?"
		"ep_02.al_str_catchingup" = "<clr:255,212,255>We're catching up!"
		"ep_02.al_str_closethankgod" = "<clr:255,212,255>We're close, thank God."
		"ep_02.al_str_detour" = "<clr:255,212,255>Looks like we're in for a detour."
		"ep_02.al_str_dogfallen01" = "<clr:255,212,255>Dog!"
		"ep_02.al_str_dogfallen02" = "<clr:255,212,255>Dog!"
		"ep_02.al_str_dogfallen03" = "<clr:255,212,255>Are you all right?"
		"ep_02.al_str_dogokay" = "<clr:255,212,255>Dog..."
		"ep_02.al_str_dograce01" = "<clr:255,212,255>Go, Gordon, go!"
		"ep_02.al_str_dograce02" = "<clr:255,212,255>Step on it, Gordon!"
		"ep_02.al_str_dograce03" = "<clr:255,212,255>We're gonna win, Dog!"
		"ep_02.al_str_dograce04" = "<clr:255,212,255>We're catching up, boy!"
		"ep_02.al_str_dograce05" = "<clr:255,212,255>No, Dog!  You're supposed to let us win!"
		"ep_02.al_str_dropship01" = "<clr:255,212,255>Whoa!  "
		"ep_02.al_str_dropship02" = "<clr:255,212,255>A dropship!"
		"ep_02.al_str_dropship03" = "<clr:255,212,255>That must have been the crash we heard.  "
		"ep_02.al_str_dropship04" = "<clr:255,212,255>White Forest sentries are doing their job."
		"ep_02.al_str_ew" = "<clr:255,212,255>Ewww...."
		"ep_02.al_str_fine01" = "<clr:255,212,255>We're fine!"
		"ep_02.al_str_fine02" = "<clr:255,212,255>Thanks for your help!"
		"ep_02.al_str_gasp" = "<clr:255,212,255>[Gasp]"
		"ep_02.al_str_getclear" = "<clr:255,212,255>Get clear!"
		"ep_02.al_str_gettingclose01" = "<clr:255,212,255>This looks familiar.  "
		"ep_02.al_str_gettingclose02" = "<clr:255,212,255>I think we're getting close."
		"ep_02.al_str_gettobase" = "<clr:255,212,255>Ok, let's go."
		"ep_02.al_str_getup" = "<clr:255,212,255>Get up!"
		"ep_02.al_str_good" = "<clr:255,212,255>Good."
		"ep_02.al_str_goodboy" = "<clr:255,212,255>Good boy."
		"ep_02.al_str_gooddoggie" = "<clr:255,212,255>Good doggie..."
		"ep_02.al_str_gordonoverhere" = "<clr:255,212,255>Gordon, over here!"
		"ep_02.al_str_great" = "<clr:255,212,255>Grrrreat."
		"ep_02.al_str_hangon" = "<clr:255,212,255>Hang on!"
		"ep_02.al_str_helpagain" = "<clr:255,212,255>Looks like we need your help again."
		"ep_02.al_str_holdon" = "<clr:255,212,255>Hold on!"
		"ep_02.al_str_lookoutdog" = "<clr:255,212,255>Look out, Dog!"
		"ep_02.al_str_no" = "<clr:255,212,255>No!"
		"ep_02.al_str_ohnodog" = "<clr:255,212,255>Oh no!"
		"ep_02.al_str_ohnodog02" = "<clr:255,212,255>Oh no!"
		"ep_02.al_str_ohshistrid" = "<clr:255,212,255>A strider!"
		"ep_02.al_str_omg" = "<clr:255,212,255>Oh my god!"
		"ep_02.al_str_onfoot" = "<clr:255,212,255>Well, we're close enough to make it the rest of the way on foot if we have to."
		"ep_02.al_str_onourside" = "<clr:255,212,255>I'm glad you're on our side."
		"ep_02.al_str_opengate01" = "<clr:255,212,255>Hey, wait a minute."
		"ep_02.al_str_opengate02" = "<clr:255,212,255>Dog, help us open this gate!"
		"ep_02.al_str_outoftheway" = "<clr:255,212,255>Out of the way!"
		"ep_02.al_str_overhere" = "<clr:255,212,255>Over here, Gordon."
		"ep_02.al_str_overheregordon" = "<clr:255,212,255>Over here, Gordon!"
		"ep_02.al_str_raceyou01" = "<clr:255,212,255>Okay, Dog."
		"ep_02.al_str_raceyou02" = "<clr:255,212,255>Race you to the base!"
		"ep_02.al_str_seeantenna01" = "<clr:255,212,255>Over there!  "
		"ep_02.al_str_seeantenna02" = "<clr:255,212,255>I see an antenna!"
		"ep_02.al_str_seeantenna03" = "<clr:255,212,255>I think that's White Forest!"
		"ep_02.al_str_selfserve" = "<clr:255,212,255>I guess it's self service."
		"ep_02.al_str_sentrypost" = "<clr:255,212,255>Over there--a gate. "
		"ep_02.al_str_soldiers01" = "<clr:255,212,255>Hear that?  "
		"ep_02.al_str_soldiers02" = "<clr:255,212,255>Must be soldiers from White Forest.  "
		"ep_02.al_str_soldiers03" = "<clr:255,212,255>Let's catch up with them."
		"ep_02.al_str_soundgood" = "<clr:255,212,255>That...doesn't sound good."
		"ep_02.al_str_soundlikecrash01" = "<clr:255,212,255>What's that?  "
		"ep_02.al_str_soundlikecrash02" = "<clr:255,212,255>Sounded like a crash!"
		"ep_02.al_str_soundslikedog01" = "<clr:255,212,255>Wait!"
		"ep_02.al_str_soundslikedog02" = "<clr:255,212,255>That sounds like..."
		"ep_02.al_str_soundslikedog03" = "<clr:255,212,255>Dog!"
		"ep_02.al_str_steponit" = "<clr:255,212,255>Step on it, Gordon!"
		"ep_02.al_str_thanksagain01" = "<clr:255,212,255>All right,"
		"ep_02.al_str_thanksagain02" = "<clr:255,212,255>thanks!"
		"ep_02.al_str_thatsoneway" = "<clr:255,212,255>Well, that's one way."
		"ep_02.al_str_uhoh" = "<clr:255,212,255>Uh oh."
		"ep_02.al_str_wakeupdog01" = "<clr:255,212,255>Wake up, Dog."
		"ep_02.al_str_wakeupdog02" = "<clr:255,212,255>Please..."
		"ep_02.al_str_watchoutsoldiers01" = "<clr:255,212,255>Watch out!  "
		"ep_02.al_str_watchoutsoldiers02" = "<clr:255,212,255>Soldiers!"
		"ep_02.al_str_waypast01" = "<clr:255,212,255>If we can find a way past this..."
		"ep_02.al_str_waypast02" = "<clr:255,212,255>I think White Forest is just over that ridge."
		"ep_02.al_str_waytogo" = "<clr:255,212,255>Way to go, boy!"
		"ep_02.al_str_waytogoboy" = "<clr:255,212,255>Way to go, boy!"
		"ep_02.al_str_welcome" = "<clr:255,212,255>Well, we're close to White Forest, but I guess we'll have to leave the car, unless we can figure out a way to open this gate."
		"ep_02.al_str_whatthehell" = "<clr:255,212,255>What the hell?"
		"ep_02.al_str_working" = "<clr:255,212,255>Everything working all right?"
		"ep_02.al_str_wouldyoumind" = "<clr:255,212,255>Would you mind..."
		"ep_02.al_str_yeah01" = "<clr:255,212,255>Yeah!"
		"ep_02.al_str_yeah02" = "<clr:255,212,255>Yeah!"
		"ep_02.al_str_youareok01" = "<clr:255,212,255>[Laugh]"
		"ep_02.al_str_youareok02" = "<clr:255,212,255>You're all right!"
		"ep_02.al_str_yougothim" = "<clr:255,212,255>You've got him!"
		"ep_02.al_throwmed01" = "<clr:255,212,255>Gordon, catch!"
		"ep_02.al_throwmed02" = "<clr:255,212,255>Catch this, Gordon!"
		"ep_02.al_throwmed03" = "<clr:255,212,255>Medkit!"
		"ep_02.al_throwmed04" = "<clr:255,212,255>Gordon, here comes a medkit!"
		"ep_02.al_throwmed05" = "<clr:255,212,255>Here, Gordon, you could use this!"
		"ep_02.al_transmit_ahno" = "<clr:255,212,255>Ah no! "
		"ep_02.al_transmit_bearings" = "<clr:255,212,255>We have to get our bearings, but we can definitely... "
		"ep_02.al_transmit_bldgs01" = "<clr:255,212,255>Those buildings look like they've seen some use recently. "
		"ep_02.al_transmit_bldgs02" = "<clr:255,212,255>We should find a way out there. "
		"ep_02.al_transmit_breakingup01" = "<clr:255,212,255>Dad? "
		"ep_02.al_transmit_breakingup02" = "<clr:255,212,255>Dad! "
		"ep_02.al_transmit_breakingup03" = "<clr:255,212,255>Dad! "
		"ep_02.al_transmit_breakingup04" = "<clr:255,212,255>Dad?"
		"ep_02.al_transmit_breakingup05" = "<clr:255,212,255>You're breaking up - come in. "
		"ep_02.al_transmit_breakingup06" = "<clr:255,212,255>Dad - are you there? "
		"ep_02.al_transmit_breakingup07" = "<clr:255,212,255>Dad! "
		"ep_02.al_transmit_breakthrough" = "<clr:255,212,255>Gordon - you've made a breakthrough!"
		"ep_02.al_transmit_carefulupthere01" = "<clr:255,212,255>Excellent, Gordon! "
		"ep_02.al_transmit_carefulupthere02" = "<clr:255,212,255>Careful up there. "
		"ep_02.al_transmit_carefulupthere03" = "<clr:255,212,255>I'll keep watch out here. "
		"ep_02.al_transmit_comein01" = "<clr:255,212,255>White Forest... "
		"ep_02.al_transmit_comein02" = "<clr:255,212,255>White Forest - this is Alyx Vance. Do you read? "
		"ep_02.al_transmit_comein03" = "<clr:255,212,255>White Forest, come in. "
		"ep_02.al_transmit_comein04" = "<clr:255,212,255>White Forest, are you there? "
		"ep_02.al_transmit_comein05" = "<clr:255,212,255>White Forest, come in, this is Alyx Vance, do you read?"
		"ep_02.al_transmit_comeon01" = "<clr:255,212,255>Come on, this way. "
		"ep_02.al_transmit_download01" = "<clr:255,212,255>I downloaded the whole packet. "
		"ep_02.al_transmit_download02" = "<clr:255,212,255>They've been chasing us ever since. "
		"ep_02.al_transmit_feedingdata01" = "<clr:255,212,255>In the control room..."
		"ep_02.al_transmit_feedingdata02" = "<clr:255,212,255>They were feeding huge volumes of data directly into the core destruction sequence. "
		"ep_02.al_transmit_gordontoo" = "<clr:255,212,255>Yes, and Gordon too. We're okay - we made it out of City Seventeen. "
		"ep_02.al_transmit_grabbed01" = "<clr:255,212,255>My God. "
		"ep_02.al_transmit_grabbed02" = "<clr:255,212,255>Gordon... "
		"ep_02.al_transmit_grabbed03" = "<clr:255,212,255>What if that's why they were sending so much data from the Citadel?"
		"ep_02.al_transmit_grabbed04" = "<clr:255,212,255>So that..."
		"ep_02.al_transmit_hmm01" = "<clr:255,212,255>Hmm. "
		"ep_02.al_transmit_howgetthru" = "<clr:255,212,255>How are we gonna get through here? "
		"ep_02.al_transmit_huh" = "<clr:255,212,255>Huh. "
		"ep_02.al_transmit_ifiwereto" = "<clr:255,212,255>If I were to... hm. "
		"ep_02.al_transmit_ithinkthat" = "<clr:255,212,255>I think that... "
		"ep_02.al_transmit_lemmefigure" = "<clr:255,212,255>Let me figure this out. "
		"ep_02.al_transmit_lemmesee01" = "<clr:255,212,255>Hmm. Let me see... "
		"ep_02.al_transmit_lemmesee02" = "<clr:255,212,255>Let me see about this. "
		"ep_02.al_transmit_letmesee01" = "<clr:255,212,255>Mmm... let me see. "
		"ep_02.al_transmit_oldrocket01" = "<clr:255,212,255>Doctor Magnusson has an old rocket up at White Forest. "
		"ep_02.al_transmit_oldrocket02" = "<clr:255,212,255>He's been hoping for the day when he could launch a satellite, to tap into the old array they set up at Black Mesa. "
		"ep_02.al_transmit_oldrocket03" = "<clr:255,212,255>But getting a launch off while the Combine was intact - there was just no way. "
		"ep_02.al_transmit_oldrocket04" = "<clr:255,212,255>I'm not sure how they'll use the satellite to shut down that portal but... "
		"ep_02.al_transmit_oldrocket05" = "<clr:255,212,255>I guess we'll find out when we get there. "
		"ep_02.al_transmit_oldrocket06" = "<clr:255,212,255>I've been there once or twice, so it shouldn't be too hard to find. "
		"ep_02.al_transmit_opengate" = "<clr:255,212,255>Hey, can you figure out a way to get this gate open? "
		"ep_02.al_transmit_pickup" = "<clr:255,212,255>I hope they didn't pick up any of that. "
		"ep_02.al_transmit_railcar" = "<clr:255,212,255>Whoa. "
		"ep_02.al_transmit_strangecore01" = "<clr:255,212,255>Don't worry, Dad - we're fine. "
		"ep_02.al_transmit_strangecore02" = "<clr:255,212,255>But something really strange is happening with the Citadel. "
		"ep_02.al_transmit_thatdidtrick" = "<clr:255,212,255>Nice, That did the trick. "
		"ep_02.al_transmit_thatworked" = "<clr:255,212,255>That worked. "
		"ep_02.al_transmit_tracking01" = "<clr:255,212,255>They're still tracking us. "
		"ep_02.al_transmit_tracking02" = "<clr:255,212,255>We need to keep moving. "
		"ep_02.al_transmit_upnorth01" = "<clr:255,212,255>Doctor Kleiner and my Dad are up north at an old missile base."
		"ep_02.al_transmit_upnorth02" = "<clr:255,212,255>I hope they're still using this frequency. "
		"ep_02.al_transmit_upnorth03" = "<clr:255,212,255>They're trying to help launch a..."
		"ep_02.al_transmit_upnorth04" = "<clr:255,212,255>Ah - here we go. "
		"ep_02.al_transmit_waythrough" = "<clr:255,212,255>I can always count on you to find a way through. "
		"ep_02.al_transmit_well01" = "<clr:255,212,255>Well... "
		"ep_02.reb_silo_reb_art10" = "We sure as hell didn't use guns.  We would just wrestle Hunters to the ground with our bare hands.  I used to kill ten-twenty a day, just using my fists."
		"ep_02.reb_silo_reb_art12" = "Out in the field?  I'm not going out in the field.  I'm a radio operator."
		"ep_02.reb_silo_reb_art14" = "I'm staying right here."
		"ep_02.reb_silo_reb_art2" = "AR2? Nooo... Now, an AR3, sure.  plenty of times."
		"ep_02.reb_silo_reb_art4" = "Are you from the city?"
		"ep_02.reb_silo_reb_art6" = "Well, see, in the city...the place was lousy with AR3s."
		"ep_02.reb_silo_reb_art8" = "Yes it was."
		"ep_02.reb_silo_reb_art1" = "So have you ever used an AR2 before?"
		"ep_02.reb_silo_reb_art11" = "So, when you're out in the field, you're going to be punching Hunters?"
		"ep_02.reb_silo_reb_art13" = "(groan) That's it.  Leave.  You don't need to be here and I'm not going to continue the lesson until you leave."
		"ep_02.reb_silo_reb_art15" = "I am serious, leave."
		"ep_02.reb_silo_reb_art16" = "I'm not going to continue until you leave."
		"ep_02.reb_silo_reb_art3" = "There is no such thing as an AR3."
		"ep_02.reb_silo_reb_art5" = "No."
		"ep_02.reb_silo_reb_art7" = "No it wasn't."
		"ep_02.reb_silo_reb_cpl1" = "Well what else could we do with him?  He isn't actually operating the radio, I told him to just make sure no one touches the knobs."
		"ep_02.reb_silo_reb_cpl3" = "Maybe we can take the knobs off the radio?"
		"ep_02.al_chop_backinsidenag01" = "<clr:255,212,255>Gordon!  The car's ready!  Come on back and we'll get going!"
		"ep_02.al_chop_backinsidenag02" = "<clr:255,212,255>Let's get inside Gordon!"
		"ep_02.al_chop_backinsidenag03" = "<clr:255,212,255>Gordon the car's ready! Let's go!"
		"ep_02.al_chop_chanceoutrun" = "<clr:255,212,255>Any chance of outrunning it?"
		"ep_02.al_chop_didweloseit" = "<clr:255,212,255>There!  Did we lose it?"
		"ep_02.al_chop_ditch" = "<clr:255,212,255>It's not gonna leave us alone.  Let's see if we can find some way to ditch it."
		"ep_02.al_chop_helloutrun" = "<clr:255,212,255>How the hell are we gonna outrun that thing?"
		"ep_02.al_chop_itsback01" = "<clr:255,212,255>Oh no, it's back!"
		"ep_02.al_chop_itsback02" = "<clr:255,212,255>It's not gonna leave us alone."
		"ep_02.al_chop_shakethisthing" = "<clr:255,212,255>How the hell are we gonna shake this thing?"
		"ep_02.al_chop_trytooutrun" = "<clr:255,212,255>Try to outrun it!"
		"ep_02.al_chop_vannag01" = "<clr:255,212,255>Must be one of those tracking beacons in the van."
		"ep_02.al_chop_vannag02" = "<clr:255,212,255>The radar's pointing right at this van."
		"ep_02.al_chop_vannag03" = "<clr:255,212,255>How're we going to get in there?"
		"ep_02.reb_chop_autogun01" = "Well that could be a problem."
		"ep_02.reb_chop_autogun02" = "You hear that autogun going off out there?"
		"ep_02.reb_chop_autogun03" = "We normally run supplies out to the White Forest base, but a few days ago the Combine cut off access."
		"ep_02.reb_chop_boyfriend" = "So, uh...is that your boyfriend?"
		"ep_02.reb_chop_favor01" = "Hey!  In here!"
		"ep_02.reb_chop_favor02" = "Since you brought that chopper in on your tail, you wanna maybe help us take it down?"
		"ep_02.reb_chop_goodluck" = "Good luck taking out that autogun!"
		"ep_02.reb_chop_nagdoor" = "The door is up here."
		"ep_02.reb_chop_nothankyou" = "No need to thank me."
		"ep_02.reb_chop_radarintro01" = "Special, this week only."
		"ep_02.reb_chop_radarintro02" = "It's like an on-board radar for you guys.  Picks up little beacon jobbers like this one here."
		"ep_02.reb_chop_radarintro03" = "We've hidden a bunch of these things out there in the field to signal emergency stashes."
		"ep_02.reb_chop_radarintro04" = "So keep an eye out!"
		"ep_02.reb_chop_radarintro05" = "When you see your dashboard light up, you're gonna want to stop and investigate."
		"ep_02.reb_chop_shipdown03" = "Shut up!"
		"ep_02.reb_chop_shop" = "Tools?  We've got a whole shop over here.  Come on, we'll get you set up."
		"ep_02.reb_chop_showgun01" = "Take a look over here.  I'll show you the set-up."
		"ep_02.reb_chop_showgun02" = "Here, check it out."
		"ep_02.reb_chop_showgun03" = "No way you're driving out past that."
		"ep_02.reb_chop_trapdoor01" = "We have a trap door up here where I can let you over to the other side.  "
		"ep_02.reb_chop_trapdoor02" = "That way you'll get to see the gun before it sees you."
		"ep_02.reb_chop_useadrink01" = "That was amazing the way you threw their mines right back at em.  "
		"ep_02.reb_chop_useadrink02" = "Well, I could sure use a drink.  Who's with me?"
		"ep_02.reb_chop_zombies01" = "All the fresh zombies coming out of City 17 have kept 'em pinned down, but it's just a matter of time till the troops start pushing this way.  "
		"ep_02.reb_chop_zombies02" = "If you think you're up to it, we'll let you out there."
		"ep_02.cpt_battle_comecloser01" = "Over here!"
		"ep_02.cpt_battle_comecloser02" = "Come closer!"
		"ep_02.cpt_battle_entrust01" = "So, they've sent me Freeman, have they?  Good man."
		"ep_02.cpt_battle_positions01" = "All right, people, this is it!"
		"ep_02.cpt_battle_positions02" = "Defensive positions!  Go!"
		"ep_02.cpt_battle_sawmillhere01" = "All right, people, gather round."
		"ep_02.cpt_battle_sawmillhere02" = "We've counted a dozen striders just north of us.  "
		"ep_02.cpt_battle_sawmillhere03" = "Our job is to keep them from reaching the base to the south.  "
		"ep_02.cpt_battle_sawmillhere04" = "If they get close enough for one good shot at the silo"
		"ep_02.cpt_battle_sawmillhere05" = "the whole launch is a bust.  "
		"ep_02.cpt_battle_sawmillhere06" = "And in case striders aren't bad enough, recon indicates they're being escorted by packs of Hunters.  "
		"ep_02.cpt_battle_sawmillhere07" = "Those mini-buggers are gonna make it hard for Freeman to get a clear shot with the Magnusson device.  "
		"ep_02.cpt_battle_sawmillhere08" = "Now what I want you to do--- "
		"ep_02.eli_launch_adv_alyx" = "<clr:255,208,172>Alyx!"
		"ep_02.eli_launch_affirm01" = "<clr:255,208,172>Mm hmm."
		"ep_02.eli_launch_affirm02" = "<clr:255,208,172>Yeah."
		"ep_02.eli_launch_affirm03" = "<clr:255,208,172>Hmm."
		"ep_02.eli_launch_affirm04" = "<clr:255,208,172>I gotcha"
		"ep_02.eli_launch_ahgordon" = "<clr:255,208,172>Ah, Gordon!"
		"ep_02.eli_launch_anotherattempt01" = "<clr:255,208,172>Good idea."
		"ep_02.eli_launch_anotherattempt02" = "<clr:255,208,172>She could well make another attempt."
		"ep_02.eli_launch_awe01" = "<clr:255,208,172>Yes! "
		"ep_02.eli_launch_awe02" = "<clr:255,208,172>Fantastic."
		"ep_02.eli_launch_bigpain01" = "<clr:255,208,172>[pain]"
		"ep_02.eli_launch_bigpain02" = "<clr:255,208,172>[pain]"
		"ep_02.eli_launch_bigpain03" = "<clr:255,208,172>[pain]"
		"ep_02.eli_launch_bigpain04" = "<clr:255,208,172>[pain]"
		"ep_02.eli_launch_bigpain05" = "<clr:255,208,172>[pain]"
		"ep_02.eli_launch_bigpain06" = "<clr:255,208,172>[pain]"
		"ep_02.eli_launch_breath01" = "<clr:255,208,172>[pain]"
		"ep_02.eli_launch_breath02" = "<clr:255,208,172>[pain]"
		"ep_02.eli_launch_breath03" = "<clr:255,208,172>[pain]"
		"ep_02.eli_launch_breath04" = "<clr:255,208,172>[pain]"
		"ep_02.eli_launch_breath05" = "<clr:255,208,172>[pain]"
		"ep_02.eli_launch_breath06" = "<clr:255,208,172>[pain]"
		"ep_02.eli_launch_breath07" = "<clr:255,208,172>[pain]"
		"ep_02.eli_launch_brt" = "<clr:255,208,172>Be right there, Alyx. "
		"ep_02.eli_launch_catchup" = "<clr:255,208,172>We'll catch up with you in a moment, sweetheart."
		"ep_02.eli_launch_check11" = "<clr:255,208,172>Now, now..."
		"ep_02.eli_launch_closeeyes" = "<clr:255,208,172>Close your eyes, honey."
		"ep_02.eli_launch_constant01" = "<clr:255,208,172>Remember to keep in constant contact."
		"ep_02.eli_launch_constant02" = "<clr:255,208,172>We have no idea what to expect."
		"ep_02.eli_launch_didit" = "<clr:255,208,172>We did it!"
		"ep_02.eli_launch_dontlook" = "<clr:255,208,172>Don't look."
		"ep_02.eli_launch_ehh" = "<clr:255,208,172>Ehhh!!!"
		"ep_02.eli_launch_fireworks01" = "<clr:255,208,172>Well, let's get outside.  "
		"ep_02.eli_launch_fireworks02" = "<clr:255,208,172>I'd like a better view of the fireworks."
		"ep_02.eli_launch_getstheidea01" = "<clr:255,208,172>Yeah, yeah, I think Gordon gets the idea."
		"ep_02.eli_launch_getstheidea02" = "<clr:255,208,172>We really need to get going."
		"ep_02.eli_launch_gimme01" = "<clr:255,208,172>We did it, Izzy!"
		"ep_02.eli_launch_gimme02" = "<clr:255,208,172>Heh."
		"ep_02.eli_launch_gimme03" = "<clr:255,208,172>Come on, come on, give me five."
		"ep_02.eli_launch_gimme04" = "<clr:255,208,172>Hit it!"
		"ep_02.eli_launch_gimme05" = "<clr:255,208,172>Come on!"
		"ep_02.eli_launch_givinghonor" = "<clr:255,208,172>I believe Gordon should have the honor."
		"ep_02.eli_launch_goodluck01" = "<clr:255,208,172>Good luck, both of you."
		"ep_02.eli_launch_goodluck02" = "<clr:255,208,172>Take care of each other."
		"ep_02.eli_launch_goodman01" = "<clr:255,208,172>Good man, Gordon."
		"ep_02.eli_launch_goodman02" = "<clr:255,208,172>Couldn't have been easy out there."
		"ep_02.eli_launch_gotcha" = "<clr:255,208,172>Gotcha!"
		"ep_02.eli_launch_gotthatright01" = "<clr:255,208,172>You got that right, sweetheart."
		"ep_02.eli_launch_gotthatright02" = "<clr:255,208,172>But we've got plenty to celebrate."
		"ep_02.eli_launch_gurgle01" = "<clr:255,208,172>[pain]"
		"ep_02.eli_launch_gurgle02" = "<clr:255,208,172>[pain]"
		"ep_02.eli_launch_gurgle03" = "<clr:255,208,172>[pain]"
		"ep_02.eli_launch_gurgle04" = "<clr:255,208,172>[pain]"
		"ep_02.eli_launch_happening01" = "<clr:255,208,172>It's working!  "
		"ep_02.eli_launch_happening02" = "<clr:255,208,172>Thank God."
		"ep_02.eli_launch_hastowork" = "<clr:255,208,172>Dear God...this has to work..."
		"ep_02.eli_launch_haveeverything" = "<clr:255,208,172>Are you sure you have everything you need?"
		"ep_02.eli_launch_hellofajob" = "<clr:255,208,172>Hell of a job you did out there, son."
		"ep_02.eli_launch_holdup" = "<clr:255,208,172>Gordon, hold up a second..."
		"ep_02.eli_launch_holysh" = "<clr:255,208,172>Holy shit!"
		"ep_02.eli_launch_iloveyou" = "<clr:255,208,172>I love you."
		"ep_02.eli_launch_iloveyou_alt" = "<clr:255,208,172>I love you."
		"ep_02.eli_launch_iloveyousweet" = "<clr:255,208,172>I love you, sweetheart."
		"ep_02.eli_launch_info01" = "<clr:255,208,172>Now."
		"ep_02.eli_launch_info02" = "<clr:255,208,172>Now Alyx do you have all the information you need?"
		"ep_02.eli_launch_ithasto" = "<clr:255,208,172>It has to."
		"ep_02.eli_launch_leavesosoon01" = "<clr:255,208,172>I wish you didn't have to head off so soon."
		"ep_02.eli_launch_leavesosoon02" = "<clr:255,208,172>If only it weren't so critical... "
		"ep_02.eli_launch_listentome01" = "<clr:255,208,172>Alyx!"
		"ep_02.eli_launch_listentome02" = "<clr:255,208,172>Listen to me!"
		"ep_02.eli_launch_moan01" = "<clr:255,208,172>[moans]"
		"ep_02.eli_launch_moan02" = "<clr:255,208,172>[moans]"
		"ep_02.eli_launch_moan03" = "<clr:255,208,172>[moans]"
		"ep_02.eli_launch_moan04" = "<clr:255,208,172>[moans]"
		"ep_02.eli_launch_moan05" = "<clr:255,208,172>[moans]"
		"ep_02.eli_launch_moan06" = "<clr:255,208,172>[moans]"
		"ep_02.eli_launch_moan07" = "<clr:255,208,172>[moans]"
		"ep_02.eli_launch_moan08" = "<clr:255,208,172>[moans]"
		"ep_02.eli_launch_moan09" = "<clr:255,208,172>[moans]"
		"ep_02.eli_launch_moan10" = "<clr:255,208,172>[moans]"
		"ep_02.eli_launch_moan11" = "<clr:255,208,172>[moans]"
		"ep_02.eli_launch_moan12" = "<clr:255,208,172>[moans]"
		"ep_02.eli_launch_moan13" = "<clr:255,208,172>[moans]"
		"ep_02.eli_launch_moan14" = "<clr:255,208,172>[moans]"
		"ep_02.eli_launch_moan15" = "<clr:255,208,172>[moans]"
		"ep_02.eli_launch_moan16" = "<clr:255,208,172>[moans]"
		"ep_02.eli_launch_moan17" = "<clr:255,208,172>[moans]"
		"ep_02.eli_launch_moan18" = "<clr:255,208,172>[moans]"
		"ep_02.eli_launch_moan19" = "<clr:255,208,172>[moans]"
		"ep_02.eli_launch_momenttoosoon01" = "<clr:255,208,172>And not a moment too soon.  "
		"ep_02.eli_launch_mother01" = "<clr:255,208,172>Your mother would be so proud..."
		"ep_02.eli_launch_mother02" = "<clr:255,208,172>if she were here today."
		"ep_02.eli_launch_notime01" = "<clr:255,208,172>There's no time to waste."
		"ep_02.eli_launch_notime02" = "<clr:255,208,172>Get right on it."
		"ep_02.eli_launch_onefire01" = "<clr:255,208,172>I just wish all this didn't have to fall on you, Alyx."
		"ep_02.eli_launch_pain01" = "<clr:255,208,172>[pain]"
		"ep_02.eli_launch_pain02" = "<clr:255,208,172>[pain]"
		"ep_02.eli_launch_pain03" = "<clr:255,208,172>[pain]"
		"ep_02.eli_launch_pain04" = "<clr:255,208,172>[pain]"
		"ep_02.eli_launch_pain05" = "<clr:255,208,172>[pain]"
		"ep_02.eli_launch_pain06" = "<clr:255,208,172>[pain]"
		"ep_02.eli_launch_pain07" = "<clr:255,208,172>[pain]"
		"ep_02.eli_launch_pain08" = "<clr:255,208,172>[pain]"
		"ep_02.eli_launch_pain09" = "<clr:255,208,172>[pain]"
		"ep_02.eli_launch_pain10" = "<clr:255,208,172>[pain]"
		"ep_02.eli_launch_pain11" = "<clr:255,208,172>[pain]"
		"ep_02.eli_launch_pain12" = "<clr:255,208,172>[pain]"
		"ep_02.eli_launch_pain13" = "<clr:255,208,172>[pain]"
		"ep_02.eli_launch_pain14" = "<clr:255,208,172>[pain]"
		"ep_02.eli_launch_portalyes01" = "<clr:255,208,172> Yes!"
		"ep_02.eli_launch_portalyes02" = "<clr:255,208,172> Yes!"
		"ep_02.eli_launch_portalyes03" = "<clr:255,208,172> Yes!"
		"ep_02.eli_launch_promiseme" = "<clr:255,208,172>Destroy it!"
		"ep_02.eli_launch_promiseme_alt" = "<clr:255,208,172>Destroy it!"
		"ep_02.eli_launch_promiseme01" = "<clr:255,208,172>Good, I just..."
		"ep_02.eli_launch_promiseme02" = "<clr:255,208,172>Promise me"
		"ep_02.eli_launch_promiseme03" = "<clr:255,208,172>you'll be careful."
		"ep_02.eli_launch_pulleditoff01" = "<clr:255,208,172>Yep."
		"ep_02.eli_launch_pulleditoff02" = "<clr:255,208,172>Magnusson pulled it off all right."
		"ep_02.eli_launch_pulleditoff03" = "<clr:255,208,172>This will definitely send a clear message to the Combine."
		"ep_02.eli_launch_pulleditoff04" = "<clr:255,208,172>We're not free of them yet..."
		"ep_02.eli_launch_pulleditoff05" = "<clr:255,208,172>But if we can acquire a signature from the data you brought back,"
		"ep_02.eli_launch_pulleditoff06" = "<clr:255,208,172>we might be able to shut them out for good."
		"ep_02.eli_launch_pulleditoff07" = "<clr:255,208,172>I feel certain that when"
		"ep_02.eli_launch_pulleditoff08" = "<clr:255,208,172>Judith..."
		"ep_02.eli_launch_remember01" = "<clr:255,208,172>Destroy that ship!"
		"ep_02.eli_launch_remember02" = "<clr:255,208,172>Whatever it takes!"
		"ep_02.eli_launch_soundplan" = "<clr:255,208,172>Sounds like a plan."
		"ep_02.eli_launch_sureashell" = "<clr:255,208,172>We sure as hell did!"
		"ep_02.eli_launch_takecarenow" = "<clr:255,208,172>You take care now!"
		"ep_02.eli_launch_talk01" = "<clr:255,208,172>That message from our mutual friend."
		"ep_02.eli_launch_talk01_alt" = "<clr:255,208,172>The more I think about that warning from our friend, the more I'm convinced it has to do with Borealis."
		"ep_02.eli_launch_talk02" = "<clr:255,208,172>It's got to be about the Borealis."
		"ep_02.eli_launch_talk03" = "<clr:255,208,172>Don't be deceived."
		"ep_02.eli_launch_talk04" = "<clr:255,208,172>That ship must never be used."
		"ep_02.eli_launch_talk05" = "<clr:255,208,172>You have got to destroy it."
		"ep_02.eli_launch_talk06" = "<clr:255,208,172>Whatever the cost."
		"ep_02.eli_launch_terrific" = "<clr:255,208,172>Terrific!"
		"ep_02.eli_launch_thanksforeverything01" = "<clr:255,208,172>Gordon... "
		"ep_02.eli_launch_thanksforeverything02" = "<clr:255,208,172>Thanks for everything you've done."
		"ep_02.eli_launch_thanksforeverything03" = "<clr:255,208,172>For Alyx,"
		"ep_02.eli_launch_thanksforeverything04" = "<clr:255,208,172>For all of us."
		"ep_02.eli_launch_thanksforeverything05" = "<clr:255,208,172>I couldn't be prouder if you were my own son."
		"ep_02.eli_launch_thanksg01" = "<clr:255,208,172>Thank you, Gordon."
		"ep_02.eli_launch_thanksg02" = "<clr:255,208,172>For everything."
		"ep_02.eli_launch_uhizzy" = "<clr:255,208,172>Uh... Izzy"
		"ep_02.eli_launch_use01" = "<clr:255,208,172>All right, all right."
		"ep_02.eli_launch_use02" = "<clr:255,208,172>All right, Gordon."
		"ep_02.eli_launch_use03" = "<clr:255,208,172>Hm?"
		"ep_02.eli_launch_use04" = "<clr:255,208,172>Big day today, eh Gordon?"
		"ep_02.eli_launch_use05" = "<clr:255,208,172>You'll just have to wait until after the launch."
		"ep_02.eli_launch_wesuredid" = "<clr:255,208,172>We sure did!"
		"ep_02.eli_launch_whenyougetback" = "<clr:255,208,172>Now when you get back, we've got a lot to talk about."
		"ep_02.eli_launch_wontifyou" = "<clr:255,208,172>I won't if you won't."
		"ep_02.eli_launch_yeah" = "<clr:255,208,172>Yeah!"
		"ep_02.eli_launch_youtwo" = "<clr:255,208,172>You two really should get going."
		"ep_02.eli_silo_amazing" = "<clr:255,208,172>Amazing isn't it?"
		"ep_02.eli_silo_atitagain" = "<clr:255,208,172>Oh boy, they're at it again."
		"ep_02.eli_silo_barrier" = "<clr:255,208,172>A barrier around the planet."
		"ep_02.eli_silo_believe" = "<clr:255,208,172>believe it or not gordon, it's been in place since you sent up the final satellite from black Mesa."
		"ep_02.eli_silo_blame" = "<clr:255,208,172>Can you blame an old man for wanting grandkids?"
		"ep_02.eli_silo_bootstrap01" = "<clr:255,208,172>Yes."
		"ep_02.eli_silo_bootstrap02" = "<clr:255,208,172>It looks like there still is."
		"ep_02.eli_silo_bootstrap03" = "<clr:255,208,172>But if it's"
		"ep_02.eli_silo_bootstrap04" = "<clr:255,208,172>fallen into "
		"ep_02.eli_silo_bootstrap05" = "<clr:255,208,172>Combine hands."
		"ep_02.eli_silo_catchingup01" = "<clr:255,208,172>Okay...  Yes, yes we should."
		"ep_02.eli_silo_catchingup02" = "<clr:255,208,172>He'll be glad for a chance to get out of the silo.  "
		"ep_02.eli_silo_catchingup03" = "<clr:255,208,172>The way he and Magnusson have been going at it, you'd think they were still competing for grant money."
		"ep_02.eli_silo_chuckles01" = "<clr:255,208,172>[quiet laughs]"
		"ep_02.eli_silo_chuckles02" = "<clr:255,208,172>[quiet laughs]"
		"ep_02.eli_silo_chuckles03" = "<clr:255,208,172>[quiet laughs]"
		"ep_02.eli_silo_chuckles04" = "<clr:255,208,172>[quiet laughs]"
		"ep_02.eli_silo_comehereg01" = "<clr:255,208,172>Gordon... "
		"ep_02.eli_silo_comehereg02" = "<clr:255,208,172>Gordon, come here."
		"ep_02.eli_silo_comehereg03" = "<clr:255,208,172>Over here, Gordon."
		"ep_02.eli_silo_cuedup01" = "<clr:255,208,172><I>Good, good."
		"ep_02.eli_silo_cuedup02" = "<clr:255,208,172><I>We're about to watch the transmission from Judith."
		"ep_02.eli_silo_cuedup03" = "<clr:255,208,172><I>Kleiner has it all cued up."
		"ep_02.eli_silo_dofavor01" = "<norepeat:10><clr:255,208,172>[breath]"
		"ep_02.eli_silo_dofavor02" = "<clr:255,208,172>Actually Alyx, would you mind getting me a cup of tea?"
		"ep_02.eli_silo_dofavor03" = "<clr:255,208,172>There's a hot plate in the old staff room."
		"ep_02.eli_silo_dofavor04" = "<norepeat:10><clr:255,208,172>[breath]"
		"ep_02.eli_silo_doneenough01" = "<clr:255,208,172>I can't put this all on you two..."
		"ep_02.eli_silo_doneenough02" = "<clr:255,208,172>You've done enough already."
		"ep_02.eli_silo_donerunning01" = "<clr:255,208,172>That's right."
		"ep_02.eli_silo_donerunning02" = "<clr:255,208,172>we're done running."
		"ep_02.eli_silo_donerunning03" = "<clr:255,208,172>it's time we took back our world."
		"ep_02.eli_silo_extracther01" = "<clr:255,208,172>I won't take that chance."
		"ep_02.eli_silo_extracther02" = "<clr:255,208,172>I'm going after her."
		"ep_02.eli_silo_feelfree" = "<clr:255,208,172>Feel free to look around, Gordon."
		"ep_02.eli_silo_findherizzy01" = "<clr:255,208,172>Just find her, Izzy"
		"ep_02.eli_silo_findherizzy02" = "<clr:255,208,172>We have to find her."
		"ep_02.eli_silo_fineinaminute01" = "<clr:255,208,172>[sigh]"
		"ep_02.eli_silo_fineinaminute02" = "<clr:255,208,172>Thank you, baby."
		"ep_02.eli_silo_fineinaminute03" = "<clr:255,208,172>I'll be fine..."
		"ep_02.eli_silo_fineinaminute04" = "<clr:255,208,172>In a minute or two."
		"ep_02.eli_silo_fineinaminute05" = "<norepeat:10><clr:255,208,172>[breath]"
		"ep_02.eli_silo_fromjudith01" = "<clr:255,208,172>Transmission?"
		"ep_02.eli_silo_fromjudith02" = "<clr:255,208,172>From Judith?"
		"ep_02.eli_silo_gettingclose01" = "<clr:255,208,172>We don't know for certain."
		"ep_02.eli_silo_gettingclose02" = "<clr:255,208,172>We're keeping an eye on it."
		"ep_02.eli_silo_good" = "<clr:255,208,172>Good."
		"ep_02.eli_silo_goodback" = "<clr:255,208,172>It's so good to have you back, sweetheart."
		"ep_02.eli_silo_goodback01" = "<clr:255,208,172>Don't worry, sweetheart, we're going to make it."
		"ep_02.eli_silo_goodback02" = "<clr:255,208,172>I'm just so glad to have you back."
		"ep_02.eli_silo_goodgod" = "<clr:255,208,172>Good God!"
		"ep_02.eli_silo_goodgod01" = "<clr:255,208,172>Good God!"
		"ep_02.eli_silo_goodgod02" = "<clr:255,208,172>It's worse than I feared."
		"ep_02.eli_silo_goodman01" = "<clr:255,208,172>And look at you, son!"
		"ep_02.eli_silo_goodman02" = "<clr:255,208,172>I knew if you both stayed together you could get through anything."
		"ep_02.eli_silo_goodman03" = "<clr:255,208,172>I knew if you both stayed together you could get through anything"
		"ep_02.eli_silo_hadalook01" = "<clr:255,208,172>Uh, yes."
		"ep_02.eli_silo_hadalook02" = "<clr:255,208,172>Gordon... "
		"ep_02.eli_silo_hadalook03" = "<clr:255,208,172>If you don't mind, I'd feel better if you had a look."
		"ep_02.eli_silo_happeningagain01" = "<clr:255,208,172>Not again."
		"ep_02.eli_silo_happeningagain02" = "<clr:255,208,172>I can't let it happen again."
		"ep_02.eli_silo_happeningagain03" = "<clr:255,208,172>Not another Black Mesa."
		"ep_02.eli_silo_heardclose01" = "<clr:255,208,172>Hey!"
		"ep_02.eli_silo_heardclose02" = "<clr:255,208,172>Gordon!"
		"ep_02.eli_silo_heardclose02_alt" = "<clr:255,208,172>Gordon!"
		"ep_02.eli_silo_heardclose03" = "<clr:255,208,172>Man, you made it!"
		"ep_02.eli_silo_helpingout" = "<clr:255,208,172>Thanks for helping out, Gordon."
		"ep_02.eli_silo_holdyou" = "<clr:255,208,172>Oh, Alyx."
		"ep_02.eli_silo_hurry" = "<clr:255,208,172>For god's sake, hurry."
		"ep_02.eli_silo_hurryizzy" = "<clr:255,208,172>Izzy!"
		"ep_02.eli_silo_iknow" = "<clr:255,208,172>I know, I know."
		"ep_02.eli_silo_iknowiknow" = "<clr:255,208,172>I know, I know."
		"ep_02.eli_silo_intercomok01" = "<clr:255,208,172><I>Yes, Alyx, is everything okay?"
		"ep_02.eli_silo_intercomok02" = "<clr:255,208,172><I>Is Gordon all right?"
		"ep_02.eli_silo_itsallrighthoney" = "<clr:255,208,172>It's all right, honey."
		"ep_02.eli_silo_justgothere" = "<clr:255,208,172>Don't worry, Izzy.  They just got here."
		"ep_02.eli_silo_keepmoving01" = "<clr:255,208,172>Well, we should keep moving"
		"ep_02.eli_silo_keepmoving02" = "<clr:255,208,172>We don't have much time... Let's get going."
		"ep_02.eli_silo_littletime01" = "<clr:255,208,172>We did."
		"ep_02.eli_silo_littletime02" = "<clr:255,208,172>And thanks to your warning, we'll be ready when they get here."
		"ep_02.eli_silo_littletime03" = "<clr:255,208,172>How much time have we got?"
		"ep_02.eli_silo_lostforever" = "<clr:255,208,172>It should have been lost forever."
		"ep_02.eli_silo_neverlether" = "<clr:255,208,172>I should have never let her go!"
		"ep_02.eli_silo_nocontrol01" = "<clr:255,208,172>Hasn't Black Mesa taught you anything?"
		"ep_02.eli_silo_nocontrol02" = "<clr:255,208,172>There's no controlling that kind of power!"
		"ep_02.eli_silo_nonemeanthing01" = "<clr:255,208,172>None of this will"
		"ep_02.eli_silo_nonemeanthing02" = "<clr:255,208,172>mean a thing if..."
		"ep_02.eli_silo_notword" = "<clr:255,208,172>That's not quite the word I'd use."
		"ep_02.eli_silo_nowayyou01" = "<clr:255,208,172>no no that's all right sweetheart"
		"ep_02.eli_silo_nowayyou02" = "<clr:255,208,172>there's no way you could know."
		"ep_02.eli_silo_ohalyx" = "<clr:255,208,172>oh"
		"ep_02.eli_silo_ohbrother" = "<clr:255,208,172>Oh brother."
		"ep_02.eli_silo_onething" = "<clr:255,208,172>One thing at a time, Izzy"
		"ep_02.eli_silo_perfect01" = "<clr:255,208,172>Thank you, darling."
		"ep_02.eli_silo_perfect02" = "<clr:255,208,172>Mmm."
		"ep_02.eli_silo_perfect03" = "<clr:255,208,172>That's perfect"
		"ep_02.eli_silo_perfect04" = "<clr:255,208,172>Mmm.."
		"ep_02.eli_silo_quick" = "<clr:255,208,172>That was quick."
		"ep_02.eli_silo_quicklyg01" = "<clr:255,208,172>Gordon, quickly..."
		"ep_02.eli_silo_quicklyg02" = "<clr:255,208,172>Any help you can give him, get in there and do it."
		"ep_02.eli_silo_raceclock01" = "<clr:255,208,172>It's gonna be close."
		"ep_02.eli_silo_raceclock02" = "<clr:255,208,172>All it would take is one strider to destroy our rocket."
		"ep_02.eli_silo_raceclock03" = "<clr:255,208,172>But we're ready for them."
		"ep_02.eli_silo_remember01" = "<clr:255,208,172>And gordon freeman certainly needs no introduction."
		"ep_02.eli_silo_rememberalyx" = "<clr:255,208,172>you remember alyx don't you?"
		"ep_02.eli_silo_rightaway" = "<clr:255,208,172>We've got to see this right away!"
		"ep_02.eli_silo_sendgordon01" = "<clr:255,208,172>Open the lock, Isaac."
		"ep_02.eli_silo_sendgordon02" = "<clr:255,208,172>We'll send him over."
		"ep_02.eli_silo_stillalive01" = "<clr:255,208,172>Well that means she's still alive up there."
		"ep_02.eli_silo_stillalive02" = "<clr:255,208,172>But if the Combine catch her,"
		"ep_02.eli_silo_stillalive03" = "<clr:255,208,172>they'll tear out everything she knows."
		"ep_02.eli_silo_stillalive04" = "<clr:255,208,172>There'll be nothing left of her."
		"ep_02.eli_silo_stoprightthere01" = "<clr:255,208,172>Stop right there, honey."
		"ep_02.eli_silo_stoprightthere02" = "<clr:255,208,172>I'm responsible for putting her close to breen."
		"ep_02.eli_silo_stoprightthere03" = "<clr:255,208,172>She wanted to stay with us but I needed her to keep an eye on him."
		"ep_02.eli_silo_stoprightthere04" = "<clr:255,208,172>my biggest mistake was forgetting how persuasive he can be."
		"ep_02.eli_silo_stoprightthere05" = "<clr:255,208,172>Judith made some terrible choices."
		"ep_02.eli_silo_stoprightthere06" = "<clr:255,208,172>but she's paid the price"
		"ep_02.eli_silo_stoprightthere07" = "<clr:255,208,172>she needs us alyx."
		"ep_02.eli_silo_stoprightthere08" = "<clr:255,208,172>and I need her."
		"ep_02.eli_silo_swoon" = "<clr:255,208,172>[Groans as he collapses]"
		"ep_02.eli_silo_talk01" = "<clr:255,208,172>Unforeseen consequences..."
		"ep_02.eli_silo_talk02" = "<clr:255,208,172>[laugh]"
		"ep_02.eli_silo_talk03" = "<clr:255,208,172>The last time I heard those words was back at Black Mesa."
		"ep_02.eli_silo_talk04" = "<clr:255,208,172>You had just stepped into the test chamber"
		"ep_02.eli_silo_talk05" = "<clr:255,208,172>when he whispered them in my ear."
		"ep_02.eli_silo_talk06" = "<clr:255,208,172>You know who I'm talking about."
		"ep_02.eli_silo_talk07" = "<clr:255,208,172>Our mutual friend."
		"ep_02.eli_silo_talk08" = "<clr:255,208,172>When he brought in that crystal I knew I... "
		"ep_02.eli_silo_talk09" = "<clr:255,208,172>I should have aborted that damned test."
		"ep_02.eli_silo_talk10" = "<clr:255,208,172>I didn't."
		"ep_02.eli_silo_talk11" = "<clr:255,208,172>The whole world went to hell that day."
		"ep_02.eli_silo_talk12" = "<clr:255,208,172>And now..."
		"ep_02.eli_silo_talk13" = "<clr:255,208,172>Now he's using my little girl."
		"ep_02.eli_silo_talk14" = "<clr:255,208,172>Putting words in her mouth."
		"ep_02.eli_silo_talk15" = "<clr:255,208,172>God damn it!"
		"ep_02.eli_silo_talk16" = "<clr:255,208,172>I should have know when he rescued her it was for his own damn reasons."
		"ep_02.eli_silo_talk17" = "<clr:255,208,172>Gordon... "
		"ep_02.eli_silo_talk18" = "<clr:255,208,172>There's so much I need to tell you."
		"ep_02.eli_silo_talk19" = "<clr:255,208,172>Between us we may finally have a chance to---"
		"ep_02.eli_silo_talk20" = "<clr:255,208,172>what else was on his agenda."
		"ep_02.eli_silo_talk21" = "<clr:255,208,172>but there's still so much."
		"ep_02.eli_silo_thankyou01" = "<norepeat:10><clr:255,208,172>[breath]"
		"ep_02.eli_silo_thankyou02" = "<clr:255,208,172>Thank you, baby."
		"ep_02.eli_silo_thankyou03" = "<clr:255,208,172>Thank you."
		"ep_02.eli_silo_thankyou04" = "<clr:255,208,172>We're not going anywhere."
		"ep_02.eli_silo_thankyou05" = "<norepeat:10><clr:255,208,172>[breath]"
		"ep_02.eli_silo_there01" = "<clr:255,208,172>There, there, sweetheart. We're together now."
		"ep_02.eli_silo_there02" = "<clr:255,208,172>That's all that matters."
		"ep_02.eli_silo_theygoagain" = "<clr:255,208,172>There they go again."
		"ep_02.eli_silo_thiswayg01" = "<clr:255,208,172>This way, Gordon."
		"ep_02.eli_silo_thiswayg02" = "<clr:255,208,172>Come on, man."
		"ep_02.eli_silo_uh" = "<clr:255,208,172>Oh, it's nothing, honey."
		"ep_02.eli_silo_underwraps01" = "<clr:255,208,172>better than we thought"
		"ep_02.eli_silo_underwraps02" = "<clr:255,208,172>magnusson's done a remarkable job here."
		"ep_02.eli_silo_underwraps03" = "<clr:255,208,172>we're almost ready to put our first big piece into play."
		"ep_02.eli_silo_underwraps04" = "<clr:255,208,172>the combine won't see this coming."
		"ep_02.eli_silo_useit01" = "<clr:255,208,172>Use it?"
		"ep_02.eli_silo_useit02" = "<clr:255,208,172>That thing has to be destroyed!"
		"ep_02.eli_silo_welltalklater" = "<clr:255,208,172>We'll talk later, Gordon."
		"ep_02.eli_silo_whahappen" = "<clr:255,208,172>What happened to you?"
		"ep_02.eli_silo_whatisit" = "<clr:255,208,172>What is it, Izzy?  What have you got?"
		"ep_02.eli_silo_whatsay" = "<clr:255,208,172>What did you say?"
		"ep_02.eli_silo_wheresalyx01" = "<clr:255,208,172>Where's Alyx?"
		"ep_02.eli_silo_wheresalyx02" = "<clr:255,208,172>Alyx!"
		"ep_02.eli_silo_youheardkleiner01" = "<clr:255,208,172>Well, that's good, because, well..."
		"ep_02.eli_silo_youheardkleiner02" = "<clr:255,208,172>now that the suppression field is down..."
		"ep_02.eli_silo_youheardkleiner03" = "<clr:255,208,172>we all have to do our part."
		"ep_02.eli_silo_yousure01" = "<clr:255,208,172>Are you sure?  "
		"ep_02.eli_silo_yousure02" = "<clr:255,208,172>Shouldn't we have that looked at?"
		"ep_02.eli_transmit_believe01" = "<clr:255,208,172><I>Alyx! "
		"ep_02.eli_transmit_believe02" = "<clr:255,208,172><I>Thank God! "
		"ep_02.eli_transmit_believe03" = "<clr:255,208,172><I>I can hardly believe it. "
		"ep_02.eli_transmit_crawl01" = "<clr:255,208,172><I>It's the Combine. "
		"ep_02.eli_transmit_crawl02" = "<clr:255,208,172><I>They're trying to open another gateway. "
		"ep_02.eli_transmit_goodgod" = "<clr:255,208,172><I>Good God. "
		"ep_02.eli_transmit_rash01" = "<clr:255,208,172><I>Get here as quickly as you can, you two. "
		"ep_02.eli_transmit_rash02" = "<clr:255,208,172><I>But for God's sake, be careful. "
		"ep_02.eli_transmit_rash03" = "<clr:255,208,172><I>I'll be waiting for you.  "
		"ep_02.eli_transmit_rash04" = "<clr:255,208,172><I>Can't wait to see you."
		"ep_02.eli_transmit_sevenminutes01" = "<clr:255,208,172><I>It'll be the Seven Hour War, all over again. "
		"ep_02.eli_transmit_sevenminutes02" = "<clr:255,208,172><I>Except this time we won't last seven minutes. "
		"ep_02.gman_har" = "Ha ha..."
		"ep_02.gman_mono01" = "Doctor Freeman. "
		"ep_02.gman_mono02" = "I realize this moment may not be the most convenient for a heart-to-heart,"
		"ep_02.gman_mono03" = "but I had to wait until your friends were otherwise occupied. "
		"ep_02.gman_mono04" = "Hm. "
		"ep_02.gman_mono05" = "There was a time they cared nothing for Miss Vance..."
		"ep_02.gman_mono06" = "When their only experience of humanity was a crowbar coming at them down a steel corridor. "
		"ep_02.gman_mono07" = "It seems they've grown to share my estimation of her worth."
		"ep_02.gman_mono08" = "When I plucked her from Black Mesa, I acted in the face of objections that she was a mere child and of no practical use to anyone. "
		"ep_02.gman_mono09" = "I have learned to ignore such naysayers when quelling them was out of the question. "
		"ep_02.gman_mono10" = "[breathing]"
		"ep_02.gman_mono11" = "Still, I am not one to squander my investments..."
		"ep_02.gman_mono12" = "and I remain confident she was worth far more than the initial..."
		"ep_02.gman_mono13" = "appraisal. "
		"ep_02.gman_mono14" = "That's why I must now "
		"ep_02.gman_mono15" = "extract "
		"ep_02.gman_mono16" = "from you "
		"ep_02.gman_mono17" = "some small repayment owed for your own survival. "
		"ep_02.gman_mono18" = "I'm not asking for anything that goes against your nature."
		"ep_02.gman_mono19" = "Merely the favor of her continued protection,"
		"ep_02.gman_mono20" = "while she acts as"
		"ep_02.gman_mono21" = "medium for a message of some importance."
		"ep_02.gman_mono22" = "See her safely to White Forest, Doctor Freeman. "
		"ep_02.gman_mono23" = "She may require more care than was previously the case."
		"ep_02.gman_mono24" = "[breathing]"
		"ep_02.gman_mono25" = "I wish I could do more than keep an eye on you,"
		"ep_02.gman_mono26" = "but I have agreed to abide by certain... "
		"ep_02.gman_mono27" = "restrictions. "
		"ep_02.gman_mono28" = "Mmm."
		"ep_02.gman_mono29" = "Well..."
		"ep_02.gman_mono30" = "Now..."
		"ep_02.gman_mono31" = "Listen carefully, my dear."
		"ep_02.gman_mono32" = "When you see your father "
		"ep_02.gman_mono33" = "relay these words:"
		"ep_02.gman_mono34" = "Prepare for unforeseen consequences. "
		"ep_02.griggs_12crazy" = "<clr:255,216,150>12's going crazy!"
		"ep_02.griggs_24lit" = "<clr:255,216,150>24's lit up!"
		"ep_02.griggs_24swarm" = "<clr:255,216,150>Swarm at 24!"
		"ep_02.griggs_36again" = "<clr:255,216,150>36 again!"
		"ep_02.griggs_36majorswarm" = "<clr:255,216,150>Major swarm!"
		"ep_02.griggs_36overthere" = "<clr:255,216,150>Over there!"
		"ep_02.griggs_afteralyx" = "<clr:255,216,150>They're going after Alyx!"
		"ep_02.griggs_ahcrap" = "<clr:255,216,150>Ahh crap!"
		"ep_02.griggs_altvortarrive" = "<clr:255,216,150>Get ready, oh God, get ready, three lights, this is going to be bad...."
		"ep_02.griggs_and12" = "<clr:255,216,150>And 12!"
		"ep_02.griggs_and24" = "<clr:255,216,150>And 24!"
		"ep_02.griggs_and36" = "<clr:255,216,150>And 36!"
		"ep_02.griggs_andbreach" = "<clr:255,216,150>And the Breach!"
		"ep_02.griggs_at12" = "<clr:255,216,150>They're at 12!"
		"ep_02.griggs_at12again" = "<clr:255,216,150>They're at 12 again!"
		"ep_02.griggs_atbreach" = "<clr:255,216,150>They're at the breach!"
		"ep_02.griggs_awayfromvort" = "<clr:255,216,150>Get em away from the vort!"
		"ep_02.griggs_badturret" = "<clr:255,216,150>Oh, sorry.  We shoulda warned you about that turret."
		"ep_02.griggs_beadequate" = "<clr:255,216,150>Okay, Freeman!  Be adequate!"
		"ep_02.griggs_betweenwave_01" = "<clr:255,216,150>Freeman, you did avoid the grubs on the way in here, right?"
		"ep_02.griggs_betweenwave_02" = "<clr:255,216,150>Freeman, how many grubs did you step on?"
		"ep_02.griggs_betweenwave_03" = "<clr:255,216,150>I wasn't even supposed to be here."
		"ep_02.griggs_betweenwave_04" = "<clr:255,216,150>No offense Freeman, but things were pretty quiet until you showed up."
		"ep_02.griggs_betweenwave_05" = "<clr:255,216,150>I don't think that was the last of them."
		"ep_02.griggs_betweenwave_06" = "<clr:255,216,150>We'll be okay as long as they stick to one tunnel."
		"ep_02.griggs_betweenwave_07" = "<clr:255,216,150>If they start comin' out of more than one tunnel, we're cooked."
		"ep_02.griggs_betweenwave_08" = "<clr:255,216,150>You ready Freeman?"
		"ep_02.griggs_betweenwave_09" = "<clr:255,216,150>We can do this, right guys? Yeah, sure, we can do this."
		"ep_02.griggs_betweenwave_conver1_01" = "<clr:255,216,150>I got ten!"
		"ep_02.griggs_betweenwave_conver2_01" = "<clr:255,216,150>Sheckley!"
		"ep_02.griggs_betweenwave_conver2_02" = "<clr:255,216,150>Sheckley!"
		"ep_02.griggs_betweenwave_conver2_03" = "<clr:255,216,150>Forget it..."
		"ep_02.griggs_betweenwave_conver3_01" = "<clr:255,216,150>There can't be many more."
		"ep_02.griggs_betweenwave_conver4_01" = "<clr:255,216,150>I didn't see it."
		"ep_02.griggs_breachagain" = "<clr:255,216,150>The breach again!"
		"ep_02.griggs_bye01" = "<clr:255,216,150>See ya!  "
		"ep_02.griggs_bye02" = "<clr:255,216,150>Good luck out there"
		"ep_02.griggs_calvary" = "<clr:255,216,150>Looks like the calvary's here!"
		"ep_02.griggs_cantholdout" = "<clr:255,216,150>We can't hold out much longer."
		"ep_02.griggs_coming01" = "<clr:255,216,150>They're coming!"
		"ep_02.griggs_coming02" = "<clr:255,216,150>One light..."
		"ep_02.griggs_comingfrom24" = "<clr:255,216,150>They're coming from 24 again!"
		"ep_02.griggs_cover12" = "<clr:255,216,150>Cover 12!"
		"ep_02.griggs_cover24" = "<clr:255,216,150>Cover 24!"
		"ep_02.griggs_cover36" = "<clr:255,216,150>Cover 36!"
		"ep_02.griggs_covervort" = "<clr:255,216,150>Cover the vort!"
		"ep_02.griggs_dochelpvort" = "<clr:255,216,150>Doc, help the vort!"
		"ep_02.griggs_doctorin" = "<clr:255,216,150>Oh yeah.  Down there by the vort.  Everything you need for doctorin'."
		"ep_02.griggs_everywhere" = "<clr:255,216,150>Oh God, they're coming from everywhere!"
		"ep_02.griggs_fightlion_01" = "<clr:255,216,150>AHHHHH!"
		"ep_02.griggs_fightlion_02" = "<clr:255,216,150>Cover me, Sheck!"
		"ep_02.griggs_fightlion_03" = "<clr:255,216,150>Sheckley look out!"
		"ep_02.griggs_fightlion_04" = "<clr:255,216,150>Sheck, look out!"
		"ep_02.griggs_fightlion_05" = "<clr:255,216,150>Ah!  Ah!  AH! AH! AH!"
		"ep_02.griggs_followed01" = "<clr:255,216,150>Hey, Doc"
		"ep_02.griggs_followed02" = "<clr:255,216,150>on your way here...  "
		"ep_02.griggs_followed03" = "<clr:255,216,150>You weren't followed, were you?"
		"ep_02.griggs_following01" = "<clr:255,216,150>I'm with ya, I'm with ya."
		"ep_02.griggs_following02" = "<clr:255,216,150>I'm comin', I'm comin'."
		"ep_02.griggs_following03" = "<clr:255,216,150>I'm right behind ya."
		"ep_02.griggs_following04" = "<clr:255,216,150>Let's just stay here."
		"ep_02.griggs_followme01" = "<clr:255,216,150>C'mon, Sheckley, move it."
		"ep_02.griggs_followme02" = "<clr:255,216,150>Let's go, Sheck."
		"ep_02.griggs_followme03" = "<clr:255,216,150>Over here, Sheckley."
		"ep_02.griggs_followvortnag_01" = "<clr:255,216,150>Better get moving, Doc. Follow the Vort."
		"ep_02.griggs_followvortnag_02" = "<clr:255,216,150>Seriously, Freeman, you need to get going."
		"ep_02.griggs_followvortnag_03" = "<clr:255,216,150>Ms. Vance doesn't look so great, Doc. You better hurry up and follow the Vort."
		"ep_02.griggs_followvortnag_04" = "<clr:255,216,150>We're all tired, Freeman, but you can't just sit around here. Follow the Vort!"
		"ep_02.griggs_gohelpvort" = "<clr:255,216,150>Freeman, go help the vort!"
		"ep_02.griggs_gosheckley" = "<clr:255,216,150>Nice one, Sheckley!"
		"ep_02.griggs_grubs" = "<clr:255,216,150>The vort says as long as we don't step on their grubs, they shouldn't hear us this far from the nest..."
		"ep_02.griggs_gunnags01" = "<clr:255,216,150>Hey, Doc...spare gun here if you want it."
		"ep_02.griggs_gunnags02" = "<clr:255,216,150>Hey, Doc, you might want to grab a gun, down by the vort!"
		"ep_02.griggs_gunnags03" = "<clr:255,216,150>Hey, Doc, if you need a gun there's some down by the elevator.  Plenty for all!"
		"ep_02.griggs_incom36" = "<clr:255,216,150>Incoming at 36! "
		"ep_02.griggs_junc_extrahand" = "<clr:255,216,150>Hey, vorts, thanks!  We're sure glad for the extra hand!"
		"ep_02.griggs_junc_freemanlaughed" = "<clr:255,216,150>Ah, Freeman laughed a little.  I saw him."
		"ep_02.griggs_kaput" = "<clr:255,216,150>Oh no!  A turret just went kaput!"
		"ep_02.griggs_keepeye" = "<clr:255,216,150>Freeman! Keep your eye on the lights!"
		"ep_02.griggs_killlion_01" = "<clr:255,216,150>Hey Sheck, am I gonna have to kill all of these myself?"
		"ep_02.griggs_killlion_02" = "<clr:255,216,150>Yeah!"
		"ep_02.griggs_killlion_03" = "<clr:255,216,150>Yeah!"
		"ep_02.griggs_killlion_04" = "<clr:255,216,150>Stinkin' bugs!"
		"ep_02.griggs_lookalive" = "<clr:255,216,150>Look alive!"
		"ep_02.griggs_moreat12" = "<clr:255,216,150>More at 12!"
		"ep_02.griggs_moreat24" = "<clr:255,216,150>More at 24!"
		"ep_02.griggs_moreat36" = "<clr:255,216,150>More at 36!"
		"ep_02.griggs_moreatbreach" = "<clr:255,216,150>More at the breach!"
		"ep_02.griggs_needagun" = "<clr:255,216,150>Hey Doc, if you need a gun, there's extras around."
		"ep_02.griggs_needsomehelp" = "<clr:255,216,150>I might need some help on this one."
		"ep_02.griggs_nestbigger" = "<clr:255,216,150>That nest must be bigger than we thought."
		"ep_02.griggs_neverseen" = "<clr:255,216,150>Never seen this many all at once."
		"ep_02.griggs_onelight" = "<clr:255,216,150>One light!"
		"ep_02.griggs_onenoproblem" = "<clr:255,216,150>No problem."
		"ep_02.griggs_pickturretup" = "<clr:255,216,150>Pick your turret up!"
		"ep_02.griggs_protectvort" = "<clr:255,216,150>Protect the vort!"
		"ep_02.griggs_rightturret" = "<clr:255,216,150>Right that turret!"
		"ep_02.griggs_samediff" = "<clr:255,216,150>What's the difference?"
		"ep_02.griggs_sparegun" = "<clr:255,216,150>You might want to grab that extra gun, Doc!"
		"ep_02.griggs_swarmatbreach" = "<clr:255,216,150>Swarm at the breach!"
		"ep_02.griggs_thosevortswant" = "<clr:255,216,150>Don't look at me, I don't know what those vorts want"
		"ep_02.griggs_threelights" = "<clr:255,216,150>Three lights!  We got three lights!"
		"ep_02.griggs_threeomg" = "<clr:255,216,150>Oh my God!"
		"ep_02.griggs_threeswarm" = "<clr:255,216,150>Swarm!"
		"ep_02.griggs_thrubreach" = "<clr:255,216,150>They're coming through the breach!"
		"ep_02.griggs_toomany" = "<clr:255,216,150>Too many!"
		"ep_02.griggs_tryingtoscare" = "<clr:255,216,150>Yeah, I knew, I knew it, I was just tryin' to scare you, Sheck."
		"ep_02.griggs_tunnelpanic_01" = "<clr:255,216,150>Oh shit, the whole place is lit up. Grab a tunnel!"
		"ep_02.griggs_tunnelpanic_02" = "<clr:255,216,150>The whole place is lightin' up, grab a tunnel!"
		"ep_02.griggs_turretdown01" = "<clr:255,216,150>We got a turret down!"
		"ep_02.griggs_turretdown02" = "<clr:255,216,150>Turret, Doc!"
		"ep_02.griggs_turretfeet" = "<clr:255,216,150>Get those turrets back on their feet!"
		"ep_02.griggs_turretsturrets" = "<clr:255,216,150>Turrets!  Turrets!"
		"ep_02.griggs_twolights" = "<clr:255,216,150>Two lights."
		"ep_02.griggs_twothatmeans" = "<clr:255,216,150>That means two or three, right?"
		"ep_02.griggs_underest" = "<clr:255,216,150>I think we misunderestimated."
		"ep_02.griggs_vortintrouble" = "<clr:255,216,150>The VORT needs help!"
		"ep_02.griggs_vortscalling" = "<clr:255,216,150>The vorts are calling you."
		"ep_02.griggs_vortswantyou" = "<clr:255,216,150>I think the vorts want you down there."
		"ep_02.griggs_vortswouldsay" = "<clr:255,216,150>Ah, I dunno, sounds like something the vorts would say."
		"ep_02.griggs_watchall" = "<clr:255,216,150>Got to watch all the tunnels, Freeman!"
		"ep_02.griggs_watchvorts_01" = "<clr:255,216,150>Sheck! Stay back and give the Vorts room to work!"
		"ep_02.griggs_watchvorts_02" = "<clr:255,216,150>The Vorts are tearin' 'em up!"
		"ep_02.griggs_watchvorts_03" = "<clr:255,216,150>Those bugs sure messed with the wrong slugs."
		"ep_02.griggs_watchvorts_04" = "<clr:255,216,150>Jesus, I've never seen the Vorts this pissed."
		"ep_02.griggs_wecandothis" = "<clr:255,216,150>More lights, we can do this."
		"ep_02.griggs_wegot_12_01" = "<clr:255,216,150>We got 12!"
		"ep_02.griggs_wegot_12_02" = "<clr:255,216,150>We'll take 12!"
		"ep_02.griggs_wegot_24_01" = "<clr:255,216,150>We got 24!"
		"ep_02.griggs_wegot_24_02" = "<clr:255,216,150>We'll take 24!"
		"ep_02.griggs_wegot_36_01" = "<clr:255,216,150>We got 36!"
		"ep_02.griggs_wegot_36_02" = "<clr:255,216,150>We'll take 36!"
		"ep_02.griggs_wegot_breach01" = "<clr:255,216,150>We got the breach!"
		"ep_02.griggs_wegot_breach02" = "<clr:255,216,150>We'll take the breach!"
		"ep_02.griggs_wegotantlions01" = "<clr:255,216,150>Sheckley!"
		"ep_02.griggs_wegotantlions02" = "<clr:255,216,150>We got antlions!"
		"ep_02.griggs_whysomany" = "<clr:255,216,150>Why are there so many?"
		"ep_02.griggs_wronghole" = "<clr:255,216,150>What was wrong with that hole?"
		"ep_02.griggs_youtake_12_01" = "<clr:255,216,150>Hey doc, you cover 12!"
		"ep_02.griggs_youtake_12_02" = "<clr:255,216,150>You handle 12, Doc!"
		"ep_02.griggs_youtake_24_01" = "<clr:255,216,150>Hey doc, you cover 24!"
		"ep_02.griggs_youtake_24_02" = "<clr:255,216,150>You handle 24, Doc!"
		"ep_02.griggs_youtake_36_01" = "<clr:255,216,150>Hey doc, you cover 36!"
		"ep_02.griggs_youtake_36_02" = "<clr:255,216,150>You handle 36, Doc!"
		"ep_02.griggs_youtake_breach_01" = "<clr:255,216,150>Hey doc, you cover the breach!"
		"ep_02.griggs_youtake_breach_02" = "<clr:255,216,150>You handle the breach, Doc!"
		"ep_02.griggs_youturrets" = "<clr:255,216,150>Dr. Freeman, you take care of the turrets."
		"ep_02.kl_launch_1" = "<clr:255,255,200>One..."
		"ep_02.kl_launch_10" = "<clr:255,255,200>T minus ten..."
		"ep_02.kl_launch_2" = "<clr:255,255,200>Two..."
		"ep_02.kl_launch_3" = "<clr:255,255,200>Three..."
		"ep_02.kl_launch_4" = "<clr:255,255,200>Four..."
		"ep_02.kl_launch_5" = "<clr:255,255,200>Five..."
		"ep_02.kl_launch_6" = "<clr:255,255,200>Six..."
		"ep_02.kl_launch_7" = "<clr:255,255,200>Seven..."
		"ep_02.kl_launch_8" = "<clr:255,255,200>Eight..."
		"ep_02.kl_launch_9" = "<clr:255,255,200>Nine..."
		"ep_02.kl_launch_anomaly01" = "<clr:255,255,200>Wait a moment..."
		"ep_02.kl_launch_anomaly02" = "<clr:255,255,200>I'm seeing a payload anomaly of approximately eight and a half pounds."
		"ep_02.kl_launch_atlast" = "<clr:255,255,200>At last!"
		"ep_02.kl_launch_awe01" = "<clr:255,255,200>[Sounds of wordless awe]"
		"ep_02.kl_launch_awe02" = "<clr:255,255,200>Great Scott!"
		"ep_02.kl_launch_awe03" = "<clr:255,255,200>Look at it go!"
		"ep_02.kl_launch_awe04" = "<clr:255,255,200>Yes!"
		"ep_02.kl_launch_awe05" = "<clr:255,255,200>Yes!"
		"ep_02.kl_launch_awe06" = "<clr:255,255,200>[Sounds of wordless awe]"
		"ep_02.kl_launch_awe07" = "<clr:255,255,200>Look!"
		"ep_02.kl_launch_awe08" = "<clr:255,255,200>Look!"
		"ep_02.kl_launch_awe09" = "<clr:255,255,200>Fly, you beautiful bird!"
		"ep_02.kl_launch_awe10" = "<clr:255,255,200>Oh..."
		"ep_02.kl_launch_awe11" = "<clr:255,255,200>There it goes..."
		"ep_02.kl_launch_awe12" = "<clr:255,255,200>We're off!"
		"ep_02.kl_launch_awe13" = "<clr:255,255,200>Yes."
		"ep_02.kl_launch_awe14" = "<clr:255,255,200>Yes."
		"ep_02.kl_launch_bestofluck01" = "<clr:255,255,200>Of course."
		"ep_02.kl_launch_bestofluck02" = "<clr:255,255,200>Best of luck, you two."
		"ep_02.kl_launch_button01" = "<clr:255,255,200>The button, Gordon?  "
		"ep_02.kl_launch_button02" = "<clr:255,255,200>Oh...  "
		"ep_02.kl_launch_button03" = "<clr:255,255,200>If you don't mind?"
		"ep_02.kl_launch_check01a" = "<clr:255,255,200><I>Tested and operational."
		"ep_02.kl_launch_check01b" = "<clr:255,255,200><I>What's this one? ''Flight termination system...check links with backup range safety sites...''?"
		"ep_02.kl_launch_check02" = "<clr:255,255,200><I>Pre-flight alignment complete."
		"ep_02.kl_launch_check03" = "<clr:255,255,200><I>Check."
		"ep_02.kl_launch_check04" = "<clr:255,255,200><I>Check-check-check."
		"ep_02.kl_launch_check05" = "<clr:255,255,200><I>Did you do that?"
		"ep_02.kl_launch_check06" = "<clr:255,255,200><I>Completed, of course."
		"ep_02.kl_launch_check07" = "<clr:255,255,200><I>Well, the precision of those readings is not to my liking, but we'll have to make do with what we have."
		"ep_02.kl_launch_check08" = "<clr:255,255,200><I>Reporting normal."
		"ep_02.kl_launch_check09" = "<clr:255,255,200><I>Naturally, some time ago."
		"ep_02.kl_launch_check10" = "<clr:255,255,200><I>Of course."
		"ep_02.kl_launch_check11" = "<clr:255,255,200><I>No, of course not."
		"ep_02.kl_launch_check12" = "<clr:255,255,200><I>Yes, yes."
		"ep_02.kl_launch_congrats01" = "<clr:255,255,200><I>attention, your attention please. Congratulations to the staff and residents of white forest."
		"ep_02.kl_launch_congrats02" = "<clr:255,255,200><I>woodland creatures excepted"
		"ep_02.kl_launch_curtail01" = "<clr:255,255,200><I>although we hate to curtail the spontaneous festivities or otherwise interfere with the celebratory air"
		"ep_02.kl_launch_curtail02" = "<clr:255,255,200><I>we must ask all personnel to take cover immediately in order to ensure the vicinity is clear for launch"
		"ep_02.kl_launch_curtail03" = "<clr:255,255,200><I>it would certainly put a dampen on the natural outpourings of goodwill if any of our stalwarts were rendered crispy in the super-heated flames of the victory launch"
		"ep_02.kl_launch_excuseme01" = "<clr:255,255,200>Excuse me."
		"ep_02.kl_launch_excuseme02" = "<clr:255,255,200>Pardon me."
		"ep_02.kl_launch_excuseme03" = "<clr:255,255,200>Excuse me, Gordon."
		"ep_02.kl_launch_fever01" = "<clr:255,255,200>I believe I've just learned the meaning of the phenomenon described as feverish anticipation"
		"ep_02.kl_launch_fever02" = "<clr:255,255,200>I've always believed it a figure of speech"
		"ep_02.kl_launch_fever03" = "<clr:255,255,200>but suddenly I'm"
		"ep_02.kl_launch_fever04" = "<clr:255,255,200>quite warm"
		"ep_02.kl_launch_finger" = "<clr:255,255,200>We await only the push of a highly trained finger."
		"ep_02.kl_launch_fruition01" = "<clr:255,255,200>the fruition of your many years of service and devotion are about to reach their culmination"
		"ep_02.kl_launch_fruition02" = "<clr:255,255,200>we fully expect this to be a glorious and transcendent moment for human civilization."
		"ep_02.kl_launch_high5a" = "<clr:255,255,200>Well, I, oh--"
		"ep_02.kl_launch_high5b" = "<clr:255,255,200>yes indeed"
		"ep_02.kl_launch_high5c" = "<clr:255,255,200>very nice"
		"ep_02.kl_launch_high5d" = "<clr:255,255,200>I suppose there's something to be said for physical reinforcement of the intellectual bond."
		"ep_02.kl_launch_high5e" = "<clr:255,255,200>[sniff]"
		"ep_02.kl_launch_lamarr01" = "<clr:255,255,200>Now...hm...  "
		"ep_02.kl_launch_lamarr02" = "<clr:255,255,200>Has anyone seen Lamarr?"
		"ep_02.kl_launch_lookup01" = "<clr:255,255,200><I>Eli!  Gordon! Alyx!  Look at the portal"
		"ep_02.kl_launch_lookup02" = "<clr:255,255,200><I>We've activated the resonator."
		"ep_02.kl_launch_lookup03" = "<clr:255,255,200><I>This is it!  "
		"ep_02.kl_launch_morelamarr01" = "<clr:255,255,200>Lamarr?"
		"ep_02.kl_launch_morelamarr02" = "<clr:255,255,200>Lamarr?"
		"ep_02.kl_launch_morelamarr03" = "<clr:255,255,200>Lamarr?"
		"ep_02.kl_launch_morelamarr04" = "<clr:255,255,200>Where the devil have you gotten to?"
		"ep_02.kl_launch_morelamarr05" = "<clr:255,255,200>Hedy?"
		"ep_02.kl_launch_morelamarr06" = "<clr:255,255,200>Oh dear..."
		"ep_02.kl_launch_morelamarr07" = "<clr:255,255,200>Has anyone seen Lamarr?"
		"ep_02.kl_launch_neverfear01" = "<clr:255,255,200>Just as soon as this is wrapped up."
		"ep_02.kl_launch_neverfear02" = "<clr:255,255,200>I wouldn't dream of letting you go without a proper goodbye!"
		"ep_02.kl_launch_palamarr" = "<clr:255,255,200>Attention, attention, all personnel.  Has anyone seen Lamarr?"
		"ep_02.kl_launch_permorbit01" = "<clr:255,255,200>the payload capsule itself will not enter a permanent orbit until sometime afterward"
		"ep_02.kl_launch_permorbit02" = "<clr:255,255,200>here."
		"ep_02.kl_launch_permorbit03" = "<clr:255,255,200>at which point we can test the stability of the system"
		"ep_02.kl_launch_permorbit04" = "<clr:255,255,200>however, we should see the first effects almost immediately."
		"ep_02.kl_launch_portalclosing01" = "<clr:255,255,200><I>My goodness..."
		"ep_02.kl_launch_portalclosing02" = "<clr:255,255,200><I>Oh - look at that!"
		"ep_02.kl_launch_portalclosing03" = "<clr:255,255,200><I>The resonator seems to be taking hold."
		"ep_02.kl_launch_portalclosing04" = "<clr:255,255,200><I>The portal has been neutralized!"
		"ep_02.kl_launch_portalclosing05" = "<clr:255,255,200><I>Spectacular"
		"ep_02.kl_launch_portalclosing06" = "<clr:255,255,200><I>What a relief."
		"ep_02.kl_launch_portalclosing07" = "<clr:255,255,200><I>Marvelous."
		"ep_02.kl_launch_portalclosing08" = "<clr:255,255,200><I>Well doesn't that beat all."
		"ep_02.kl_launch_portalclosing09" = "<clr:255,255,200><I>There's hope after all."
		"ep_02.kl_launch_portalclosing10" = "<clr:255,255,200><I>Safe again...for a time."
		"ep_02.kl_launch_portalclosing11" = "<clr:255,255,200><I>I confess, I...had my doubts."
		"ep_02.kl_launch_portalclosing12" = "<clr:255,255,200><I>Yes, yes, we can all be proud of the effort---"
		"ep_02.kl_launch_portalclosing13" = "<clr:255,255,200><I>Now, Magnusson---"
		"ep_02.kl_launch_right01" = "<clr:255,255,200>That's right.  "
		"ep_02.kl_launch_right02" = "<clr:255,255,200>If you please."
		"ep_02.kl_launch_shortly01" = "<clr:255,255,200>I'm sure he'll be along shortly."
		"ep_02.kl_launch_shortly02" = "<clr:255,255,200>This is rather unlike him."
		"ep_02.kl_launch_show01" = "<clr:255,255,200>Once the rocket is in range of the portal, we'll be able to switch on the xenium resonator.  "
		"ep_02.kl_launch_show02" = "<clr:255,255,200>There should be quite a show.  Regrettably, I can't come out with you."
		"ep_02.kl_launch_show03" = "<clr:255,255,200>Magnusson and I will need to keep a close eye on the rocket's trajectory"
		"ep_02.kl_launch_show04" = "<clr:255,255,200>So you can see"
		"ep_02.kl_launch_show05" = "<clr:255,255,200>here"
		"ep_02.kl_launch_show06" = "<clr:255,255,200>once we reach altitude, the existing satellite array will begin to reactivate."
		"ep_02.kl_launch_sigh" = "<clr:255,255,200>[sigh...]"
		"ep_02.kl_launch_signoff01" = "<clr:255,255,200>All right, just let us secure our instruments and we will be over to see you off."
		"ep_02.kl_launch_signoff02" = "<clr:255,255,200>Thank you, everyone.  Signing off."
		"ep_02.kl_launch_skyawe01" = "<clr:255,255,200>Oh!"
		"ep_02.kl_launch_skyawe02" = "<clr:255,255,200>Marvelous"
		"ep_02.kl_launch_skyawe03" = "<clr:255,255,200>Magnificent!"
		"ep_02.kl_launch_skyawe04" = "<clr:255,255,200>Ah, spectacular!"
		"ep_02.kl_launch_skyawe05" = "<clr:255,255,200>Oh, I hope Lamarr is watching"
		"ep_02.kl_launch_skyawe06" = "<clr:255,255,200>Oh..."
		"ep_02.kl_launch_skyawe07" = "<clr:255,255,200>Beautiful"
		"ep_02.kl_launch_skyawe08" = "<clr:255,255,200>splendid!  Magnificent!"
		"ep_02.kl_launch_skyawe09" = "<clr:255,255,200>Oh, the corona!"
		"ep_02.kl_launch_theirsuccess" = "<clr:255,255,200>Yes, well, I think perhaps Gordon had something to do with their success."
		"ep_02.kl_launch_ticking01" = "<clr:255,255,200>Too right!  "
		"ep_02.kl_launch_ticking02" = "<clr:255,255,200>The clock is ticking."
		"ep_02.kl_launch_use01" = "<clr:255,255,200>I can't be bothered right now."
		"ep_02.kl_launch_use02" = "<clr:255,255,200>You will just have to wait until after the launch."
		"ep_02.kl_launch_valiant01" = "<clr:255,255,200>You'll hear no objection from me."
		"ep_02.kl_launch_valiant02" = "<clr:255,255,200>The launch would be all but impossible without his valiant efforts."
		"ep_02.kl_launch_waxing01" = "<clr:255,255,200>[sniff]"
		"ep_02.kl_launch_waxing02" = "<clr:255,255,200>Gracious!"
		"ep_02.kl_launch_wedidit" = "<clr:255,255,200>We did it!"
		"ep_02.kl_launch_wogordon" = "<clr:255,255,200>Well, we can't proceed without Gordon."
		"ep_02.kl_silo_agreed01" = "<clr:255,255,200>Agreed!"
		"ep_02.kl_silo_agreed02" = "<clr:255,255,200>The Combine encroaches."
		"ep_02.kl_silo_arrived" = "<clr:255,255,200>Good grief!  Eli!  Why didn't you tell me they'd arrived?"
		"ep_02.kl_silo_auxil" = "<clr:255,255,200>and then we can view it in the auxiliary control room."
		"ep_02.kl_silo_auxil02" = "<clr:255,255,200>and then we can view it in the auxiliary control room."
		"ep_02.kl_silo_berightthere" = "<clr:255,255,200>I'll hurry it along, Magnusson. "
		"ep_02.kl_silo_auxil01" = "<clr:255,255,200>Just let me start the decoding process,"
		"ep_02.kl_silo_comein" = "<clr:255,255,200>Eli, Eli?  Are you there?"
		"ep_02.kl_silo_delight" = "<clr:255,255,200>My dear, what a relief--not to mention a delight--to see you here at last!  "
		"ep_02.kl_silo_devised01" = "<clr:255,255,200>Indeed yes."
		"ep_02.kl_silo_devised02" = "<clr:255,255,200>magnusson designed a xenium resonator that once in orbital range will activate the old array and effectively turn it into a shield."
		"ep_02.kl_silo_devised03" = "<clr:255,255,200>with sub dimensional properties."
		"ep_02.kl_silo_emergency01" = "<clr:255,255,200>oh dear.  On second thought, maybe you shouldn't send gordon just yet."
		"ep_02.kl_silo_emergency02" = "<clr:255,255,200>what's that?"
		"ep_02.kl_silo_emergency03" = "<clr:255,255,200>well I can't let him in"
		"ep_02.kl_silo_emergency04" = "<clr:255,255,200>the emergency doors will have sealed up tight."
		"ep_02.kl_silo_emergency05" = "<clr:255,255,200>oh fie!"
		"ep_02.kl_silo_emergency06" = "<clr:255,255,200>There's been a breach"
		"ep_02.kl_silo_emergency07" = "<clr:255,255,200>I hope magnusson's provided for contingencies"
		"ep_02.kl_silo_fiethecode01" = "<clr:255,255,200>Oh fie, the code.   "
		"ep_02.kl_silo_fiethecode02" = "<clr:255,255,200>Yes, Magnusson, it just needs a little bit longer! "
		"ep_02.kl_silo_findus" = "<clr:255,255,200>You'll find us in the auxiliary control room."
		"ep_02.kl_silo_fond01" = "<clr:255,255,200>As you're so fond of pointing out"
		"ep_02.kl_silo_fond02" = "<clr:255,255,200>you've gotten this far without us."
		"ep_02.kl_silo_givenup01" = "<clr:255,255,200>Oh yes, quite real, despite its almost legendary stature.  "
		"ep_02.kl_silo_givenup02" = "<clr:255,255,200>Our peers at Aperture Science were at work on a project of some promise, but in their rush to beat Black Mesa for funding, they must have compromised ordinary standards of risk.  We heard their research vessel had simply disappeared.  Vanished-with all hands... even part of the dry dock!"
		"ep_02.kl_silo_givenup03" = "<clr:255,255,200>Few believed the Borealis would ever be seen again."
		"ep_02.kl_silo_goingover01" = "<clr:255,255,200>yes, I'll give it a thorough going over when time permits but first..."
		"ep_02.kl_silo_goingover02" = "<clr:255,255,200>let me find the transmission"
		"ep_02.kl_silo_goldmine01" = "<clr:255,255,200>Well, yes, there's always a risk, Eli."
		"ep_02.kl_silo_goldmine01a" = "<clr:255,255,200>Well..."
		"ep_02.kl_silo_goldmine01b" = "<clr:255,255,200>Yes..."
		"ep_02.kl_silo_goldmine01c" = "<clr:255,255,200>There's always a risk, Eli."
		"ep_02.kl_silo_goldmine02" = "<clr:255,255,200>But my goodness, we have coordinates...blueprints...hailing frequencies...  "
		"ep_02.kl_silo_goldmine03" = "<clr:255,255,200>Quite ingenious of Dr. Mossman, to hide it all in the carrier wave."
		"ep_02.kl_silo_headway01" = "<clr:255,255,200>Well, it's all but certain she found borealis"
		"ep_02.kl_silo_headway02" = "<clr:255,255,200>It bears all the hallmarks of Aperture Science."
		"ep_02.kl_silo_headway03" = "<clr:255,255,200>however, I've made very little headway with the data itself"
		"ep_02.kl_silo_headway04" = "<clr:255,255,200>I could use Gordon's assistance, if you could spare him."
		"ep_02.kl_silo_hev" = "<clr:255,255,200>And Gordon.  I see you and the HEV suit have taken excellent care of each other."
		"ep_02.kl_silo_hm" = "<clr:255,255,200>Hmmm."
		"ep_02.kl_silo_idontbelieveit01" = "<clr:255,255,200>[Gasp!]  It's the...Borealis!  "
		"ep_02.kl_silo_incredible" = "<clr:255,255,200>Incredible!"
		"ep_02.kl_silo_inorder01" = "<clr:255,255,200>Everything seems to be in order.  "
		"ep_02.kl_silo_inorder02" = "<clr:255,255,200>I only wonder..."
		"ep_02.kl_silo_ionlymeant" = "<clr:255,255,200>Good grief, I only meant they might..."
		"ep_02.kl_silo_ireally" = "<clr:255,255,200>But  we don't know for sure---"
		"ep_02.kl_silo_keeponthis" = "<clr:255,255,200>I'll be back as soon as I finish."
		"ep_02.kl_silo_least" = "<clr:255,255,200>The least he could do is say hello."
		"ep_02.kl_silo_lookaround01" = "<clr:255,255,200>it appears gordon wishes to examine the so called spearhead missile."
		"ep_02.kl_silo_lookaround02" = "<clr:255,255,200>Why, his restless spirit embodies the very essence of scientific inquiry."
		"ep_02.kl_silo_lookaround03" = "<clr:255,255,200>He reminds me so much of myself at his age."
		"ep_02.kl_silo_neverfear01" = "<clr:255,255,200>and so we shall."
		"ep_02.kl_silo_neverfear02" = "<clr:255,255,200>I'll get right to work on the analysis"
		"ep_02.kl_silo_nevermind" = "<clr:255,255,200>Well, never mind him."
		"ep_02.kl_silo_nostoppingher" = "<clr:255,255,200>There was no stopping her, Eli."
		"ep_02.kl_silo_noweli01" = "<clr:255,255,200>Now, Eli...  The only thing worse than Judith falling into their hands would be if they should get a hold of you.  She may know the particulars of the Borealis, but you...you know everything about the resistance!"
		"ep_02.kl_silo_nowfound" = "<clr:255,255,200>Ah, but now that we've found it, we can use it against the Combine!"
		"ep_02.kl_silo_nowmag" = "<clr:255,255,200>Now listen here, Magnusson, there's no call for hurtful comments."
		"ep_02.kl_silo_nowmag01" = "<clr:255,255,200>Now listen here, Magnusson."
		"ep_02.kl_silo_nowmag02" = "<clr:255,255,200>There's no call for hurtful comments."
		"ep_02.kl_silo_nownow01" = "<clr:255,255,200>Don't worry, Eli."
		"ep_02.kl_silo_nownow02" = "<clr:255,255,200>I'm sure Dr. Mossman is all right."
		"ep_02.kl_silo_nownow03" = "<clr:255,255,200>She's nothing if not resourceful."
		"ep_02.kl_silo_onceinplace01" = "<clr:255,255,200>once in place, it will block combine access to earth, even if they do manage to restore their portal network"
		"ep_02.kl_silo_onceinplace02" = "<clr:255,255,200>which is starting to seem ever more likely."
		"ep_02.kl_silo_rawtrans01" = "<clr:255,255,200>why, even a fragment of a raw transmission will give us penetrating insight into"
		"ep_02.kl_silo_rawtrans02" = "<clr:255,255,200>well, it's unimaginable."
		"ep_02.kl_silo_rawtrans03" = "<clr:255,255,200>and it's all right here you say?"
		"ep_02.kl_silo_reunion01" = "<clr:255,255,200>I can't get over this"
		"ep_02.kl_silo_reunion02" = "<clr:255,255,200>it's as if we've brought back the original black mesa science team for a grand reunion."
		"ep_02.kl_silo_reunion03" = "<clr:255,255,200>minus one or two titular functionaries we are almost certainly better without"
		"ep_02.kl_silo_samearray01" = "<clr:255,255,200>yes, the array has lain dormant since you so ably annihilated the nihilanth."
		"ep_02.kl_silo_samearray02" = "<clr:255,255,200>however, recently we've hit upon a brilliant plan to reverse the portal's polarity"
		"ep_02.kl_silo_sayinghello01" = "<clr:255,255,200>All right, all right.  "
		"ep_02.kl_silo_sayinghello02" = "<clr:255,255,200>I was just saying hello to Alyx and Gordon."
		"ep_02.kl_silo_sendhim" = "<clr:255,255,200>go ahead and send him through."
		"ep_02.kl_silo_shoulddoit" = "<clr:255,255,200>ah, this should do it."
		"ep_02.kl_silo_signature01" = "<clr:255,255,200>unfortunately, it's impossible to do more than guess at that portal's specific signature."
		"ep_02.kl_silo_signature02" = "<clr:255,255,200>at least until they've reestablished contact with the combine overworld."
		"ep_02.kl_silo_signature03" = "<clr:255,255,200>at which time it would be too late to prevent reinvasion."
		"ep_02.kl_silo_signature04" = "<clr:255,255,200>if we knew the signal characteristics we could selectively block combine access while allowing ourselves to teleport freely."
		"ep_02.kl_silo_signature05" = "<clr:255,255,200>but, that is such a remote possibility"
		"ep_02.kl_silo_signature06" = "<clr:255,255,200>none dare bank upon it."
		"ep_02.kl_silo_smallcrew" = "<clr:255,255,200>she took a small crew and flew north... shortly after we flew to white forest."
		"ep_02.kl_silo_somethingelse01" = "<clr:255,255,200>Wait a moment..."
		"ep_02.kl_silo_somethingelse02" = "<clr:255,255,200>There's something else here."
		"ep_02.kl_silor_superb" = "<clr:255,255,200>superb work in delaying the citadel core reaction, you two! It must have been quite exciting."
		"ep_02.kl_silo_thereweare" = "<clr:255,255,200>There we are."
		"ep_02.kl_silo_tour" = "<clr:255,255,200>you can give him the full tour later, magnusson"
		"ep_02.kl_silo_trove01" = "<clr:255,255,200>well, this is quite the treasure trove"
		"ep_02.kl_silo_trove02" = "<clr:255,255,200>it would appear you've plundered the citadel storehouse like a pair of latter-day data pirates"
		"ep_02.kl_silo_trove02_alt" = "<clr:255,255,200>it would appear you've plundered the citadel storehouse like a"
		"ep_02.kl_silo_waste01" = "<clr:255,255,200>But think of the advantage for humanity! We can't simply waste all that potential.  "
		"ep_02.kl_silo_wellseeyou" = "<clr:255,255,200>We'll see you in the auxiliary control room."
		"ep_02.kl_silo_whatmean" = "<clr:255,255,200>my dear, what do you mean?"
		"ep_02.kl_silo_whatsthis" = "<clr:255,255,200>what's this?"
		"ep_02.kl_silo_wheredata01" = "<clr:255,255,200>Oh, never mind him."
		"ep_02.kl_silo_wheredata02" = "<clr:255,255,200>Now, my dear, where is this data packet you've been carrying? "
		"ep_02.kl_silo_wheredata03" = "<clr:255,255,200>If I delay a single moment, I'll never hear the end of it."
		"ep_02.kl_transmit_callmag01" = "<clr:255,255,200><I>Magnusson, did you hear that? "
		"ep_02.kl_transmit_callmag02" = "<clr:255,255,200><I>I'll bet it's the Combine portal code! "
		"ep_02.kl_transmit_data" = "<clr:255,255,200><I>Data? From the Citadel? "
		"ep_02.kl_transmit_goodness" = "<clr:255,255,200><I>Alyx - my goodness - is that really you? "
		"ep_02.kl_transmit_monitor" = "<clr:255,255,200><I>Oh yes, we've been monitoring the situation. The raw discharge of the melt-down has been focused into a coherent beam of portal energy. "
		"ep_02.kl_transmit_neversaid" = "<clr:255,255,200><I>Well, I can see that, I never said- "
		"ep_02.kl_transmit_superportal01" = "<clr:255,255,200><I>Yes. What you're seeing is the infancy of a superportal. "
		"ep_02.kl_transmit_superportal02" = "<clr:255,255,200><I>If it attains full strength... "
		"ep_02.kl_silo_yesyes" = "<clr:255,255,200>Yes, yes!  Of course!"
		"ep_02.kl_silo_resume" = "<clr:255,255,200>Shall we resume?"
		"ep_02.mag_aband_apex01" = "<clr:209,178,178><I>Freeman"
		"ep_02.mag_aband_apex02" = "<clr:209,178,178><I>Freeman can you hear me?"
		"ep_02.mag_aband_apex03" = "<clr:209,178,178><I>The base is vulnerable until you find the controls and shut the overhead door assembly."
		"ep_02.mag_aband_assume01" = "<clr:209,178,178><I>Freeman..."
		"ep_02.mag_aband_assume02" = "<clr:209,178,178><I>Freeman, I'm going to assume you are in the secondary silo and able to hear me."
		"ep_02.mag_aband_assume03" = "<clr:209,178,178><I>I have identified the overhead launch door assembly as the source of the breach."
		"ep_02.mag_aband_assume04" = "<clr:209,178,178><I>Move toward the top of the launch tube and take all necessary steps to seal the area."
		"ep_02.mag_aband_critical" = "<clr:209,178,178><I>Attention, Freeman!  It is critical that you seal the overhead silo doors and stop this infiltration!"
		"ep_02.mag_aband_dearbreach" = "<clr:209,178,178><I>Oh my god!  Oh dear.  This is a breach.  A breach!"
		"ep_02.mag_aband_decom01" = "<clr:209,178,178><I>Freeman, I repeat!  There has been a breach of the secondary silo by way of the overhead launch doors."
		"ep_02.mag_aband_decom02" = "<clr:209,178,178><I>I will trust you to seal the silo doors."
		"ep_02.mag_aband_dontanswer" = "<clr:209,178,178><I>If not...don't answer."
		"ep_02.mag_aband_fiends01" = "<clr:209,178,178><I>These feathered fiends are the most persistent I've ever...  "
		"ep_02.mag_aband_fiends02" = "<clr:209,178,178><I>Wait... What is this?"
		"ep_02.mag_aband_forgordsake" = "<clr:209,178,178><I>If you can hear me, Freeman, for god's sake close the overhead silo doors!"
		"ep_02.mag_aband_freeman" = "<clr:209,178,178><I>Freeman? Freeman, I hope you can hear me.  This is Dr. Magnusson."
		"ep_02.mag_aband_notcrows" = "<clr:209,178,178><I>Not crows, people!  Combine!"
		"ep_02.mag_aband_ominous" = "<clr:209,178,178><I>I'm beginning to think that something more ominous than crows is..."
		"ep_02.mag_aband_onceagain01" = "<clr:209,178,178><I>Freeman!"
		"ep_02.mag_aband_onceagain02" = "<clr:209,178,178><I>Freeman!  Have you heard a word I've been saying?  "
		"ep_02.mag_aband_onceagain03" = "<clr:209,178,178><I>It's up to you to seal the launch doors!"
		"ep_02.mag_aband_pinpoint" = "<clr:209,178,178><I>Attention! Attention, personnel!  This is Dr. Magnusson.  We are experiencing a breach of internal base defenses.  Please bear with us while we pinpoint the location of the breach.  "
		"ep_02.mag_aband_pleased" = "<clr:209,178,178><I>This is Dr. Magnusson. And I am pleased to announce the secondary silo has been sealed.  Well!  Back to work!"
		"ep_02.mag_aband_popular01" = "<clr:209,178,178><I>Attention, personnel."
		"ep_02.mag_aband_popular02" = "<clr:209,178,178><I>This is Dr. Magnusson!"
		"ep_02.mag_aband_popular03" = "<clr:209,178,178><I>Since the secondary silo staff seem incapable of solving their little crow problem, you will be happy to hear we have put the popular Dr. Freeman on the job.  We all look forward to his remedy.  "
		"ep_02.mag_aband_popular04" = "<clr:209,178,178><I>And I look forward to hearing the staff's excuses for why they couldn't handle it themselves."
		"ep_02.mag_aband_popular05" = "<clr:209,178,178><I>Thank you for your patience."
		"ep_02.mag_aband_racket" = "<clr:209,178,178><I>For God's sake, Freeman, what is taking you so long?  Oh, I cannot concentrate with all of this racket!"
		"ep_02.mag_aband_stillalive" = "<clr:209,178,178><I>Is anyone still alive in there?"
		"ep_02.mag_aband_stillthere" = "<clr:209,178,178><I>Freeman!  Are you still in the secondary silo?"
		"ep_02.mag_launch_check01" = "<clr:209,178,178><I>Telemetry data links."
		"ep_02.mag_launch_check02" = "<clr:209,178,178><I>That must be an ancient entry.  There are no backup sites.  If we fail, the best we can hope is that the rocket falls on the enemy.  Now...inertial navigation systems..."
		"ep_02.mag_launch_check03" = "<clr:209,178,178><I>Tracking beacon...there's another bit of cruft we can ignore.  Support equipment powered down."
		"ep_02.mag_launch_check04" = "<clr:209,178,178><I>Satellite payload powered and ready..."
		"ep_02.mag_launch_check05" = "<clr:209,178,178><I>Already closed out launch support equipment checklist..."
		"ep_02.mag_launch_check06" = "<clr:209,178,178><I>Safety test of FTS..."
		"ep_02.mag_launch_check07" = "<clr:209,178,178><I>Ground and high-altitude winds..."
		"ep_02.mag_launch_check08" = "<clr:209,178,178><I>Guidance computer voltages and currents..."
		"ep_02.mag_launch_check09" = "<clr:209,178,178><I>FTS switched over to internal power."
		"ep_02.mag_launch_check10" = "<clr:209,178,178><I>And armed?"
		"ep_02.mag_launch_check11" = "<clr:209,178,178><I>Don't ever say ''of course.''  We can't take anything for granted!"
		"ep_02.mag_launch_check12a" = "<clr:209,178,178><I>[Sigh]"
		"ep_02.mag_launch_check12b" = "<clr:209,178,178><I>Avionics to internal power?"
		"ep_02.mag_launch_chitchat01" = "<clr:209,178,178>Ahem... Well, that's enough chitchat. "
		"ep_02.mag_launch_chitchat02" = "<clr:209,178,178>I've got a rocket to launch. "
		"ep_02.mag_launch_cutclose" = "<clr:209,178,178><I>We couldn't have cut it any closer if that was our intention. "
		"ep_02.mag_launch_doitmyself" = "<clr:209,178,178><I>Hurry up or I'll do it myself! "
		"ep_02.mag_launch_flawless01" = "<clr:209,178,178>Ah, Freeman. "
		"ep_02.mag_launch_flawless02" = "<clr:209,178,178>Well, I see the Magnusson Device performed flawlessly. "
		"ep_02.mag_launch_forgetmd01" = "<clr:209,178,178>Ah, let's not forget that with the Magnusson device, those striders practically destroy themselves. "
		"ep_02.mag_launch_haventseenhim" = "<clr:209,178,178><I>No, no - haven't seen him. "
		"ep_02.mag_launch_holdon" = "<clr:209,178,178>Hold on a moment, Kleiner. "
		"ep_02.mag_launch_indeed" = "<clr:209,178,178><I>Indeed. "
		"ep_02.mag_launch_launchsequence01" = "<clr:209,178,178><I>Silo doors open. "
		"ep_02.mag_launch_launchsequence02" = "<clr:209,178,178><I>Stations everyone. "
		"ep_02.mag_launch_launchsequence03" = "<clr:209,178,178><I>Power to main thrusters. "
		"ep_02.mag_launch_launchsequence04" = "<clr:209,178,178><I>Steady on. "
		"ep_02.mag_launch_launchsequence05" = "<clr:209,178,178><I>We are launching. "
		"ep_02.mag_launch_launchsequence06" = "<clr:209,178,178><I>Steady, steady. "
		"ep_02.mag_launch_launchsequence07" = "<clr:209,178,178><I>We... we have lift-off. "
		"ep_02.mag_launch_launchsequence08a" = "<clr:209,178,178><I>We have lift-off. "
		"ep_02.mag_launch_launchsequence08b" = "<clr:209,178,178><I>Lift-off. "
		"ep_02.mag_launch_launchsequence08c" = "<clr:209,178,178><I>Lift-off! Oh, it worked... it worked! "
		"ep_02.mag_launch_launchsequence08d" = "<clr:209,178,178><I>Oh, oh I must I must get control of myself.  Oh, deep breaths, deep breaths."
		"ep_02.mag_launch_launchsequence09a" = "<clr:209,178,178><I>Oh my rocket! Oh my rocket works! Ah... "
		"ep_02.mag_launch_launchsequence09b" = "<clr:209,178,178><I>I'm a genius! "
		"ep_02.mag_launch_launchsequence09c" = "<clr:209,178,178><I>I told you it would all work! I knew it would work! "
		"ep_02.mag_launch_launchsequence09d" = "<clr:209,178,178><I>Thank you, Freeman. "
		"ep_02.mag_launch_onlyabutton" = "<clr:209,178,178><I>Oh, for God's sake. It's only a button. Just press it, that's all I ask. "
		"ep_02.mag_launch_portalresponse01" = "<clr:209,178,178>"
		"ep_02.mag_launch_portalresponse02" = "<clr:209,178,178>"
		"ep_02.mag_launch_portalresponse03" = "<clr:209,178,178>"
		"ep_02.mag_launch_portalresponse04" = "<clr:209,178,178>"
		"ep_02.mag_launch_premature01" = "<clr:209,178,178><I>Now... now, it's still too early to celebrate. "
		"ep_02.mag_launch_premature02" = "<clr:209,178,178><I>We need to reach altitude and transmit the signal. "
		"ep_02.mag_launch_premature03" = "<clr:209,178,178><I>Assuming Kleiner decoded it correctly. "
		"ep_02.mag_launch_pushingit" = "<clr:209,178,178><I>That's it then - I'm pushing it. Try and stop me! "
		"ep_02.mag_launch_readytostartauto" = "<clr:209,178,178><I>I believe we're ready to start the autosequence. "
		"ep_02.mag_launch_solong01" = "<clr:209,178,178><I>What could possibly be taking him so long. "
		"ep_02.mag_launch_solong02" = "<clr:209,178,178><I>Where the hell has he gotten to. "
		"ep_02.mag_launch_standaround" = "<clr:209,178,178><I>Well, doesn't everyone have more important things to do than stand around? "
		"ep_02.mag_launch_startauto01" = "<clr:209,178,178><I>Ready to start autosequence. "
		"ep_02.mag_launch_startauto02" = "<clr:209,178,178><I>I suggest we adjourn this meeting of the mutual admiration society until after we have launched our rocket. "
		"ep_02.mag_launch_thankyou01" = "<clr:209,178,178>I feel compelled to thank you, personally, for saving my rocket. "
		"ep_02.mag_launch_thankyou02" = "<clr:209,178,178>So, um... "
		"ep_02.mag_launch_thankyou03" = "<clr:209,178,178>Thank you. "
		"ep_02.mag_launch_tolerance01" = "<clr:209,178,178><I>Well... that's within tolerance, certainly not worth scuttling the ... "
		"ep_02.mag_launch_tolerance02" = "<clr:209,178,178><I>Ah, Gordon Freeman! "
		"ep_02.mag_launch_what" = "<clr:209,178,178><I>What? "
		"ep_02.mag_launch_wherewerewe" = "<clr:209,178,178><I>Now, where were we? "
		"ep_02.mag_launch_whose" = "<clr:209,178,178><I>Just launch the damn thing! "
		"ep_02.mag_post_pa01" = "<clr:209,178,178><I>That's it!  The last strider has been destroyed!"
		"ep_02.mag_post_pa02" = "<clr:209,178,178><I>The Combine have been repelled!"
		"ep_02.mag_post_pa03" = "<clr:209,178,178><I>Everyone return to base!  Repeat!  All personnel, return to base immediately!  This rocket must launch!"
		"ep_02.mag_post_pa04" = "<clr:209,178,178><I>Clear the field!  White Forest personnel, please clear the field!"
		"ep_02.mag_post_pa05" = "<clr:209,178,178><I>Evacuate the area!  All personnel, return to base or take shelter immediately.  We must clear the area for launch!"
		"ep_02.mag_post_pa06" = "<clr:209,178,178><I>Freeman, if you're still out there, return to base immediately!"
		"ep_02.mag_post_pa07a" = "<clr:209,178,178><I>All personnel, return to base!  "
		"ep_02.mag_post_pa07b" = "<clr:209,178,178><I>And if you see Gordon Freeman, tell him to get his butt in here!"
		"ep_02.mag_rad_expectedyou01" = "<I><clr:209,178,178>Alyx? "
		"ep_02.mag_rad_expectedyou02" = "<I><clr:209,178,178>Alyx Vance? "
		"ep_02.mag_rad_expectedyou03" = "<I><clr:209,178,178>Where are you? "
		"ep_02.mag_rad_expectedyou04" = "<I><clr:209,178,178>I expected you hours ago. "
		"ep_02.mag_rad_gravity01" = "<I><clr:209,178,178>Don't you understand the gravity of the situation? "
		"ep_02.mag_rad_gravity02" = "<I><clr:209,178,178>The survival of Earth depends on the data you carry. "
		"ep_02.mag_rad_hopeso01" = "<I><clr:209,178,178>What - what's that? What? "
		"ep_02.mag_rad_hopeso02" = "<I><clr:209,178,178>You're heading our way? Well I should hope so! "
		"ep_02.mag_rad_hopeso03" = "<I><clr:209,178,178>What? What was that? "
		"ep_02.mag_rad_hopeso04" = "<I><clr:209,178,178>Oh."
		"ep_02.mag_rad_hopeso05" = "<I><clr:209,178,178>You're breaking up, Alyx. "
		"ep_02.mag_rad_hopeso06" = "<I><clr:209,178,178>I cannot hear you. "
		"ep_02.mag_rad_whatwhat01" = "<I><clr:209,178,178>What? "
		"ep_02.mag_rad_whatwhat02" = "<I><clr:209,178,178>What? "
		"ep_02.mag_silo_backtowork01" = "<clr:209,178,178><I>All right, back to work, everyone!  "
		"ep_02.mag_silo_backtowork02" = "<clr:209,178,178><I>It's just another false alarm in the secondary silo."
		"ep_02.mag_silo_changeplans01" = "<clr:209,178,178>All right, people - change of plans. "
		"ep_02.mag_silo_changeplans02" = "<clr:209,178,178>There is no way we can launch before those striders are - "
		"ep_02.mag_silo_datapeople" = "<clr:209,178,178>The data, people, the data! "
		"ep_02.mag_silo_excuseme01" = "<clr:209,178,178>Oh - oh, excuse me if I'm interrupting tea time. "
		"ep_02.mag_silo_excuseme02" = "<clr:209,178,178>I'll just step out until you've finished if that's more convenient. "
		"ep_02.mag_silo_falsealarms01" = "<clr:209,178,178>Hello. "
		"ep_02.mag_silo_falsealarms02" = "<clr:209,178,178>Hello, is anyone there? "
		"ep_02.mag_silo_falsealarms03" = "<clr:209,178,178>Anyone? "
		"ep_02.mag_silo_falsealarms04" = "<clr:209,178,178>False alarms all day - damn crows have been nesting in the tracks. I do not know how I am supposed to concentrate with all of this racket. "
		"ep_02.mag_silo_follownags01" = "<clr:209,178,178>Now, follow me. "
		"ep_02.mag_silo_follownags02" = "<clr:209,178,178>Freeman! "
		"ep_02.mag_silo_follownags03" = "<clr:209,178,178>Follow me "
		"ep_02.mag_silo_follownags04" = "<clr:209,178,178>Follow me, Freeman. "
		"ep_02.mag_silo_follownags05" = "<clr:209,178,178>Freeman! "
		"ep_02.mag_silo_follownags06" = "<clr:209,178,178>Freeman - follow and quickly! "
		"ep_02.mag_silo_follownags07" = "<clr:209,178,178>Freeman - where the hell are you? "
		"ep_02.mag_silo_followquick01" = "<clr:209,178,178>Well, Freeman."
		"ep_02.mag_silo_followquick02" = "<clr:209,178,178>I believe I've found the perfect use for you."
		"ep_02.mag_silo_followquick03" = "<clr:209,178,178>Follow me. "
		"ep_02.mag_silo_followquick04" = "<clr:209,178,178>Quickly."
		"ep_02.mag_silo_goahead" = "<clr:209,178,178><I>If you're waiting for the Combine's go-ahead, they'll soon be here to give it to you in person! "
		"ep_02.mag_silo_guarant" = "<clr:209,178,178>You have my word on it! "
		"ep_02.mag_silo_kleinercert01" = "<clr:209,178,178>The last thing on my mind was submitting it for the Kleiner certificate of approval. "
		"ep_02.mag_silo_kleinercert02" = "<clr:209,178,178>Whatever troubles we might have had were the result of staffing and supply deficiencies. "
		"ep_02.mag_silo_laddernags01" = "<clr:209,178,178>Take this ladder down. "
		"ep_02.mag_silo_laddernags02" = "<clr:209,178,178>Quickly man - the ladder. "
		"ep_02.mag_silo_laddernags03" = "<clr:209,178,178>Hurry and get down that ladder. "
		"ep_02.mag_silo_laddernags04" = "<clr:209,178,178>The ladder's here. "
		"ep_02.mag_silo_lamarr" = "<clr:209,178,178>And get your cranio-conjugal parasite away from my nose cone! "
		"ep_02.mag_silo_makeuseful" = "<clr:209,178,178>Freeman - Freeman, you're not doing anything. Make yourself useful and find out what the hell is going on in there. "
		"ep_02.mag_silo_needahand01" = "<clr:209,178,178><I>Kleiner, where are you? "
		"ep_02.mag_silo_needahand02" = "<clr:209,178,178><I>Why isn't the decoding finished? "
		"ep_02.mag_silo_needyouhere" = "<clr:209,178,178><I>I need you over here."
		"ep_02.mag_silo_notagain" = "<clr:209,178,178>Oh, not again. What the hell is going on in the secondary silo? "
		"ep_02.mag_silo_parade01" = "<clr:209,178,178>Oh, what next in the parade of constant interruptions? "
		"ep_02.mag_silo_redcarpet" = "<clr:209,178,178>Oh, fine - no one grants me a moment's peace, but by all means - unroll the red carpet. "
		"ep_02.mag_silo_reunion" = "<clr:209,178,178>Kleiner, are you going to sync up the satellite? Or should I postpone the launch to make time for a family reunion? "
		"ep_02.mag_silo_sendtosecondsilo01" = "<clr:209,178,178>I'll open this hatch to let you down. "
		"ep_02.mag_silo_sendtosecondsilo02" = "<clr:209,178,178>The blast doors will have sealed due to the alert, so you'll have to go through the bottom of the launch tube. "
		"ep_02.mag_silo_sendtosecondsilo03" = "<clr:209,178,178>Now, once you're down there, I'll have Uriah let you into the secondary silo. "
		"ep_02.mag_silo_thisway" = "<clr:209,178,178>This way, Freeman. "
		"ep_02.mag_silo_waitingforhug01" = "<clr:209,178,178>Well what are you waiting for Freeman, a hug? "
		"ep_02.mag_silo_waitingforhug02" = "<clr:209,178,178>The situation is not going to investigate itself! "
		"ep_02.mag_silo_wheregoing" = "<clr:209,178,178>Where do you think you're going, Freeman? "
		"ep_02.mag_transmit_linchpin" = "<clr:209,178,178><I>Well, of course they have. You see, Kleiner, it's the linchpin of all of their plans. "
		"ep_02.mag_transmit_nodoubt01" = "<clr:209,178,178><I>Now, if I'm right about this - and I have no reason to doubt myself - you are carrying the very code Doctor Mossman had hoped to recover. "
		"ep_02.mag_transmit_nodoubt02" = "<clr:209,178,178><I>Now, how soon can you get here? "
		"ep_02.mag_transmit_nowaste01" = "<clr:209,178,178><I>There is no time to waste. "
		"ep_02.mag_transmit_nowaste02" = "<clr:209,178,178><I>We'll need to step up the launch schedule. "
		"ep_02.mag_transmit_nowaste03" = "<clr:209,178,178><I>Now as soon as you get here with the signature data, we'll encode the satellite and get the damn thing into orbit. "
		"ep_02.mag_transmit_sequence01" = "<clr:209,178,178><I>Somewhere in that sequence, they would have had to establish a connection with the far side "
		"ep_02.mag_transmit_sequence02" = "<clr:209,178,178><I>What you have there young lady, is the specific contact code for the Combine Overworld. "
		"ep_02.mag_transmit_whatnow" = "<clr:209,178,178><I>Yes, yes, I'm not deaf. "
		"ep_02.mag_tutor_aimforcarap" = "<clr:209,178,178>Aim for the carapace. "
		"ep_02.mag_tutor_aimforupperbody" = "<clr:209,178,178>Aim for the upper body, man. "
		"ep_02.mag_tutor_amplesupply" = "<clr:209,178,178>Now, every building in the valley has its own dispenser port so you'll have ample supply of explosives. "
		"ep_02.mag_tutor_anothermiss" = "<clr:209,178,178>And... another miss. "
		"ep_02.mag_tutor_attach" = "<clr:209,178,178>You needn't attach more than one. "
		"ep_02.mag_tutor_backtorocket" = "<clr:209,178,178>Now, I must get back to my rocket, Freeman. "
		"ep_02.mag_tutor_bitmore" = "<clr:209,178,178>A bit more challenging at this range, isn't it. "
		"ep_02.mag_tutor_brawn01" = "<clr:209,178,178>Now, you've proved yourself capable, and the staff seem to respect you. Therefore, I'm putting defense of White Forest, and this ingenious new weapon of mine, in your hands. "
		"ep_02.mag_tutor_carapfreeman" = "<clr:209,178,178>The carapace. Freeman. "
		"ep_02.mag_tutor_darelaunch01" = "<clr:209,178,178>Freeman, striders are coming. "
		"ep_02.mag_tutor_darelaunch02" = "<clr:209,178,178>A single one of those damn things could shoot down our rocket. "
		"ep_02.mag_tutor_darelaunch03" = "<clr:209,178,178>We don't dare launch until all striders are destroyed. "
		"ep_02.mag_tutor_debacle" = "<clr:209,178,178>Oh, and Freeman! If you pull this off, I might just forgive you for that debacle at Black Mesa. You know the one I mean - involving a certain microwave casserole. "
		"ep_02.mag_tutor_debacle_dist" = "<clr:209,178,178>Oh, and Freeman! If you pull this off, I might just forgive you for that debacle at Black Mesa. You know the one I mean... involving a certain microwave casserole. "
		"ep_02.mag_tutor_exprop" = "<clr:209,178,178>I said we should expropriate that hazard suit and give it to Doctor Mossman. Maybe now they'll listen to me. "
		"ep_02.mag_tutor_fartarget" = "<clr:209,178,178>Uriah, send the target to the far end of the rails. "
		"ep_02.mag_tutor_figuratively" = "<clr:209,178,178>When I remarked that with the Magnusson Device the striders would destroy themselves, I was speaking figuratively. "
		"ep_02.mag_tutor_finally" = "<clr:209,178,178>Finally. "
		"ep_02.mag_tutor_firearm" = "<clr:209,178,178>Good. Now take out the firearm of your choice and shoot the device. "
		"ep_02.mag_tutor_fragile" = "<clr:209,178,178>As you can see, the Magnussons are fragile. They will disintegrate immediately if they miss their target. "
		"ep_02.mag_tutor_fueled" = "<clr:209,178,178>Your car is fueled and ready to go. "
		"ep_02.mag_tutor_getinpractice" = "<clr:209,178,178>Follow me and we'll let you get in some practice while we still have time. "
		"ep_02.mag_tutor_giveitathrow" = "<clr:209,178,178>Give it a throw. "
		"ep_02.mag_tutor_gravitygun01" = "<clr:209,178,178>Hmm? The Gravity gun? "
		"ep_02.mag_tutor_gravitygun02" = "<clr:209,178,178>What those loafers back there would call your gravity gun. "
		"ep_02.mag_tutor_hadenough" = "<clr:209,178,178>Had enough? "
		"ep_02.mag_tutor_homing" = "<clr:209,178,178>The device has an inbuilt homing function...if you get it in close range of the strider, it will close the gap and affix itself to the carapace. "
		"ep_02.mag_tutor_impaling" = "<clr:209,178,178>Don't be alarmed, Freeman. This strider's days of impaling your friends are a thing of the past. "
		"ep_02.mag_tutor_longasyoulike" = "<clr:209,178,178>Practice as long as you like. "
		"ep_02.mag_tutor_looklively" = "<clr:209,178,178>Now look lively in there. Warm up the delivery port. "
		"ep_02.mag_tutor_magdevice01" = "<clr:209,178,178>We call it the Magnusson Device. "
		"ep_02.mag_tutor_magdevice02" = "<clr:209,178,178>Not my chosen label you understand, but it seemed to please the personnel. "
		"ep_02.mag_tutor_magnif" = "<clr:209,178,178>Magnificent device, isn't it? "
		"ep_02.mag_tutor_miss01" = "<clr:209,178,178>Miss. "
		"ep_02.mag_tutor_miss02" = "<clr:209,178,178>Miss! "
		"ep_02.mag_tutor_miss03" = "<clr:209,178,178>Miss! "
		"ep_02.mag_tutor_moveon" = "<clr:209,178,178>Now, let's move on to a more challenging task. "
		"ep_02.mag_tutor_noisaidcarap" = "<clr:209,178,178>No, I said the - the carapace! "
		"ep_02.mag_tutor_notshot" = "<clr:209,178,178>You've ably demonstrated what happens when the device is not shot. Now shoot it. "
		"ep_02.mag_tutor_nottoohard01" = "<clr:209,178,178>There you go. "
		"ep_02.mag_tutor_nottoohard02" = "<clr:209,178,178>Not too difficult at this range, is it? Gets a bit harder when it's moving about and firing at you, of course. "
		"ep_02.mag_tutor_onedevice01" = "<clr:209,178,178>One device at a time is sufficient, Freeman. "
		"ep_02.mag_tutor_onedevice02" = "<clr:209,178,178>Don't waste them. Each one is a marvel of craftsmanship. "
		"ep_02.mag_tutor_outinfield" = "<clr:209,178,178>Now, out in the field, we'll supply you with all the Magnusson Devices you need through delivery ports like this one. "
		"ep_02.mag_tutor_overhere" = "<clr:209,178,178>I'll be right over here when you are ready to head out. "
		"ep_02.mag_tutor_perfect" = "<clr:209,178,178>More than adequate. "
		"ep_02.mag_tutor_rdu01" = "<clr:209,178,178>Now, what it is, is a sort of a sticky-bomb, although cleverer than that makes it sound. "
		"ep_02.mag_tutor_rdu02" = "<clr:209,178,178>From your point of view, you merely pitch the device at the strider's hull, then blow it up. "
		"ep_02.mag_tutor_rdu03" = "<clr:209,178,178>I've struggled with a mechanism for launching the device, but... well, your Zero Point Energy Field Manipulator clears up that little problem. "
		"ep_02.mag_tutor_rocketsci" = "<clr:209,178,178>This isn't rocket science. Well, my contribution is. All you need to do is shoot the device. "
		"ep_02.mag_tutor_settarget" = "<clr:209,178,178>Uriah - set the target for close range practice. "
		"ep_02.mag_tutor_shell" = "<clr:209,178,178>Good God, man. Carapace. It means 'shell.' Aim for it! "
		"ep_02.mag_tutor_shootthemagdev" = "<clr:209,178,178>Shoot. The. Magnusson. Device. "
		"ep_02.mag_tutor_squander" = "<clr:209,178,178>I'm relying on you not to squander my trust... or my Magnussons! "
		"ep_02.mag_tutor_takeoutdevice" = "<clr:209,178,178>Go ahead and take the device out of the dispenser. "
		"ep_02.mag_tutor_takeyourtime" = "<clr:209,178,178>The Combine are nearly upon us. But by all means, take your time. "
		"ep_02.mag_tutor_thatsright" = "<clr:209,178,178>That's right. "
		"ep_02.mag_tutor_thereuare" = "<clr:209,178,178>There you are."
		"ep_02.mag_tutor_timeforrealthing" = "<clr:209,178,178>Go ahead now. It's time for the real thing. "
		"ep_02.mag_tutor_tossatbody" = "<clr:209,178,178>That's right. Now toss it at the main body of the strider. "
		"ep_02.mag_tutor_unless" = "<clr:209,178,178>Well, unless there's something else... "
		"ep_02.mag_tutor_verywell" = "<clr:209,178,178>Very well, Freeman. Try it now. "
		"ep_02.mag_tutor_wanttousegravgun" = "<clr:209,178,178>Now you'll want to use your gravity gun to throw it. "
		"ep_02.mag_tutor_welldone" = "<clr:209,178,178>Good enough. "
		"ep_02.mag_tutor_wearedoomed" = "<clr:209,178,178>We are doomed. "
		"MISSING" = "<clr:209,178,178>Consider yourself encouraged with all the usual aphorisms regarding practice.  I'll be right over here."
		"ep_02.mirt_battle_anomalies01" = "<I>Picking up some kind of anomalous troop movements...  "
		"ep_02.mirt_battle_anomalies02" = "<I>Can't quite get a bead on em.   Maybe just uh..."
		"ep_02.mirt_battle_anomalies03" = "<I>Well, stay tuned."
		"ep_02.mirt_battle_keepalert" = "<I>Keep alert."
		"ep_02.mirt_battle_northbreach" = "<I>Attention!  North perimeter breach!  We have a strider, approaching from the cranes!"
		"ep_02.mirt_battle_periclear" = "<I>Perimeters clear.  Still no sign of incursion."
		"ep_02.mirt_brief_keepyoucurrent01" = "I'll be staying here to watch the field and send status updates.  "
		"ep_02.mirt_brief_keepyoucurrent02" = "Good luck out there!"
		"ep_02.mirt_brief_mapquicklook01" = "Now, check this map.  "
		"ep_02.mirt_brief_mapquicklook02" = "We're right here at the south end of the valley.  "
		"ep_02.mirt_brief_mapquicklook03" = "Rest of the gang's up north by the old sawmill-here.  "
		"ep_02.mirt_brief_mapquicklook04" = "Head on up there and they'll fill you in on the battle plan."
		"ep_02.mirt_brief_overhere01" = "Dr. Freeman, over here!  "
		"ep_02.mirt_brief_overhere02" = "I've taken a few liberties with your car."
		"ep_02.mirt_brief_ports01" = "I tweaked your onboard radar so that Combine show up red on the dashboard unit now.  "
		"ep_02.mirt_brief_ports02" = "Plus, it'll send a homing signal to your HEV suit, in case you get separated from your car.  "
		"ep_02.mirt_brief_ports03" = "No need to thank me."
		"ep_02.mirt_brief_yanktrunk01" = "Check it out-"
		"ep_02.mirt_brief_yanktrunk02" = "I added a rack for Magnusson Devices back here."
		"ep_02.mirt_post_waytogo01" = "Way to go, Freeman!  The Combine's falling back!  "
		"ep_02.mirt_post_waytogo02" = "I wouldn't say we've got them on the run, but...hell, it's a start!"
		"ep_02.mirt_silo_dogpatrol" = "Mind if we keep Dog patrolling out here?"
		"ep_02.mirt_silo_eliknows01" = "I don't think Eli knows you're here yet."
		"ep_02.mirt_silo_eliknows02" = "He's in the silo 1 access unit.  Right through here."
		"ep_02.mirt_silo_overhere" = "Alyx!  Dr. Freeman!  You made it."
		"ep_02.mirt_silo_trouble01" = "Yeah, we heard you ran into a little trouble out there. "
		"ep_02.mirt_silo_trouble02" = "Combine's been trying to head in the front door. "
		"ep_02.mirt_silo_trouble03" = "I think they learned their lesson. "
		"ep_02.mirt_silo_walk" = "Okay, Dog.  Let's take a walk!"
		"ep_02.over_barn" = "<clr:255,73,24><I> OVERWATCH VOICE:  VITAL ALERT.  AUTONOMOUS UNITS SUBSUMED.  MANDATORY COMPLIANCE WITH ALL TENENTS OF ADVISORIAL ASSISTANCE ACT.  THREAT LEVEL ADJUSTMENT.  PROBE.  EXPUNGE."
		"ep_02.over_camp" = "<clr:255,73,24><I> OVERWATCH VOICE:  ONGOING SECTOR SWEEP.  BIOTICS CONFIRMED.  CONTINUE SURFACE SECTOR SWEEP.  REMOTE COMPLIANCE.  EXTERMINATE.  SEEK PASSIVE SIGNATURE IMPRINT.  MANDATE SUBLEVEL RESTRICTIONS."
		"ep_02.over_inne" = "<clr:255,73,24><I> OVERWATCH VOICE:  ALERT.  ANTICITIZEN ONE ENGAGED.  VANCE SUBPRIME ENGAGED.   EXPUNGE.  MANDATE REMOVAL OF ACTIVE SIGNATURE IMPRINT.  CAUTERIZE AND EXPUNGE."
		"ep_02.over_vista" = "<clr:255,73,24><I> OVERWATCH VOICE:  ALL AUTONOMOUS UNITS:  ACCEPT MANDATORY SECTOR ASSIMILATION.  COORDINATED CONSTRICTION UNDERWAY.  DEBRIDE AND CAUTERIZE.  ENTERING PHASE NINE, ENHANCED COMPLIANCE.  DEPLOY ADVISORY CONTROL AND OVERSIGHT.  SUBMIT AND BE SUBSUMED."
		"ep_02.cit_loudspeaker_01" = "<I>Strider coming in from the cranes."
		"ep_02.cit_loudspeaker_02" = "<I>Strider at the sawmill."
		"ep_02.cit_loudspeaker_03" = "<I>Another strider coming towards the sawmill."
		"ep_02.cit_loudspeaker_04" = "<I>A strider has been spotted by the cranes."
		"ep_02.cit_loudspeaker_05" = "<I>Another strider coming in towards what used to be the sawmill."
		"ep_02.cit_loudspeaker_06" = "<I>Now we have a strider coming in from the water tower."
		"ep_02.cit_loudspeaker_07" = "<I>Strider spotted at the cranes."
		"ep_02.cit_loudspeaker_08" = "<I>Another strider from the water tower."
		"ep_02.cit_loudspeaker_09" = "<I>We have a strider coming in from the cranes."
		"ep_02.cit_loudspeaker_10" = "<I>Now there's one at the sawmill."
		"ep_02.cit_loudspeaker_11" = "<I>They are coming from everywhere--strider spotted at the water tower."
		"ep_02.cit_loudspeaker_12" = "<I>Heads up people, we aren't done yet.  Another strider was just spotted at the sawmill."
		"ep_02.cit_loudspeaker_13" = "<I>One more at the cranes!"
		"ep_02.cit_loudspeaker_atbase" = "<I>Strider at the silo! Strider at the base!"
		"ep_02.cit_loudspeaker_closetobase" = "<I>Alert!  There's a strider getting close to the base!"
		"ep_02.cit_loudspeaker_dropships" = "<I>Looks like that was the last one---Wait a minute!  Get ready, everyone!  We've spotted dropships carrying even more striders!  We have about a minute before they hit, so gear up!  This is going to get ugly before it's over."
		"ep_02.cit_loudspeaker_failure01" = "<I>No!"
		"ep_02.cit_loudspeaker_failure02" = "<I>Oh my god!"
		"ep_02.cit_loudspeaker_failure03" = "<I>They've hit the bunker!"
		"ep_02.cit_loudspeaker_failure04" = "<I>The rocket's destroyed!"
		"ep_02.cit_loudspeaker_failure05" = "<I>We're finished"
		"ep_02.cit_loudspeaker_failure06" = "<I>Oh dear God nooo..."
		"ep_02.cit_loudspeaker_failure07" = "<I>Oh hell.."
		"ep_02.cit_loudspeaker_failure08" = "<I>Well that tears it."
		"ep_02.cit_loudspeaker_failure09" = "<I>I'm sorry Dr. Magnusson.  We let you down."
		"ep_02.cit_loudspeaker_failure10" = "<I>Oh god... Magnusson's gonna be pissed!"
		"ep_02.cit_loudspeaker_fewleft" = "<I>Keep up the good work!  Only a few striders left!"
		"ep_02.cit_loudspeaker_hereyougo" = "<I>I think-uh, yessir, Dr. Magnusson.  Here you go."
		"ep_02.cit_loudspeaker_packs" = "<I>Keep an eye out.  It looks like hunters are traveling with the striders.  They're working in packs!"
		"ep_02.cit_loudspeaker_returntobase01" = "<I>Striders!  Approaching the silo! "
		"ep_02.cit_loudspeaker_returntobase02" = "<I>Fall back and defend the silo!"
		"ep_02.cit_loudspeaker_returntobase03" = "<I>They're getting too close to the silo!"
		"ep_02.cit_loudspeaker_returntobase04" = "<I>We need more defense at the silo!"
		"ep_02.cit_loudspeaker_returntobase05" = "<I>They're closing in on the silo!  Hold them off!"
		"ep_02.cit_loudspeaker_returntobase06" = "<I>Drop what you're doing and get to the base!  Defend the silo!"
		"ep_02.cit_loudspeaker_returntobase07" = "<I>All personnel, get back to the base!  The silo is under attack!"
		"ep_02.cit_loudspeaker_returntobase08" = "<I>That's the base alarm, people!  Fall back and defend the silo!"
		"ep_02.cit_loudspeaker_victory" = "<I>Attention! Attention!  The striders have been defeated!  All personnel return to base immediately.  Repeat. All personnel return to base immediately."
		"ep_02.cit_loudspeaker_wedidit" = "<I>We did it! We held them off!  Good work everyone!"
		"ep_02.cit_loudspeakeralt_05" = "<I>Another strider coming in towards the sawmill wreckage."
		"ep_02.cit_tothesawmill_01" = "You'll find the sawmill at the far end of the valley!"
		"ep_02.cit_tothesawmill_02" = "The sawmill is that way.  They're expecting you."
		"ep_02.cit_tothesawmill_03" = "They're waiting for you in the sawmill-that way!"
		"ep_02.cit_tothesawmill_04" = "If you're looking for the sawmill, it's thataway!"
		"ep_02.reb_1stwave01" = "Did we do it?  Was that it?  Somebody please tell me that was all of them!"
		"ep_02.reb_1stwave02" = "I think we've seen the last of the Combine!  We should have beat their asses years ago!"
		"ep_02.reb_1stwave03" = "Something tells me we haven't seen the last of them."
		"ep_02.reb_1stwave04" = "That's it, we won! WHOOOO! "
		"ep_02.reb_1stwave05" = "I guess it's time to rebuild the sawmill."
		"ep_02.reb_1stwave06" = "I need a nap."
		"ep_02.reb_1stwave07" = "Well, I'll see everyone back at base."
		"ep_02.reb_1stwave08" = "[panting]Is that it?"
		"ep_02.reb_1stwave09" = "That can't be it..."
		"ep_02.reb_1stwave10" = "I don't think we're through yet."
		"ep_02.reb_1stwave11" = "Stay sharp. We're not done yet."
		"ep_02.reb_altfireprompt01" = "The supercharged AR2 ammo really messes up those hunters."
		"ep_02.reb_altfireprompt02" = "That supercharged ammo for your AR2 will kill hunters with one shot!"
		"ep_02.reb_altfireprompt03" = "Use that Combine pulse ammo against em, Freeman!"
		"ep_02.reb_altfireprompt04" = "Alt-fire, Freeman!  Alt-fire!"
		"ep_02.reb_ammocall01" = "Rockets over here!"
		"ep_02.reb_ammocall02" = "Magnussons over here, Freeman!"
		"ep_02.reb_ammocall03" = "More ammo over here!"
		"ep_02.reb_basedestroyed01" = "Nooooooooo!"
		"ep_02.reb_basedestroyed02" = "Oh god no."
		"ep_02.reb_basedestroyed03" = "The rocket! We're dead!"
		"ep_02.reb_basedestroyed04" = "We're history!"
		"ep_02.reb_basesaved01" = "We did it!"
		"ep_02.reb_basesaved02" = "Thanks for your help, Freeman!"
		"ep_02.reb_basesaved03" = "I did it!  I saved the base!  I'm a hero!  Oh, and Dr. Freeman's a hero too!"
		"ep_02.reb_basesaved04" = "Fantastic, Freeman!"
		"ep_02.reb_basesaved05" = "Head on in there, Freeman!"
		"ep_02.reb_basesaved06" = "Here he comes!  Here comes Freeman!"
		"ep_02.reb_basesaved07" = "Free-man! Free-man! Free-man!"
		"ep_02.reb_basesaved08" = "You came through again, Doc."
		"ep_02.reb_battle_needyourcar01" = "You'll need that cool-ass car of yours, Freeman!"
		"ep_02.reb_battle_needyourcar02" = "Don't forget your car, Freeman!  As if anyone could!"
		"ep_02.reb_battle_needyourcar03" = "Use your car, Freeman!"
		"ep_02.reb_battle_needyourcar04" = "Get back to your car!"
		"ep_02.reb_battle_needyourcar05" = "Why are you walkin, man?  You got that car!"
		"ep_02.reb_buildingexplo01" = "Hey, I was living there!"
		"ep_02.reb_buildingexplo02" = "Home sweet-aw, shit!"
		"ep_02.reb_buildingexplo03" = "All right, now it's personal!"
		"ep_02.reb_buildingexplo04" = "Jeez, that place was full of antiques!"
		"ep_02.reb_buildingexplo05" = "Ah Christ."
		"ep_02.reb_buildingexplo06" = "Shit!"
		"ep_02.reb_buildingexplo07" = "I think they're pissed about the citadel."
		"ep_02.reb_calmplususe_01" = "No time now, Doc."
		"ep_02.reb_calmplususe_02" = "Hey, Doc, time for that later."
		"ep_02.reb_calmplususe_03" = "Hey, come on."
		"ep_02.reb_calmplususe_04" = "Little busy right now, Doc."
		"ep_02.reb_cannon_thanks" = "Thanks for clearing out the yard, Freeman!  Heck of a job!"
		"ep_02.reb_chop_alyxinside01" = "Hey Doc, she's in there."
		"ep_02.reb_chop_alyxinside02" = "The car's ready, Freeman.  Alyx is waiting inside."
		"ep_02.reb_chop_alyxinside03" = "Alyx is right in there, Dr. Freeman."
		"ep_02.reb_chop_cheers01" = "[cheering]"
		"ep_02.reb_chop_cheers02" = "Yeah!"
		"ep_02.reb_chop_cheers03" = "[cheering]"
		"ep_02.reb_chop_chopper_hint01" = "Our guns aren't cutting it."
		"ep_02.reb_chop_chopper_hint02" = "Keep trying, we might get lucky."
		"ep_02.reb_chop_chopper_hint03" = "These mines are killing us."
		"ep_02.reb_chop_chopper_hint04" = "Freeman, clear out those mines!"
		"ep_02.reb_chop_chopper_hint05" = "Damn these mines!"
		"ep_02.reb_chop_chopper_hint06" = "Let Freeman handle the mines!"
		"ep_02.reb_chop_chopper_hint07" = "Freeman, you have anything to take down a chopper?"
		"ep_02.reb_chop_chopper_hint08" = "Doc, can that grav gun help us?"
		"ep_02.reb_chop_chopper_hint09" = "Hey, Freeman, try throwing those mines back at the chopper!"
		"ep_02.reb_chop_goodgoing" = "Good going!"
		"ep_02.reb_chop_nowonder" = "Hey, it's Gordon Freeman!  No wonder!"
		"ep_02.reb_chop_roadclear" = "All right, the road's clear!"
		"ep_02.reb_combatuse01" = "Busy now, Doc!"
		"ep_02.reb_combatuse02" = "No time now!"
		"ep_02.reb_combatuse03" = "Not right now!"
		"ep_02.reb_complaint01" = "Dr. Magnuisance, I call him.  That's why he sent me out here."
		"ep_02.reb_complaint02" = "We call em Magnussons cause it doesn't take much to set em off."
		"ep_02.reb_complaint03" = "Hey, this ain't so bad.  We could be inside getting browbeat."
		"ep_02.reb_complaint04" = "You think this is bad, you should spend a day working in Magnusson's nursery. "
		"ep_02.reb_complaint05" = "Sometimes I like to get Magnusson mad just for the fun of it.  Course, it's not much of a challenge."
		"ep_02.reb_healthcall01" = "More health over here!"
		"ep_02.reb_healthcall02" = "Health over here!"
		"ep_02.reb_healthcall03" = "We'll keep this place stocked with health"
		"ep_02.reb_healthcall04" = "We'll keep the outposts stocked with health"
		"ep_02.reb_hunters01" = "Hunters!"
		"ep_02.reb_hunters02" = "Hunters!"
		"ep_02.reb_hunters03" = "They're like striders... but smaller."
		"ep_02.reb_hunters04" = "Oh my god, HUNTERS!"
		"ep_02.reb_hunters05" = "Damn it. Hunters!"
		"ep_02.reb_hunters06" = "Look out, hunters"
		"ep_02.reb_hunters07" = "Eyes of blue and three feet, too."
		"ep_02.reb_huntprompt01" = "You gotta take those hunters out first!"
		"ep_02.reb_huntprompt02" = "Throw something at the hunters!"
		"ep_02.reb_huntprompt03" = "Throw a log at those hunters!"
		"ep_02.reb_huntprompt04" = "Those hunters don't do well against a well-aimed radiator!"
		"ep_02.reb_huntprompt05" = "One time, back in the city, I saw a guy take down a hunter with his bare fists!"
		"ep_02.reb_idles01" = "So...what now?"
		"ep_02.reb_idles02" = "So what happens next?"
		"ep_02.reb_idles03" = "I knew it would end like this."
		"ep_02.reb_idles04" = "Here's where we turn it all around, eh, Freeman?"
		"ep_02.reb_idles05" = "I can handle the truth, Doc.  Should I be worried?"
		"ep_02.reb_idles06" = "Next portal I see, I'm jumping through it.  Anywhere's gotta be better than this."
		"ep_02.reb_idles07" = "Let's take the fight to the Combine, Doc.  Straight to their universe.  Whaddaya say?"
		"ep_02.reb_idles08" = "You know what I'd give for a shower?  I'd give you up to the Combine!  Just kidding."
		"ep_02.reb_idles09" = "Word to the wise, don't eat the k-rations.  They put something in 'em to make you forget the suppression field's down."
		"ep_02.reb_idles10" = "Long time no see.  In fact, we've never met."
		"ep_02.reb_idles11" = "Dr. Freeman.  I'm not a big fan of your work at Black Mesa, but you've been doing a bang-up job lately.  "
		"ep_02.reb_idles13" = "Magnusson said whatever you say, goes."
		"ep_02.reb_idles14" = "You ever miss Black Mesa?  I do.  And I was never even there."
		"ep_02.reb_idles15" = "Well, this place is hell, but at least it's not North America."
		"ep_02.reb_idles16" = "I could get used to living out here."
		"ep_02.reb_lastwave01" = "That seals it. We're dead!"
		"ep_02.reb_lastwave02" = "Defend the base, people!  Don't let 'em near the base!"
		"ep_02.reb_lastwave03" = "They must've brought in every strider on the continent!"
		"ep_02.reb_lastwave04" = "Ah, Freeman, you seein' this?"
		"ep_02.reb_lastwave05" = "Now they're flyin' em in. Great."
		"ep_02.reb_lastwave06" = "Dropships incoming!"
		"ep_02.reb_lastwave07" = "We got dropships!"
		"ep_02.reb_lastwave08" = "Here they come again!"
		"ep_02.reb_lastwave09" = "Incoming!!!"
		"ep_02.reb_lastwave10" = "They're not making this easy!"
		"ep_02.reb_lastwaveannounced01" = "I knew it was too good to last."
		"ep_02.reb_lastwaveannounced02" = "Oh man.  Here we go again."
		"ep_02.reb_lastwaveannounced03" = "God. Damn. It."
		"ep_02.reb_lastwaveannounced04" = "[to self]All right, all right. You're gonna be fine."
		"ep_02.reb_lastwaveannounced05" = "[to self]I'm gonna make it. I am gonna make it."
		"ep_02.reb_lastwaveannounced06" = "It's gonna take a damn miracle to get us out of this."
		"ep_02.reb_lastwaveannounced07" = "These Combine bastards just don't give up..."
		"ep_02.reb_lastwaveannounced08" = "Uh oh..."
		"ep_02.reb_lastwaveannounced09" = "That rocket better work..."
		"ep_02.reb_lastwaveannounced10" = "I don't freakin' believe it."
		"ep_02.reb_lastwaveannounced11" = "No freakin' way."
		"ep_02.reb_lull01" = "It's quiet...too quiet."
		"ep_02.reb_lull02" = "That was too easy."
		"ep_02.reb_lull03" = "I've got a baaaaad feeling about this."
		"ep_02.reb_lull04" = "Freeman, are we done?"
		"ep_02.reb_lull05" = "Thanks for the help, Freeman."
		"ep_02.reb_lull06" = "What do you think, Freeman? They comin' back?"
		"ep_02.reb_lull07" = "Nice work out there, Doc."
		"ep_02.reb_lull08" = "You're an inspiration, Doc."
		"ep_02.reb_magblasted01" = "Don't give up, Freeman!  You're doing great!"
		"ep_02.reb_magblasted02" = "If I had a gravity gun, I'd be right there with you, Doc!"
		"ep_02.reb_magblasted03" = "Take out the Hunters!"
		"ep_02.reb_magblasted04" = "Goddamn Hunters..."
		"ep_02.reb_magblasted05" = "Aim for the Hunters!"
		"ep_02.reb_magblasted06" = "They sure hate these Magnusson devices!"
		"ep_02.reb_magblasted07" = "Those hunters keep shooting the Magnussons!"
		"ep_02.reb_magblasted08" = "That hunter targeted the Magnusson!"
		"ep_02.reb_magblasted09" = "I hate those freakin things!"
		"ep_02.reb_packs01" = "They're traveling in packs!"
		"ep_02.reb_packs02" = "The striders and hunters are working together."
		"ep_02.reb_packs03" = "Watch out for the hunters!"
		"ep_02.reb_packs04" = "The hunters aren't making this easy."
		"ep_02.reb_prepare_battle_01" = "Oh boy, here we go!"
		"ep_02.reb_prepare_battle_02" = "Everyone ready?"
		"ep_02.reb_prepare_battle_03" = "We need to stop em here!"
		"ep_02.reb_prepare_battle_04" = "Good luck, you guys!"
		"ep_02.reb_prepare_battle_05" = "There they are!"
		"ep_02.reb_prepare_battle_06" = "Remember, keep em distracted while Freeman takes em down!"
		"ep_02.reb_prepare_battle_07" = "Where's the water tower again?"
		"ep_02.reb_prepare_battle_08" = "Oh man, this is gonna be bad!"
		"ep_02.reb_prepare_battle_09" = "Hey, stay focused!  Get to cover and start shootin!"
		"ep_02.reb_prepare_battle_10" = "Freeman'll do the hard work!"
		"ep_02.reb_runover01" = "Nice driving, Freeman!"
		"ep_02.reb_runover02" = "There goes your paintjob!"
		"ep_02.reb_runover03" = "Frickin three legged jaywalkers!"
		"ep_02.reb_runover04" = "Oh man, that was cool!"
		"ep_02.reb_runover05" = "[Derisive laughter]"
		"ep_02.reb_runover06" = "BAM!"
		"ep_02.reb_runover07" = "I don't think that one's getting up again."
		"ep_02.reb_runover08" = "Back over it!"
		"ep_02.reb_runover09" = "Take that, Dumbass!"
		"ep_02.reb_runover10" = "Heh heh!"
		"ep_02.reb_sawmillexplo01" = "Oh my god-not the sawmill!  Is nothing sacred?"
		"ep_02.reb_sawmillexplo02" = "Look out!"
		"ep_02.reb_sawmillexplo03" = "Ho-ly shit!"
		"ep_02.reb_sawmillexplo04" = "Duck!"
		"ep_02.reb_sawmillexplo05" = "AHHH!"
		"ep_02.reb_sawmillexplo06" = "Goddamn it, TAKE IT DOWN!"
		"ep_02.reb_sawmillexplo07" = "What the-?"
		"ep_02.reb_shootmag01" = "Aim for the Mag Device!"
		"ep_02.reb_shootmag02" = "Aim for the device!"
		"ep_02.reb_shootmag03" = "Now take it down!"
		"ep_02.reb_shootmag04" = "Finish it, Freeman!"
		"ep_02.reb_shootmag05" = "Finish it, Doc!"
		"ep_02.reb_shootmag06" = "Shoot the Mag Device!"
		"ep_02.reb_shootmag07" = "Take it down!"
		"ep_02.reb_shootmag08" = "Finish the goddamn thing!"
		"ep_02.reb_silo_bailout" = "Wow!  Wait'll I tell the gang I actually helped bail out Gordon Freeman! (chastenend) I'll be quiet now."
		"ep_02.reb_silo_evacuee" = "Hey, Doc-I just wanted to say thanks.  I was on that train you helped evacuate from City 17."
		"ep_02.reb_silo_extrahands" = "Hey...an extra pair of hands."
		"ep_02.reb_silo_heretheycome" = "Here they come!  It's Alyx and Gordon Freeman!"
		"ep_02.reb_silo_letemthru" = "Yo!  Let em through!"
		"ep_02.reb_silo_magsentyou" = "Magnusson must've sent you, eh?"
		"ep_02.reb_silo_reb_cpl2" = "And who is going to watch him?"
		"ep_02.reb_silo_thruhere" = "Right through here."
		"ep_02.reb_silo_youwereclose" = "We had a feeling you were close when we saw Dog take off like that."
		"ep_02.reb_str_brains01" = "Oh, man!  Brains!"
		"ep_02.reb_str_brains02" = "Whoa!"
		"ep_02.reb_str_brains03" = "Oh my god!"
		"ep_02.reb_str_dogcheers01" = "Yeah!"
		"ep_02.reb_str_dogcheers02" = "Wow!"
		"ep_02.reb_str_dogcheers03" = "Go, Dog!"
		"ep_02.reb_str_dogcheers04" = "Woo hoo"
		"ep_02.reb_str_dogcheers05" = "Ho, yeah!"
		"ep_02.reb_str_dogcheers06" = "Get him, Dog!"
		"ep_02.reb_str_dogcheers07" = "Get that thing!"
		"ep_02.reb_str_dogcheers08" = "Bring it down!"
		"ep_02.reb_str_dogcheers09" = "On your knees, Strider!"
		"ep_02.reb_str_godog01" = "Go get em, boy!"
		"ep_02.reb_str_godog02" = "Look at him go!"
		"ep_02.reb_str_godog03" = "Make way!"
		"ep_02.reb_str_strider" = "Strider!"
		"ep_02.reb_str_upriver" = "We've been waiting for you.  Just follow the stream, then head up the other side.  White Forest is right there.  You can't miss it!"
		"ep_02.reb_str_youallright" = "You all right down there?  Is Dog okay?"
		"ep_02.reb_striderdown01" = "Nice one, Freeman!"
		"ep_02.reb_striderdown02" = "You've really got a way with those Magnussons!"
		"ep_02.reb_striderdown03" = "Magnusson would be proud!"
		"ep_02.reb_striderdown04" = "Keep up the good work, Doc!"
		"ep_02.reb_striderdown05" = "HAHAHA YEAH!"
		"ep_02.reb_striderdown06" = "YES!"
		"ep_02.reb_striderdown07" = "Yeah!"
		"ep_02.reb_striderdown08" = "Whoo hoo!"
		"ep_02.reb_striderdown09" = "Nice shot, Doc!"
		"ep_02.reb_striderdown10" = "Right in the melon!"
		"ep_02.reb_striderdown11" = "Die! [to self] Freakin' bug."
		"ep_02.reb_striderdown12" = "Eat it!"
		"ep_02.reb_striderdown13" = "Keep it up, Doc!"
		"ep_02.rebel_rad_id" = "<I>This is White forest. Identify yourself."
		"ep_02.silo_reb_thruhere" = "Right through here."
		"ep2_rebel.reb_ammo01" = "Here, ammo."
		"ep2_rebel.reb_ammo02" = "Take this ammo."
		"ep2_rebel.reb_ammo03" = "Ammo, Freeman."
		"ep2_rebel.reb_ammo04" = "Freeman, ammo."
		"ep2_rebel.reb_ammo05" = "You can use this."
		"ep2_rebel.reb_ammo06" = "Lock and load Doc."
		"ep2_rebel.reb_ammo07" = "Got some ammo for you doc."
		"ep2_rebel.reb_antlions01" = "Antlions."
		"ep2_rebel.reb_antlions02" = "Antlions!"
		"ep2_rebel.reb_antlions03" = "Damn bugs."
		"ep2_rebel.reb_antlions04" = "Damn bugs!"
		"ep2_rebel.reb_antlions05" = "Spray em"
		"ep2_rebel.reb_antlions06" = "Hate bugs."
		"ep2_rebel.reb_antlions07" = "I HATE BUGS"
		"ep2_rebel.reb_antlions08" = "get em off me."
		"ep2_rebel.reb_antlions09" = "Ah. Get em off me. "
		"ep2_rebel.reb_antlions10" = "Bugs!"
		"ep2_rebel.reb_antlions11" = "Bugs."
		"ep2_rebel.reb_antlions12" = "Damn these things."
		"ep2_rebel.reb_antlions13" = "More antlions."
		"ep2_rebel.reb_buddykilled01" = "Ah man, they got em."
		"ep2_rebel.reb_buddykilled02" = "No!"
		"ep2_rebel.reb_buddykilled03" = "Oh god I'm next."
		"ep2_rebel.reb_buddykilled04" = "They killed whatshisface."
		"ep2_rebel.reb_buddykilled05" = "That's it, I'm pissed."
		"ep2_rebel.reb_buddykilled06" = "How many more are going to have to die?"
		"ep2_rebel.reb_buddykilled07" = "Man Down."
		"ep2_rebel.reb_buddykilled08" = "Noo"
		"ep2_rebel.reb_buddykilled09" = "Ah shit!"
		"ep2_rebel.reb_buddykilled10" = "Ah crap"
		"ep2_rebel.reb_buddykilled11" = "Dammit!"
		"ep2_rebel.reb_buddykilled12" = "Bastards!!!"
		"ep2_rebel.reb_buddykilled13" = "Rarrgh!"
