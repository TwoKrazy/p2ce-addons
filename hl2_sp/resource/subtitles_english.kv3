		"ep2_rebel.reb_pardon01" = "Sorry doc."
		"ep2_rebel.reb_pardon02" = "Excuse me."
		"ep2_rebel.reb_pardon03" = "Sorry."
		"ep2_rebel.reb_pardon04" = "Whoops."
		"ep2_rebel.reb_pardon05" = "My fault."
		"ep2_rebel.reb_pardon06" = "I'm sorry about that doc."
		"ep2_rebel.reb_playerdeath01" = "Oh man, not Freeman."
		"ep2_rebel.reb_playerdeath02" = "Hey, that guy, what his name? Just died."
		"ep2_rebel.reb_playerdeath03" = "[empty]"
		"ep2_rebel.reb_playerdeath04" = "That's it, I quit."
		"ep2_rebel.reb_playerdeath05" = "Runnnn!"
		"ep2_rebel.reb_playerdeath06" = "Every man for himself. Every man for himself."
		"ep2_rebel.reb_playerdeath07" = "Is Freeman ok?"
		"ep2_rebel.reb_playerdeath08" = "You ok doc?"
		"ep2_rebel.reb_playerdeath09" = "Doc.. Doc... doc!"
