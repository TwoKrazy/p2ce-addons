		"ep2_rebel.reb_newweapon07" = "Oh cool."
		"ep2_rebel.reb_newweapon08" = "Now I'm ready"
		"ep2_rebel.reb_newweapon09" = "Heh. I'll take this."
		"ep2_rebel.reb_newweapon10" = "This'll work."
		"ep2_rebel.reb_newweapon11" = "Anyone mind if I take this?"
		"ep2_rebel.reb_newweapon12" = "Mine now, mine."
