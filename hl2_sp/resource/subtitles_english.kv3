		"ep_02.al_car_crazy01" = "<clr:255,212,255>[laugh]"
		"ep_02.al_car_crazy02" = "<clr:255,212,255>Gordon!"
		"ep_02.al_car_crazy03" = "<clr:255,212,255>Whoa!"
		"ep_02.al_car_crazy04" = "<clr:255,212,255>Easy there!"
		"ep_02.al_car_crazy05" = "<clr:255,212,255>Yikes!"
		"ep_02.al_car_crazy06" = "<clr:255,212,255>Wow!"
		"ep_02.al_car_crazy07" = "<clr:255,212,255>Whoa!"
		"ep_02.al_car_crazy08" = "<clr:255,212,255>Okay!"
		"ep_02.al_car_getgoing01" = "<clr:255,212,255>Punch it!"
		"ep_02.al_car_getgoing02" = "<clr:255,212,255>Hit it!"
		"ep_02.al_car_getgoing03" = "<clr:255,212,255>Go for it! "
		"ep_02.al_car_getgoing04" = "<clr:255,212,255>Let's go!"
		"ep_02.al_car_hitit" = "<clr:255,212,255>Hit it!"
		"ep_02.al_car_jumpyell01" = "<clr:255,212,255>Yeehaw!"
		"ep_02.al_car_jumpyell02" = "<clr:255,212,255>Ha ha!"
		"ep_02.al_car_jumpyell03" = "<clr:255,212,255>Wooo!"
		"ep_02.al_car_jumpyell04" = "<clr:255,212,255>Yeah!"
		"ep_02.al_car_jumpyell05" = "<clr:255,212,255>Woohoo, yeah!"
		"ep_02.al_car_jumpyell06" = "<clr:255,212,255>Wow!"
		"ep_02.al_car_kickoff01" = "<clr:255,212,255>Ugh!"
		"ep_02.al_car_kickoff02" = "<clr:255,212,255>Get off!"
		"ep_02.al_car_kickoff03" = "<clr:255,212,255>Off, get off."
		"ep_02.al_car_kickoff04" = "<clr:255,212,255>Get off!"
		"ep_02.al_car_killit02" = "<clr:255,212,255>We're drivin' here!"
		"ep_02.al_car_killit03" = "<clr:255,212,255>Splat!"
		"ep_02.al_car_killit04" = "<clr:255,212,255>Kapow"
		"ep_02.al_car_killit05" = "<clr:255,212,255>Oh Gross"
		"ep_02.al_car_killit06" = "<clr:255,212,255>Eww"
		"ep_02.al_car_killit07" = "<clr:255,212,255>Oh!  Roadkill"
		"ep_02.al_car_killit08" = "<clr:255,212,255>Jaywalkers will be prosecuted."
		"ep_02.al_car_killit09" = "<clr:255,212,255>Hey!  Watch the paintjob!"
		"ep_02.al_car_laughing01" = "<clr:255,212,255>[Laughter, shouts]"
		"ep_02.al_car_laughing02" = "<clr:255,212,255>[Laughter, shouts]"
		"ep_02.al_car_laughing03" = "<clr:255,212,255>[Laughter, shouts]"
		"ep_02.al_car_laughing04" = "<clr:255,212,255>[Laughter, shouts]"
		"ep_02.al_car_laughing05" = "<clr:255,212,255>[Laughter, shouts]"
		"ep_02.al_car_laughing06" = "<clr:255,212,255>[Laughter, shouts]"
		"ep_02.al_car_laughing07" = "<clr:255,212,255>[Laughter, shouts]"
		"ep_02.al_car_laughing08" = "<clr:255,212,255>[Laughter, shouts]"
		"ep_02.al_car_laughing09" = "<clr:255,212,255>[Laughter, shouts]"
		"ep_02.al_car_laughing10" = "<clr:255,212,255>[Laughter, shouts]"
		"ep_02.al_car_laughing11" = "<clr:255,212,255>[Laughter, shouts]"
		"ep_02.al_car_laughing12" = "<clr:255,212,255>[Laughter, shouts]"
		"ep_02.al_car_laughing13" = "<clr:255,212,255>[Laughter, shouts]"
		"ep_02.al_car_laughing14" = "<clr:255,212,255>[Laughter, shouts]"
		"ep_02.al_car_nearmiss01" = "<clr:255,212,255>Whoa!"
		"ep_02.al_car_nearmiss02" = "<clr:255,212,255>Hey!"
		"ep_02.al_car_nearmiss03" = "<clr:255,212,255>That was close!"
		"ep_02.al_car_nearmiss04" = "<clr:255,212,255>Cuttin' it pretty close, Gordon!"
		"ep_02.al_car_playerout01" = "<clr:255,212,255>Stay close, ok?"
		"ep_02.al_car_playerout02" = "<clr:255,212,255>I'll stay here."
		"ep_02.al_car_playerout03" = "<clr:255,212,255>I'll watch the car."
		"ep_02.al_car_playerout04" = "<clr:255,212,255>Don't go too far."
		"ep_02.al_car_playerout05" = "<clr:255,212,255>Careful out there!"
		"ep_02.al_car_playerout06" = "<clr:255,212,255>Wake me up when you get back."
		"ep_02.al_car_rolled01a" = "<clr:255,212,255>Whoa!  "
		"ep_02.al_car_rolled01b" = "<clr:255,212,255>Rollover!"
		"ep_02.al_car_rolled02" = "<clr:255,212,255>They made these things to last, didn't they?"
		"ep_02.al_car_rolled03" = "<clr:255,212,255>This car can sure take some abuse."
		"ep_02.al_car_rolled04" = "<clr:255,212,255>Whoa...dizzy..."
		"ep_02.al_car_rolled05" = "<clr:255,212,255>Well, okay..."
		"ep_02.al_car_rolled06" = "<clr:255,212,255>Gordon - you notice anything wrong?"
		"ep_02.al_car_rolled07" = "<clr:255,212,255>Hey, Gordon... You're not gonna leave a girl hanging, are you?"
		"ep_02.al_car_runafter01" = "<clr:255,212,255>Gordon, wait!"
		"ep_02.al_car_runafter02" = "<clr:255,212,255>Wait for me!"
		"ep_02.al_car_runafter03" = "<clr:255,212,255>Hold on!"
		"ep_02.al_car_runafter04" = "<clr:255,212,255>Wait up!"
		"ep_02.al_car_runafter05" = "<clr:255,212,255>Gordon!  Wait for me!"
		"ep_02.al_car_runitover" = "<clr:255,212,255>Run it over!"
		"ep_02.al_car_startle01" = "<clr:255,212,255>[gasps]"
		"ep_02.al_car_startle02" = "<clr:255,212,255>[gasps]"
		"ep_02.al_car_startle03" = "<clr:255,212,255>[gasps]"
		"ep_02.al_car_startle04" = "<clr:255,212,255>What the---!"
		"ep_02.al_car_stayincar01" = "<clr:255,212,255>I'll stay here."
		"ep_02.al_car_stayincar02" = "<clr:255,212,255>I'll wait here."
		"ep_02.al_car_stayincar03" = "<clr:255,212,255>I'm going to rest here."
		"ep_02.al_car_stayincar04" = "<clr:255,212,255>Go ahead."
		"ep_02.al_car_stayincar05" = "<clr:255,212,255>I'll stay with the car."
		"ep_02.al_car_stayincar06" = "<clr:255,212,255>I'll watch the car."
		"ep_02.al_car_stayincar07" = "<clr:255,212,255>You mind if I wait with the car?"
		"ep_02.al_car_stuckup01" = "<clr:255,212,255>Think you can get us down in one piece?"
		"ep_02.al_car_stuckup02" = "<clr:255,212,255>Could you maybe...bring us back to earth?"
		"ep_02.al_car_stuckup03" = "<clr:255,212,255>Nice work."
		"ep_02.al_car_stuckup04" = "<clr:255,212,255>That's better."
		"ep_02.al_chop_alwaysgame01" = "<clr:255,212,255>Oh, he's always up for it."
		"ep_02.al_chop_alwaysgame02" = "<clr:255,212,255>Right, Gordon?"
		"ep_02.al_chop_anytools01" = "<clr:255,212,255>We need to get back on the road, but our engine's shot to hell.  "
		"ep_02.al_chop_anytools02" = "<clr:255,212,255>I don't suppose you've got any tools for working on cars?"
		"ep_02.al_chop_bonus" = "<clr:255,212,255>Not only did they help me fix the car, they threw in a bonus."
		"ep_02.al_chop_cache01" = "<clr:255,212,255>Gordon!  "
		"ep_02.al_chop_cache02" = "<clr:255,212,255>I found a first aid cache!"
		"ep_02.al_chop_cache03" = "<clr:255,212,255>Have a medkit!"
		"ep_02.al_chop_carready01" = "<clr:255,212,255>Hey, Gordon."
		"ep_02.al_chop_carready02" = "<clr:255,212,255>Car's ready."
		"ep_02.al_chop_carready03" = "<clr:255,212,255>Come on back and we'll get going."
		"ep_02.al_chop_cheers01" = "<clr:255,212,255>Yeah!"
		"ep_02.al_chop_cheers02" = "<clr:255,212,255>Awesome Gordon- way to go!"
		"ep_02.al_chop_cheers03" = "<clr:255,212,255>Good work Gordon!"
		"ep_02.al_chop_cheers04" = "<clr:255,212,255>Whoa!  Hey!"
		"ep_02.al_chop_clearup01" = "<clr:255,212,255>Hm."
		"ep_02.al_chop_clearup02" = "<clr:255,212,255>What do you think, Gordon?"
		"ep_02.al_chop_clearup03" = "<clr:255,212,255>Maybe while I'm getting the car fixed up, you can see about clearing up that roadblock?"
		"ep_02.al_chop_craptheengine01" = "<clr:255,212,255>Oh crap! The engine! "
		"ep_02.al_chop_craptheengine02" = "<clr:255,212,255>We may have to ditch the car!"
		"ep_02.al_chop_enginefire01" = "<clr:255,212,255>Whoa!  Hey!"
		"ep_02.al_chop_enginefire02" = "<clr:255,212,255>Oh crap!"
		"ep_02.al_chop_fewsoldiers01" = "<clr:255,212,255>Gordon,  can you take care of that gun?"
		"ep_02.al_chop_fewsoldiers02" = "<clr:255,212,255>I have to fix the car if we are going to have any chance of outrunning the combine. "
		"ep_02.al_chop_findmedkits01" = "<clr:255,212,255>It's not safe here. "
		"ep_02.al_chop_findmedkits02" = "<clr:255,212,255>If you wanna start chipping away at that chopper, I'll poke around and see if i can find any medkits."
		"ep_02.al_chop_getinthere" = "<clr:255,212,255>Let's get in there!"
		"ep_02.al_chop_gladguys" = "<clr:255,212,255>Boy, are we glad to see you guys."
		"ep_02.al_chop_goahead" = "<clr:255,212,255>You go ahead.  I'll look for supplies."
		"ep_02.al_chop_gunnags01" = "<clr:255,212,255>I see. "
		"ep_02.al_chop_gunnags02" = "<clr:255,212,255>Yeah, that's trouble all right."
		"ep_02.al_chop_gunnags03" = "<clr:255,212,255>Take a look, Gordon."
		"ep_02.al_chop_inhere" = "<clr:255,212,255>Gordon! In here!"
		"ep_02.al_chop_mydad01" = "<clr:255,212,255>Yeah."
		"ep_02.al_chop_mydad02" = "<clr:255,212,255>My dad's out there now"
		"ep_02.al_chop_mydad03" = "<clr:255,212,255>Eli Vance."
		"ep_02.al_chop_nagdoor01" = "<clr:255,212,255>Go ahead. Gordon, we really need to get moving."
		"ep_02.al_chop_nagdoor02" = "<clr:255,212,255>He said the trap door was up there."
		"ep_02.al_chop_nags01" = "<clr:255,212,255>Go on, Gordon."
		"ep_02.al_chop_nags02" = "<clr:255,212,255>Someone's got to bring down that chopper..."
		"ep_02.al_chop_nags03" = "<clr:255,212,255>Get the chopper, Gordon!"
		"ep_02.al_chop_nokidding01" = "<clr:255,212,255>[Laugh]"
		"ep_02.al_chop_nokidding02" = "<clr:255,212,255>You weren't kidding! "
		"ep_02.al_chop_nokidding03" = "<clr:255,212,255>We'll be back on the road in no time."
		"ep_02.al_chop_pleasure" = "<clr:255,212,255>Oh, with pleasure."
		"ep_02.al_chop_reason01" = "<clr:255,212,255>Hey, do you know if it is possible to get a message to the White Forest base from here?"
		"ep_02.al_chop_thanksguys01" = "<clr:255,212,255>I'll fill you in on the road, Gordon.  "
		"ep_02.al_chop_thanksguys02" = "<clr:255,212,255>Thanks again, you guys!"
		"ep_02.al_chop_thx" = "<clr:255,212,255>Heh.  Thanks."
		"ep_02.al_chop_waving" = "<clr:255,212,255>Hey, somebody's waving us in."
		"ep_02.al_combat_grim_01" = "<clr:255,212,255>Nice shot!"
		"ep_02.al_combat_grim_02" = "<clr:255,212,255>Good shot!"
		"ep_02.al_combat_grim_03" = "<clr:255,212,255>Great shot!"
		"ep_02.al_combat_grim_04" = "<clr:255,212,255>Nice!"
		"ep_02.al_combat_grim_05" = "<clr:255,212,255>Yeah!"
		"ep_02.al_combat_grim_06" = "<clr:255,212,255>Nice shooting, Gordon!"
		"ep_02.al_combat_grim_07" = "<clr:255,212,255>Here we go!"
		"ep_02.al_combat_grim_08" = "<clr:255,212,255>Here we go..."
		"ep_02.al_combat_grim_09" = "<clr:255,212,255>Let's take em out!"
		"ep_02.al_combat_grim_10" = "<clr:255,212,255>Let's do it!"
		"ep_02.al_combat_grim_11" = "<clr:255,212,255>I got this one!"
		"ep_02.al_combat_panic01" = "<clr:255,212,255>They're everywhere!"
		"ep_02.al_combat_panic02" = "<clr:255,212,255>They're all over!"
		"ep_02.al_guard_itsaguardian" = "<clr:255,212,255>It's a guardian!"
		"ep_02.al_guard_keepmoving01" = "<clr:255,212,255>Let's keep moving."
		"ep_02.al_guard_keepmoving02" = "<clr:255,212,255>Head for the next thumper!"
		"ep_02.al_guard_keepmoving03" = "<clr:255,212,255>Make a break for the thumper, Gordon.  I'll follow you!"
		"ep_02.al_guard_keepmoving04" = "<clr:255,212,255>Gordon, go on!  I'll follow when I can!"
		"ep_02.al_guard_keepmoving05" = "<clr:255,212,255>I'm still a little weak, but I'll catch up!"
		"ep_02.al_guard_keepmoving06" = "<clr:255,212,255>I'll cover you from here."
		"ep_02.al_guard_nevergetpast" = "<clr:255,212,255>We'll never get past those things.  We have to get rid of them."
		"ep_02.al_guard_nicework" = "<clr:255,212,255>Nice work, Gordon.  Sorry I couldn't be more help.  I'm still a little weak."
		"ep_02.al_guard_stucklift01" = "<clr:255,212,255>Looks like the elevator's stuck up there."
		"ep_02.al_guard_stucklift02" = "<clr:255,212,255>See if you can get it to come down, Gordon."
		"ep_02.al_guard_stucklift03" = "<clr:255,212,255>Thanks, Gordon!"
		"ep_02.al_guard_stucklift04" = "<clr:255,212,255>Nice work, Gordon."
		"ep_02.al_guard_takecareguardians" = "<clr:255,212,255>We're gonna have to take out those guards, Gordon."
		"ep_02.al_guard_thanksg" = "<clr:255,212,255>Thanks, Gordon!"
		"ep_02.al_hunter_heyworking" = "<clr:255,212,255>Hey, that's working!"
		"ep_02.al_hunter_hititagain" = "<clr:255,212,255>Hit it again!"
		"ep_02.al_hunter_howmanymore" = "<clr:255,212,255>How many more of these are there?"
		"ep_02.al_hunter_ihate" = "<clr:255,212,255>I hate these things."
		"ep_02.al_hunter_itshurtinggord" = "<clr:255,212,255>It's hurting, Gordon!"
		"ep_02.al_hunter_keepafterit" = "<clr:255,212,255>Keep after it!"
		"ep_02.al_hunter_nicethrow" = "<clr:255,212,255>Nice throw!"
		"ep_02.al_hunter_shootit" = "<clr:255,212,255>Shoot it!"
		"ep_02.al_hunter_shootitnowgord" = "<clr:255,212,255>Shoot it now, Gordon!"
		"ep_02.al_hunter_thatsit" = "<clr:255,212,255>That's it!"
		"ep_02.al_hunter_thatsworking" = "<clr:255,212,255>That's working!"
		"ep_02.al_hunter_wedidit" = "<clr:255,212,255>We did it!"
		"ep_02.al_hunter_weregettingit" = "<clr:255,212,255>Yeah, we're getting it!"
		"ep_02.al_hunter_yeah01" = "<clr:255,212,255>Yeah!"
		"ep_02.al_hunter_yeah02" = "<clr:255,212,255>Yeah!"
		"ep_02.al_hunter_yeah03" = "<clr:255,212,255>Yeah!"
		"ep_02.al_hunter_yeahwedidit" = "<clr:255,212,255>Yeah, we did it!"
		"ep_02.al_inn_getinside" = "<clr:255,212,255>Gordon, come on. Get inside!"
		"ep_02.al_inn_gocomeon" = "<clr:255,212,255>Let's go, come on!"
		"ep_02.al_inn_roadblock01" = "<clr:255,212,255>Crap--roadblock.  "
		"ep_02.al_inn_roadblock02" = "<clr:255,212,255>You know what to do!"
		"ep_02.al_inn_trap" = "<clr:255,212,255>It's a trap!"
		"ep_02.al_inn_wayaround" = "<clr:255,212,255>Well, let's find another way around."
		"ep_02.al_inn_wayouthere" = "<clr:255,212,255>Now why would the Combine put a roadblock way out here?"
		"ep_02.al_junc_ahhuh01" = "<clr:255,212,255>[Mumbling, unconscious moaning]"
		"ep_02.al_junc_ahhuh02" = "<clr:255,212,255>[Mumbling, unconscious moaning]"
		"ep_02.al_junc_ahhuh03" = "<clr:255,212,255>[Mumbling, unconscious moaning]"
		"ep_02.al_junc_ahhuh04" = "<clr:255,212,255>[Mumbling, unconscious moaning]"
		"ep_02.al_junc_ahhuh05" = "<clr:255,212,255>[Mumbling, unconscious moaning]"
		"ep_02.al_junc_ahhuh06" = "<clr:255,212,255>[Mumbling, unconscious moaning]"
		"ep_02.al_junc_beenout01" = "<clr:255,212,255>Ah..."
		"ep_02.al_junc_beenout02" = "<clr:255,212,255>[silence]"
		"ep_02.al_junc_beenout03" = "<clr:255,212,255>How long have I been out?"
		"ep_02.al_junc_expectingus01" = "<clr:255,212,255>We have to get to White Forest. "
		"ep_02.al_junc_expectingus02" = "<clr:255,212,255>It's vital."
		"ep_02.al_junc_gettowhiteforest01" = "<clr:255,212,255>Hurry, Gordon. "
		"ep_02.al_junc_gettowhiteforest02" = "<clr:255,212,255>We've got to get to White Forest."
		"ep_02.al_junc_ineedto01" = "<clr:255,212,255>But..."
		"ep_02.al_junc_ineedto02" = "<clr:255,212,255>I need to..."
		"ep_02.al_junc_ineedto03" = "<clr:255,212,255>mmm... "
		"ep_02.al_junc_ineedto04" = "<clr:255,212,255>[strained breathing]"
		"ep_02.al_junc_ineedto05" = "<clr:255,212,255>[strained breathing]"
		"ep_02.al_junc_luckytobehere01" = "<clr:255,212,255>Whoa..."
		"ep_02.al_junc_luckytobehere02" = "<clr:255,212,255>I don't know what you did,"
		"ep_02.al_junc_luckytobehere03" = "<clr:255,212,255>but I have a feeling I'm lucky to be here."
		"ep_02.al_junc_nexttome01" = "<clr:255,212,255>Come on, Gordon.  "
		"ep_02.al_junc_nexttome02" = "<clr:255,212,255>Next to me."
		"ep_02.al_junc_notwithoutyou01" = "<clr:255,212,255>Come on Gordon, get in."
		"ep_02.al_junc_notwithoutyou02" = "<clr:255,212,255>We're not leaving without you."
		"ep_02.al_junc_ohgod" = "<clr:255,212,255>Oh god..."
		"ep_02.al_junc_soweak" = "<clr:255,212,255>Uh... so weak..."
		"ep_02.al_junc_soweak01" = "<clr:255,212,255>Hours?  "
		"ep_02.al_junc_soweak02" = "<clr:255,212,255>Ah..."
		"ep_02.al_junc_soweak03" = "<clr:255,212,255>We've got to get moving!"
		"ep_02.al_junc_thatsg" = "<clr:255,212,255>Yeah, that's Gordon..."
		"ep_02.al_junc_thoughtdead01" = "<clr:255,212,255>Oh my God.  "
		"ep_02.al_junc_thoughtdead02" = "<clr:255,212,255>I thought..."
		"ep_02.al_junc_thoughtdead03" = "<clr:255,212,255>Uh..."
		"ep_02.al_junc_thoughtdead04" = "<clr:255,212,255>I though for sure I was dead."
		"ep_02.al_junc_vomit01" = "<clr:255,212,255>[Mumbling] "
		"ep_02.al_junc_vomit02" = ""
		"ep_02.al_junc_vomit03" = ""
		"ep_02.al_junc_vomit04" = ""
		"ep_02.al_junc_vomit05" = ""
		"ep_02.al_junc_vomit06" = ""
		"ep_02.al_junc_vomit07" = ""
		"ep_02.al_junc_vomit08" = ""
		"ep_02.al_junc_vomit09" = ""
		"ep_02.al_junc_vomit10" = ""
		"ep_02.al_junc_vomit11" = ""
		"ep_02.al_junc_vomit12" = ""
		"ep_02.al_junc_vomit13" = ""
		"ep_02.al_junc_vomit14" = ""
		"ep_02.al_junc_vomit15" = ""
		"ep_02.al_junc_whattheywere01" = "<clr:255,212,255>A Hunter!  "
		"ep_02.al_junc_whattheywere02" = "<clr:255,212,255>So that's what it was!"
		"ep_02.al_launch_allyours" = "<clr:255,212,255>It's all yours, Gordon."
		"ep_02.al_launch_attackstart01" = "<clr:255,212,255>Gordon!"
		"ep_02.al_launch_attackstart02" = "<clr:255,212,255>Help!"
		"ep_02.al_launch_aw" = "<clr:255,212,255>Dad..."
		"ep_02.al_launch_barrier01" = "<clr:255,212,255>Is that it then?"
		"ep_02.al_launch_barrier02" = "<clr:255,212,255>The barrier's working?"
		"ep_02.al_launch_beallright" = "<clr:255,212,255>Don't worry, Dad.  We'll be all right."
		"ep_02.al_launch_breath01" = "<sfx><norepeat:10><clr:255,212,255>[struggle sounds.]"
		"ep_02.al_launch_breath02" = "<sfx><norepeat:10><clr:255,212,255>[struggle sounds.]"
		"ep_02.al_launch_breath03" = "<sfx><norepeat:10><clr:255,212,255>[struggle sounds.]"
		"ep_02.al_launch_breath04" = "<sfx><norepeat:10><clr:255,212,255>[struggle sounds.]"
		"ep_02.al_launch_breath05" = "<sfx><norepeat:10><clr:255,212,255>[struggle sounds.]"
		"ep_02.al_launch_breath06" = "<sfx><norepeat:10><clr:255,212,255>[struggle sounds.]"
		"ep_02.al_launch_breath07" = "<sfx><norepeat:10><clr:255,212,255>[struggle sounds.]"
		"ep_02.al_launch_breath08" = "<sfx><norepeat:10><clr:255,212,255>[struggle sounds.]"
		"ep_02.al_launch_breath09" = "<sfx><norepeat:10><clr:255,212,255>[struggle sounds.]"
		"ep_02.al_launch_breath10" = "<sfx><norepeat:10><clr:255,212,255>[struggle sounds.]"
		"ep_02.al_launch_breath11" = "<sfx><norepeat:10><clr:255,212,255>[struggle sounds.]"
		"ep_02.al_launch_breath12" = "<sfx><norepeat:10><clr:255,212,255>[struggle sounds.]"
		"ep_02.al_launch_breath13" = "<sfx><norepeat:10><clr:255,212,255>[struggle sounds.]"
		"ep_02.al_launch_breath14" = "<sfx><norepeat:10><clr:255,212,255>[struggle sounds.]"
		"ep_02.al_launch_briefed01" = "<clr:255,212,255>Doctor Kleiner briefed me on everything he learned from the data packet"
		"ep_02.al_launch_briefed02" = "<clr:255,212,255>I'll fill Gordon in on the way."
		"ep_02.al_launch_briefed03" = "<clr:255,212,255>God knows we'll have plenty of time."
		"ep_02.al_launch_bringherback01" = "<clr:255,212,255>It's okay, Dad.  "
		"ep_02.al_launch_bringherback02" = "<clr:255,212,255>Well find Judith and bring her back,"
		"ep_02.al_launch_bringherback03" = "<clr:255,212,255>Come on, Gordon."
		"ep_02.al_launch_bringherback04" = "<clr:255,212,255>The chopper's waiting for us."
		"ep_02.al_launch_bringherback05" = "<clr:255,212,255>Come on, Gordon, the chopper's waiting for us."
		"ep_02.al_launch_byedad01" = "<clr:255,212,255>We will.   "
		"ep_02.al_launch_byedad02" = "<clr:255,212,255>Bye, Dad."
		"ep_02.al_launch_comeon" = "<clr:255,212,255>Come on, Gordon."
		"ep_02.al_launch_comeong" = "<clr:255,212,255>Come on, Gordon!"
		"ep_02.al_launch_comeonin" = "<clr:255,212,255>Come on in, Gordon."
		"ep_02.al_launch_comeonportal" = "<clr:255,212,255>Come on!"
		"ep_02.al_launch_copterworking01" = "<clr:255,212,255>While you were out having fun, I found an old helicopter that I was able to get working."
		"ep_02.al_launch_copterworking02" = "<clr:255,212,255>I've got it all packed up and ready to go. "
		"ep_02.al_launch_copterworking03" = "<clr:255,212,255>I'm afraid we'll need to leave for the Borealis right after the launch."
		"ep_02.al_launch_copterworking04" = "<clr:255,212,255>Never a dull moment, huh?"
		"ep_02.al_launch_countingdog01" = "<clr:255,212,255>Ok, Dog!"
		"ep_02.al_launch_countingdog02" = "<clr:255,212,255>Remember, I'm counting on you."
		"ep_02.al_launch_cue01" = "<clr:255,212,255>Well..."
		"ep_02.al_launch_cue02" = "<clr:255,212,255>Let's get going, Gordon."
		"ep_02.al_launch_dadcry" = "<clr:255,212,255>Dad!  "
		"ep_02.al_launch_daddad01" = "<clr:255,212,255>Dad!  "
		"ep_02.al_launch_daddad02" = "<clr:255,212,255>Dad!  "
		"ep_02.al_launch_dadgetaway01" = "<clr:255,212,255>Dad!  "
		"ep_02.al_launch_dadgetaway02" = "<clr:255,212,255>Get away!   "
		"ep_02.al_launch_dadimnot01" = "<clr:255,212,255>Dad---"
		"ep_02.al_launch_dadimnot02" = "<clr:255,212,255>Don't---"
		"ep_02.al_launch_dambutton" = "<clr:255,212,255>Push the damn button, Gordon!"
		"ep_02.al_launch_damnit" = "<clr:255,212,255>God damn it, let go of him!"
		"ep_02.al_launch_dogspot_alt1" = "<clr:255,212,255>Dog!"
		"ep_02.al_launch_dogspot_alt2" = "<clr:255,212,255>Dog!"
		"ep_02.al_launch_dogspot01" = "<clr:255,212,255>Ah!"
		"ep_02.al_launch_dogspot02" = "<clr:255,212,255>Dog!"
		"ep_02.al_launch_finalstage" = "<clr:255,212,255>The launch is in its final stages."
		"ep_02.al_launch_findus01" = "<clr:255,212,255>Okay, I'll hold you to that. "
		"ep_02.al_launch_findus02" = "<clr:255,212,255>You, too, Dr. Magnusson. "
		"ep_02.al_launch_followme" = "<clr:255,212,255>Follow me, Gordon!"
		"ep_02.al_launch_gassedup" = "<clr:255,212,255>Well, there she is...gassed up and ready to go...  "
		"ep_02.al_launch_gethug" = "<clr:255,212,255>Wow, for a minute there I thought you were gonna get a hug."
		"ep_02.al_launch_getmoving01" = "<clr:255,212,255>Launch the rocket, Gordon! "
		"ep_02.al_launch_getmoving02" = "<clr:255,212,255>We gotta get moving."
		"ep_02.al_launch_gonnamissit" = "<clr:255,212,255>Where are you two?  You're gonna miss it!"
		"ep_02.al_launch_gonnawork" = "<clr:255,212,255>It's going to work, right?"
		"ep_02.al_launch_goonin" = "<clr:255,212,255>Go on in."
		"ep_02.al_launch_hailingfreq01" = "<clr:255,212,255>I think so."
		"ep_02.al_launch_hailingfreq02" = "<clr:255,212,255>Dr. Kleiner gave us the Borealis coordinates.  "
		"ep_02.al_launch_hailingfreq03" = "<clr:255,212,255>We'll keep the hailing frequency open on the chopper radio, in case Judith tries to reach us again."
		"ep_02.al_launch_herewecome01" = "<clr:255,212,255>Well, Gordon,"
		"ep_02.al_launch_herewecome02" = "<clr:255,212,255>I hope that suit of yours is warm because"
		"ep_02.al_launch_herewecome03" = "<clr:255,212,255>Borealis"
		"ep_02.al_launch_herewecome04" = "<clr:255,212,255>Here we come."
		"ep_02.al_launch_heydog01" = "<clr:255,212,255>Dog?  "
		"ep_02.al_launch_heydog02" = "<clr:255,212,255>Hey!  Where are you---"
		"ep_02.al_launch_iloveyou" = "<clr:255,212,255>I love you!"
		"ep_02.al_launch_iloveyoudad" = "<clr:255,212,255>I love you, Dad!"
		"ep_02.al_launch_impaling01" = "<clr:255,212,255>Oh my God, no!"
		"ep_02.al_launch_impaling01_alt" = "<clr:255,212,255>Oh my God, no!"
		"ep_02.al_launch_impaling01_alt2" = "<clr:255,212,255>Oh my God, no!"
		"ep_02.al_launch_inhere01" = "<clr:255,212,255>Gordon..."
		"ep_02.al_launch_inhere02" = "<clr:255,212,255>In here."
		"ep_02.al_launch_inhere03" = "<clr:255,212,255>We're waiting for you"
		"ep_02.al_launch_judith01" = "<clr:255,212,255>Don't worry..."
		"ep_02.al_launch_judith02" = "<clr:255,212,255>we're not coming back without her."
		"ep_02.al_launch_lethimgo01" = "<clr:255,212,255>No...no!  Let him go!  "
		"ep_02.al_launch_lethimgo02" = "<clr:255,212,255>Please let him go!"
		"ep_02.al_launch_lift01" = "<clr:255,212,255>Well...here we are again."
		"ep_02.al_launch_lift02" = "<clr:255,212,255>Seems like we spend half our lives in elevators."
		"ep_02.al_launch_lookout" = "<clr:255,212,255>Look out!"
		"ep_02.al_launch_lookout01" = "<clr:255,212,255>Dad!  Look out!"
		"ep_02.al_launch_loveyoudont01" = "<clr:255,212,255>Yes "
		"ep_02.al_launch_loveyoudont02" = "<clr:255,212,255>All right."
		"ep_02.al_launch_loveyoudont03" = "<clr:255,212,255>Dad!"
		"ep_02.al_launch_moveitnag01" = "<clr:255,212,255>Time to launch that rocket, Gordon."
		"ep_02.al_launch_moveitnag02" = "<clr:255,212,255>They're all waiting for us."
		"ep_02.al_launch_moveitnag03a" = "<clr:255,212,255>Let's go to the control room.  "
		"ep_02.al_launch_moveitnag03b" = "<clr:255,212,255>We can get a great view of the launch from there."
		"ep_02.al_launch_moveon" = "<clr:255,212,255>Everything okay?"
		"ep_02.al_launch_moving01" = "<clr:255,212,255>Well, you gonna push the button?"
		"ep_02.al_launch_moving02" = "<clr:255,212,255>Launch the rocket, Gordon! We gotta get moving. "
		"ep_02.al_launch_no01" = "<clr:255,212,255>No!"
		"ep_02.al_launch_no02a" = "<clr:255,212,255>No!"
		"ep_02.al_launch_no02b" = "<clr:255,212,255>Dad!"
		"ep_02.al_launch_nodad01" = "<clr:255,212,255>Dad!  "
		"ep_02.al_launch_nohug" = "<clr:255,212,255>What, no hug?"
		"ep_02.al_launch_noooo" = "<clr:255,212,255>Noooo!"
		"ep_02.al_launch_noooo_alt1" = "<clr:255,212,255>Noooo!"
		"ep_02.al_launch_noooo_alt2" = "<clr:255,212,255>Noooo!"
		"ep_02.al_launch_noooo_alt3" = "<clr:255,212,255>Noooo!"
		"ep_02.al_launch_ohgord" = "<clr:255,212,255>Gordon..."
		"ep_02.al_launch_ohgord_alt1" = "<clr:255,212,255>Gordon..."
		"ep_02.al_launch_ohgord_alt2" = "<clr:255,212,255>Gordon..."
		"ep_02.al_launch_ohnodad01" = "<clr:255,212,255>Oh no.  "
		"ep_02.al_launch_ohnodad02" = "<clr:255,212,255>Dad!"
		"ep_02.al_launch_onelevator01" = "<clr:255,212,255>You coming, Gordon?"
		"ep_02.al_launch_onelevator02" = "<clr:255,212,255>We're holding the lift for you, Gordon."
		"ep_02.al_launch_onelevator03" = "<clr:255,212,255>Come on, Gordon."
		"ep_02.al_launch_orders01" = "<clr:255,212,255>Now remember, Dog has strict orders to look after you."
		"ep_02.al_launch_orders02" = "<clr:255,212,255>So don't get into any trouble."
		"ep_02.al_launch_pieta01" = "<clr:255,212,255>[sobbing]"
		"ep_02.al_launch_pieta01a" = "<clr:255,212,255>Oh God!"
		"ep_02.al_launch_pieta01b" = "<clr:255,212,255>Dad."
		"ep_02.al_launch_pieta01c" = "<clr:255,212,255>Dad, please. Dad!"
		"ep_02.al_launch_pieta01d" = "<clr:255,212,255>Oh my God!"
		"ep_02.al_launch_pieta01e" = "<clr:255,212,255>[sobbing]"
		"ep_02.al_launch_pieta01f" = "<clr:255,212,255>[sobbing]"
		"ep_02.al_launch_pieta01g" = "<clr:255,212,255>[sobbing]"
		"ep_02.al_launch_pieta01h" = "<clr:255,212,255>[sobbing]"
		"ep_02.al_launch_pieta01i" = "<clr:255,212,255>[sobbing]"
		"ep_02.al_launch_pieta01j" = "<clr:255,212,255>No..."
		"ep_02.al_launch_pieta01k" = "<clr:255,212,255>[sobbing]"
		"ep_02.al_launch_pieta01l" = "<clr:255,212,255>[sobbing]"
		"ep_02.al_launch_pieta01m" = "<clr:255,212,255>[sobbing]"
		"ep_02.al_launch_pieta01n" = "<clr:255,212,255>[sobbing]"
		"ep_02.al_launch_pieta01o" = "<clr:255,212,255>[sobbing]"
		"ep_02.al_launch_pieta01p" = "<clr:255,212,255>[sobbing]"
		"ep_02.al_launch_pieta01q" = "<clr:255,212,255>Oh my God!"
		"ep_02.al_launch_pieta01r" = "<clr:255,212,255>No."
		"ep_02.al_launch_pieta01s" = "<clr:255,212,255>No...don't leave me."
		"ep_02.al_launch_pieta01t" = "<clr:255,212,255>[sobbing]"
		"ep_02.al_launch_pieta01u" = "<clr:255,212,255>Dad."
		"ep_02.al_launch_pieta01v" = "<clr:255,212,255>[sobbing]"
		"ep_02.al_launch_pieta02" = "<clr:255,212,255>[sobbing]"
