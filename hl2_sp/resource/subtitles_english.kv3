		"ep2_rebel.reb_warnings10" = "Take cover"
		"ep2_rebel.reb_warnings11" = "Head up."
		"ep2_rebel.reb_zombies01" = "Oh god, Zombies."
		"ep2_rebel.reb_zombies02" = "Zombies!"
		"ep2_rebel.reb_zombies03" = "Zombies."
		"ep2_rebel.reb_zombies04" = "Here come zombies."
