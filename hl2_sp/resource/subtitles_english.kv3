		"ep2_rebel.reb_following02" = "I'm following you."
		"ep2_rebel.reb_following03" = "Lead the way."
		"ep2_rebel.reb_following04" = "Mind if I tag along?"
		"ep2_rebel.reb_greet01" = "Hey doc."
		"ep2_rebel.reb_greet02" = "Doctor Freeman."
		"ep2_rebel.reb_greet03" = "Gordon Freeman."
		"ep2_rebel.reb_greet04" = "Howdy Doc."
		"ep2_rebel.reb_greet05" = "Hi."
		"ep2_rebel.reb_greet06" = "Hey there Freeman."
		"ep2_rebel.reb_greet07" = "Hey there Doc."
		"ep2_rebel.reb_headcrabs01" = "Heads up for headcrabs."
		"ep2_rebel.reb_headcrabs02" = "Headcrabs!"
		"ep2_rebel.reb_headcrabs03" = "Head humpers."
		"ep2_rebel.reb_headcrabs04" = "Heads up!  Hahaha."
		"ep2_rebel.reb_headcrabs05" = "These things can have my head when they chew it off my cold, dead neck."
		"ep2_rebel.reb_headcrabs06" = "Don't let em near your head."
		"ep2_rebel.reb_headcrabs07" = "Crabs."
		"ep2_rebel.reb_headcrabs08" = "Watch your heads."
		"ep2_rebel.reb_headcrabs09" = "The colors on this head don't run you bastards."
