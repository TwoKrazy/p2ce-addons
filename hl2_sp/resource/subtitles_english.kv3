		"ep_02.al_launch_portalclose" = "<clr:255,212,255>The portal's close to opening, but Dr. Magnusson's sure we'll be in time to stop it.  "
		"ep_02.al_launch_portalwhoa01" = "<clr:255,212,255>Whoa!   "
		"ep_02.al_launch_portalwhoa02" = "<clr:255,212,255>Yes! Yes!"
		"ep_02.al_launch_portalwhoa03" = "<clr:255,212,255>Oh!"
		"ep_02.al_launch_portalwhoa04" = "<clr:255,212,255>Oh my God!"
		"ep_02.al_launch_praise01" = "<clr:255,212,255>Sweet job out there."
		"ep_02.al_launch_praise02" = "<clr:255,212,255>Wow, nice work, Gordon."
		"ep_02.al_launch_praise03" = "<clr:255,212,255>You're still my hero."
		"ep_02.al_launch_push" = "<clr:255,212,255>Push the button, Gordon."
		"ep_02.al_launch_readywaiting" = "<clr:255,212,255>The chopper's ready and waiting."
		"ep_02.al_launch_rightthisway" = "<clr:255,212,255>Right this way."
		"ep_02.al_launch_rushoff01" = "<clr:255,212,255>As soon as I get back, we'll start on those upgrades for Dog we've been talking about."
		"ep_02.al_launch_seeusoff" = "<clr:255,212,255>Aren't you gonna see us off?"
		"ep_02.al_launch_sigh01" = "<clr:255,212,255>[sigh]"
		"ep_02.al_launch_sigh02" = "<clr:255,212,255>[sigh]"
